{
  "name": "portfolio",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint 'src/**/*.{ts,astro}'",
    "lint:fix": "eslint 'src/**/*.{ts,astro}' --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "check:colors": "node scripts/check-oklch.mjs",
    "check:colors:fix": "node scripts/check-oklch.mjs --fix",
    "typecheck": "astro check && tsc --noEmit"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/mdx": "^5.0.4",
    "@astrojs/sitemap": "^3.7.2",
    "astro": "^6.1.9",
    "astro-favicons": "^3.1.6",
    "gsap": "^3.13.0",
    "typescript": "^5.6.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.2",
    "@typescript-eslint/eslint-plugin": "^8.48.1",
    "@typescript-eslint/parser": "^8.48.1",
    "culori": "^4.0.2",
    "eslint": "^10.2.1",
    "eslint-plugin-astro": "^1.5.0",
    "globals": "^17.5.0",
    "knip": "^6.6.2",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "sass-embedded": "^1.99.0",
    "tailwindcss": "^4.2.2",
    "vite": "^7.3.2"
  }
