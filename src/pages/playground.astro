---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Style Reference — Grant Keller">
  <main class="bg-background-dark text-foundation min-h-screen px-6 pt-16 pb-32 md:px-12 lg:px-20">
    <a class="button">See Stuff</a>
  </main>
</Layout>

<style lang="scss">
  .button {
    position: relative;
    color: var(--color-highlight);
    padding: 0.5rem 1rem;
    border-bottom: 1px solid var(--color-highlight);
    z-index: 3;

    &::before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      transform: translate3d(-100%, 0, 0);
      opacity: 1;
      width: 100%;
      height: 100%;
      z-index: -1;
      background-color: var(--color-highlight);
      transition: all 300ms;
    }
    &::after {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
    }

    &:hover {
      color: black;

      &::before {
        transform: translate3d(0, 0, 0);
      }
    }
  }
</style>
