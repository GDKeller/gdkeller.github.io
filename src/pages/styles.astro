---
import Layout from "../layouts/Layout.astro";

// Pulled directly from src/styles/global.css. Keep in sync when adding tokens.
const colorTokens = [
  { name: "background", group: "structural" },
  // Non-interactive singles first so base+hover pairs land on even-column starts.
  { name: "foundation", group: "attention" },
  { name: "subtle", group: "attention" },
  { name: "faint", group: "attention" },
  { name: "reduced", group: "attention" },
  { name: "emphasis", group: "attention" },
  { name: "emphasis-hover", group: "attention" },
  { name: "accent", group: "attention" },
  { name: "accent-hover", group: "attention" },
  { name: "highlight", group: "attention" },
  { name: "highlight-hover", group: "attention" },
  { name: "secondary-light", group: "secondary" },
  { name: "secondary-emphasis", group: "secondary" },
  { name: "secondary-dark", group: "secondary" },
  { name: "tertiary-highlight", group: "tertiary" },
  { name: "tertiary-highlight-hover", group: "tertiary" },
];

const fontTokens = [
  { name: "blackletter", label: "Manufacturing Consent", role: "Blackletter alias" },
  { name: "prompt", label: "Prompt", role: "Body" },
  { name: "mono", label: "IBM Plex Mono", role: "Monospace" },
];

const displaySizes = ["display-xl", "display-lg", "display-md", "display-sm"];
const headingSizes = ["h1", "h2", "h3", "h4"];
const bodySizes = ["body-lg", "body", "body-sm", "body-xs", "body-2xs"];
const spacingTokens = ["18", "28", "36", "40"];

const groupLabels: Record<string, string> = {
  attention: "Attention hierarchy",
  structural: "Structural",
  secondary: "Secondary family",
  tertiary: "Tertiary family",
};

const groupedColors = Object.keys(groupLabels).map((group) => ({
  group,
  label: groupLabels[group],
  tokens: colorTokens.filter((t) => t.group === group),
}));
---

<Layout title="Style Reference — Grant Keller">
  <main class="bg-background text-foundation min-h-screen px-6 pt-16 pb-32 md:px-12 lg:px-20">
    <header class="border-emphasis/30 mx-auto mb-16 flex max-w-6xl items-end border-b pb-6">
      <div class="mr-auto">
        <p class="text-reduced text-body-2xs font-mono tracking-widest uppercase">
          Style Reference ::: Design Tokens
        </p>
        <h1
          class="font-blackletter text-emphasis mt-4 scale-y-90 text-6xl leading-none tracking-tight md:text-7xl"
        >
          Style Reference
        </h1>
      </div>
      <a
        href="/"
        class="text-accent border-accent hover:bg-accent text-body-xs border-y px-4 py-2 font-mono tracking-widest uppercase transition-colors hover:text-black"
      >
        &larr; Return to Dossier
      </a>
    </header>

    <div class="mx-auto max-w-6xl space-y-24">
      <!-- COLORS -->
      <section aria-labelledby="colors-heading">
        <div class="mb-8 flex items-baseline gap-4">
          <h2
            id="colors-heading"
            class="font-blackletter text-emphasis scale-y-90 text-4xl leading-none tracking-tight md:text-5xl"
          >
            Color
          </h2>
          <span class="text-reduced text-body-2xs font-mono tracking-widest uppercase">
            {colorTokens.length} tokens
          </span>
        </div>

        {
          groupedColors.map((g) => (
            <div class="mb-12">
              <h3 class="text-reduced text-body-xs mb-4 font-mono tracking-widest uppercase">
                {g.label}
              </h3>
              <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 xl:grid-cols-4">
                {g.tokens.map((t) => (
                  <div class="border-emphasis/20 group relative flex items-stretch border">
                    <div
                      class="h-20 w-20 shrink-0 border-r border-black/40"
                      style={`background-color: var(--color-${t.name});`}
                    />
                    <div class="flex flex-col justify-center px-4 py-3">
                      <code class="text-emphasis text-body-sm font-mono leading-tight">
                        --color-{t.name}
                      </code>
                      <code
                        class="text-reduced text-body-2xs mt-1 font-mono leading-tight"
                        data-color-value={t.name}
                      >
                        …
                      </code>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          ))
        }
      </section>

      <!-- FONTS -->
      <section aria-labelledby="fonts-heading">
        <div class="mb-8 flex items-baseline gap-4">
          <h2
            id="fonts-heading"
            class="font-blackletter text-emphasis scale-y-90 text-4xl leading-none tracking-tight md:text-5xl"
          >
            Typography
          </h2>
          <span class="text-reduced text-body-2xs font-mono tracking-widest uppercase">
            {fontTokens.length} families
          </span>
        </div>

        <div class="space-y-6">
          {
            fontTokens.map((f) => (
              <div class="border-emphasis/20 border-b pb-6">
                <div class="mb-3 flex items-baseline gap-4">
                  <code class="text-emphasis text-body-sm font-mono">--font-{f.name}</code>
                  <span class="text-reduced text-body-2xs font-mono tracking-widest uppercase">
                    {f.label} / {f.role}
                  </span>
                </div>
                <p
                  class="text-foundation text-5xl leading-tight md:text-6xl"
                  style={`font-family: var(--font-${f.name});`}
                >
                  The quick brown fox jumps over the lazy dog.
                </p>
                <p class="text-reduced mt-2 text-2xl" style={`font-family: var(--font-${f.name});`}>
                  ABCDEFGHIJKLMNOPQRSTUVWXYZ abcdefghijklmnopqrstuvwxyz 0123456789 ᠅
                </p>
              </div>
            ))
          }
        </div>
      </section>

      <!-- TYPE SCALE -->
      <section aria-labelledby="scale-heading">
        <div class="mb-8 flex items-baseline gap-4">
          <h2
            id="scale-heading"
            class="font-blackletter text-emphasis scale-y-90 text-4xl leading-none tracking-tight md:text-5xl"
          >
            Type Scale
          </h2>
        </div>

        <div class="grid gap-8 md:grid-cols-3">
          {
            [
              { label: "Display", items: displaySizes },
              { label: "Heading", items: headingSizes },
              { label: "Body", items: bodySizes },
            ].map((col) => (
              <div>
                <h3 class="text-reduced text-body-xs mb-4 font-mono tracking-widest uppercase">
                  {col.label}
                </h3>
                <div class="space-y-4">
                  {col.items.map((name) => (
                    <div class="border-emphasis/20 border-b pb-3">
                      <div class="text-reduced text-body-2xs mb-1 font-mono">
                        text-{name} · <span data-text-value={name}>…</span>
                      </div>
                      <div
                        class="text-foundation"
                        style={`font-size: var(--text-${name}); line-height: 1;`}
                      >
                        Aa
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            ))
          }
        </div>
      </section>

      <!-- SPACING -->
      <section aria-labelledby="spacing-heading">
        <div class="mb-8 flex items-baseline gap-4">
          <h2
            id="spacing-heading"
            class="font-blackletter text-emphasis scale-y-90 text-4xl leading-none tracking-tight md:text-5xl"
          >
            Spacing Extensions
          </h2>
        </div>

        <div class="space-y-4">
          {
            spacingTokens.map((name) => (
              <div class="flex items-center gap-6">
                <code class="text-emphasis text-body-sm w-32 shrink-0 font-mono">
                  spacing-{name}
                </code>
                <code
                  class="text-reduced text-body-2xs w-16 shrink-0 font-mono"
                  data-spacing-value={name}
                >
                  …
                </code>
                <div
                  class="bg-accent h-6"
                  style={`width: var(--spacing-${name});`}
                  aria-hidden="true"
                />
              </div>
            ))
          }
        </div>
      </section>
    </div>
  </main>

  <script>
    // Resolve computed values for each token so cards show the actual defined value.
    const rootStyle = getComputedStyle(document.documentElement);
    const resolve = (prefix: string, token: string) =>
      rootStyle.getPropertyValue(`${prefix}${token}`).trim() || "(unset)";

    for (const node of document.querySelectorAll<HTMLElement>("[data-color-value]")) {
      const token = node.dataset.colorValue;
      if (token) node.textContent = resolve("--color-", token);
    }
    for (const node of document.querySelectorAll<HTMLElement>("[data-text-value]")) {
      const token = node.dataset.textValue;
      if (token) node.textContent = resolve("--text-", token);
    }
    for (const node of document.querySelectorAll<HTMLElement>("[data-spacing-value]")) {
      const token = node.dataset.spacingValue;
      if (token) node.textContent = resolve("--spacing-", token);
    }
  </script>
</Layout>
