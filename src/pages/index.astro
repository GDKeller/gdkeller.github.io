---
import Layout from "../layouts/Layout.astro";
import { Picture } from "astro:assets";
import bgImage from "../images/hero/bg_video_glitch.webp";
import SkillsGrid from "../components/SkillsGrid.astro";
import Projects from "../components/Projects.astro";
import Jobs from "../components/Jobs.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import Nypost from "../components/Nypost.astro";
import Footer from "../components/Footer.astro";
import SectionDivider from "../components/SectionDivider.astro";
import Awards from "../components/Awards.astro";
import Talks from "../components/Talks.astro";
import CurrentlyBuilding from "../components/CurrentlyBuilding.astro";
import HeadingSection from "../components/HeadingSection.astro";
import HireModal from "../components/HireModal.astro";
import MobileMenu from "../components/MobileMenu.astro";
import Overlays from "../components/Overlays.astro";
---

<Layout title="Grant Keller | Frontend Software Engineer">
  <main
    class="font-body text-foundation bg-background block"
    aria-label="Portfolio content"
  >
    <Hero />
    <Header />

    <CurrentlyBuilding />

    <div class="overflow-x-hidden">
      <!-- Featured Work: NY Post -->
      <section class="relative block py-20 md:py-28">
        <div class="container mx-auto flex max-w-6xl justify-center px-8 pt-20">
          <HeadingSection text="Featured Work" treatment="glow" />
        </div>
        <Nypost />
      </section>

      <!-- Skills -->
      <section
        id="skills"
        class="relative mx-auto max-w-6xl px-2 py-20 sm:px-4 md:px-8 md:py-20
          lg:max-w-7xl lg:pb-64"
      >
        <SkillsGrid />
      </section>

      <SectionDivider />

      <!-- Experience -->
      <section
        id="jobs"
        class="container mx-auto block w-full max-w-6xl px-2 py-20 sm:px-4
          md:px-8 md:py-20 lg:max-w-7xl"
      >
        <Jobs />
      </section>

      <SectionDivider />

      <!-- Projects -->
      <section
        id="projects"
        class="container mx-auto block max-w-6xl px-2 py-20 sm:px-4 md:px-8
          md:py-20 lg:max-w-7xl"
      >
        <Projects />
      </section>

      <SectionDivider />

      <!-- Awards -->
      <section
        class="relative mx-auto mb-16 max-w-full px-2 py-16 sm:px-4 md:max-w-7xl
          md:px-8 md:pt-48 md:pb-24"
      >
        <Awards />
      </section>

      <SectionDivider />

      <!-- Speaking / Talks -->
      <section
        id="speaking"
        class="relative mx-auto mb-32 max-w-7xl px-2 py-16 sm:px-4 md:py-24
          xl:px-8"
      >
        <Talks />
      </section>
    </div>

    <!-- Glitch overlay -->
    <div
      class="pointer-events-none fixed top-0 left-0 z-10 block h-full w-full
        overflow-hidden opacity-10 mix-blend-color"
    >
      <Picture
        src={bgImage}
        alt=""
        widths={[800, 1600, 2400]}
        sizes="100vw"
        formats={["avif", "webp"]}
        fallbackFormat="jpg"
        loading="lazy"
        class="h-full w-full object-cover"
      />
    </div>

    <Overlays />
  </main>

  <Footer />

  <HireModal />
  <MobileMenu />
</Layout>
