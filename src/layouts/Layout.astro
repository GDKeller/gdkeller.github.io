---
import "../styles/main.css";
import { Font } from "astro:assets";
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="bg-background font-body overflow-x-clip">
  <head>
    <script is:inline>
      try {
        if (localStorage.getItem("portfolio:simple-mode") === "on") {
          document.documentElement.dataset.simpleMode = "on";
        }
      } catch {
        /* localStorage unavailable (Safari private mode); ignore */
      }
    </script>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content="Grant Keller is a senior frontend web developer with over a decade of experience building fast, accessible, user-centered interfaces."
    />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <Font cssVariable="--font-prompt" preload />
    <Font cssVariable="--font-ibm_plex_mono" preload />
    <Font cssVariable="--font-manufacturing_consent" />
  </head>
  <body class="bg-background text-foundation">
    <slot />
    <script>
      document.addEventListener("click", (e) => {
        const trigger = (e.target as HTMLElement).closest<HTMLElement>(
          "[data-open-modal]",
        );
        if (!trigger) return;
        const modalId = trigger.dataset.openModal;
        if (modalId) {
          const modal = document.getElementById(
            modalId,
          ) as HTMLDialogElement | null;
          modal?.showModal();
        }
      });
    </script>
    <script>
      import { initAllAnimations } from "../lib/animations";
      import type {
        GSAPInstance,
        ScrollTriggerInstance,
      } from "../lib/animations";

      // GSAP initialization with modular animations
      window.addEventListener("load", async function () {
        try {
          const { gsap } = await import("gsap");
          const { ScrollTrigger } = await import("gsap/ScrollTrigger");
          const { ScrollToPlugin } = await import("gsap/ScrollToPlugin");

          gsap.registerPlugin(ScrollTrigger, ScrollToPlugin);

          // Wait a bit for all elements to be rendered
          setTimeout(() => {
            initAllAnimations(
              gsap as unknown as GSAPInstance,
              ScrollTrigger as unknown as ScrollTriggerInstance,
            );
          }, 100);
        } catch {
          // GSAP failed to load - site will still function without animations
        }
      });
    </script>
  </body>
</html>
