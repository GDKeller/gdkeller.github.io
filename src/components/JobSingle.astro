---
import { render } from "astro:content";
import EntryCard from "./EntryCard.astro";

const { job } = Astro.props;
const { data } = job;
const { Content } = await render(job);
---

<EntryCard
  title={data.position}
  organization={data.company}
  organizationWebsite={data.companyWebsite}
  logo={data.companyLogo}
  startMonthYear={data.startMonthYear}
  endMonthYear={data.endMonthYear}
  tech={data.tech}
>
  <Content />
</EntryCard>
