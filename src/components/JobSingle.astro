---
import Link from "./Link.astro";
import ProjectSingleImage from "./ProjectSingleImage.astro";
import SkillBadge from "./SkillBadge.astro";

const { job } = Astro.props;
const { data } = job;
const { company, companyLogo, companyWebsite, position, startMonthYear, endMonthYear, tech } = data;
const { Content } = await job.render();
---

<div class="job-card relative z-20 mb-24 pt-8">
  <div class="mb-6 flex flex-col items-start md:flex-row md:items-center">
    {
      companyLogo && (
        <div class="image relative mr-2 mb-4 shrink-0 lg:mr-8 lg:-ml-4">
          <ProjectSingleImage imagePath={companyLogo.src} altText={companyLogo.alt} />
        </div>
      )
    }
    <div class="flex flex-col">
      <div
        class="font-bayon mb-2 flex flex-col justify-start text-2xl sm:flex-row md:text-2xl lg:text-3xl"
      >
        <h3 class="text-emphasis">
          <span class="text-highlight block font-bold sm:inline-block">{position}</span>
          <span class="font-bokor mx-1 hidden sm:inline-block">&nbsp;᠅&nbsp;</span>
          {
            companyWebsite ? (
              <Link href={companyWebsite} target="_blank" class="no-underline">
                {company}
              </Link>
            ) : (
              company
            )
          }
        </h3>
      </div>

      <p class="text-emphasis font-light">
        {startMonthYear ? startMonthYear : null} -
        {endMonthYear ? endMonthYear : "Present"}
      </p>
    </div>
  </div>

  {
    tech && (
      <div class="mt-0 mb-10 text-xs">
        <p class="sr-only">Skills:&nbsp;</p>
        <ul class="flex flex-wrap gap-2">
          {tech.map((t: string, i: number) => (
            <>
              <SkillBadge tag="li" class="mb-1" key={i}>
                {t}
              </SkillBadge>
              {i !== tech.length - 1 && " "}
            </>
          ))}
        </ul>
      </div>
    )
  }

  <div class="job-body list-custom-wrapper prose bg-background relative z-20 max-w-none pr-8 pb-8">
    <Content />
  </div>
  <span
    class="absolute -right-1 -bottom-1 -z-40 h-24 w-48 bg-gradient-to-br from-blue-900/10 via-teal-800/10 to-emerald-400/20 opacity-40"
  >
  </span>
</div>

<style>
  @reference "../styles/global.css";
  .job-card {
    &::before {
      @apply absolute top-1 -left-8 z-0 h-full max-h-96 w-1 bg-gradient-to-b from-emerald-400/20 via-teal-500/15 to-blue-950/20;
      content: "";
    }
    &::after {
      @apply absolute -top-0 -left-8 z-0 h-1 w-12 bg-gradient-to-r from-emerald-400/20 via-teal-500/15 to-blue-950/20;
      content: "";
    }

    .project-image img {
      @apply max-h-20 sm:max-h-20 md:max-h-24 lg:max-h-32;
    }
  }
  .job-body {
    p {
      @apply mb-5;

      &:last-child {
        @apply mb-0;
      }
    }

    ul {
      @apply mt-8;
    }
    li {
      @apply mb-2 pl-6;
    }

    a {
      @apply hover:text-highlight underline;
    }
  }

  .image:before {
    z-index: 0;
    background: radial-gradient(
      circle,
      rgba(0, 150, 100, 0.4) 0%,
      rgba(0, 150, 100, 0.15) 25%,
      transparent 70%
    );
    content: "";
    top: 50%;
    left: 50%;
    height: 100%;
    width: 100%;
    position: absolute;
    transform: translate3d(-50%, -50%, 0) scale(3);
  }
</style>
