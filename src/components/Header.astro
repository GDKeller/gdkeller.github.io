---
import Link from "./Link.astro";
import Nav from "./Nav.astro";
import Oscilloscope from "./Oscilloscope.astro";
import SimpleModeToggle from "./SimpleModeToggle.astro";
import IconGitHub from "./icons/IconGitHub.astro";
import IconLinkedIn from "./icons/IconLinkedIn.astro";
---

<div
  id="header__main"
  class="bg-background-dark sticky top-0 left-0 z-140 block w-full
    justify-between py-0 pr-0 pl-2 shadow-sm duration-100 sm:pl-1"
>
  <div
    class="border-box border-fainter flex w-full items-center justify-between
      border-y"
  >
    <div class="box-border flex items-stretch gap-4">
      <Oscilloscope />
      <Nav />
    </div>
    <div class="bg-fainter flex items-center gap-px pl-px text-sm">
      <SimpleModeToggle />
      <div class="hidden items-center gap-px md:flex">
        <Link
          href="https://github.com/gdkeller"
          target="_blank"
          class="icon-link group hover:bg-accent-hover bg-background-dark hidden
            p-2 transition-colors md:block"
        >
          <IconGitHub
            class="text-emphasis group-hover:text-background-dark
              group-focus-visible:text-background-dark
              group-focus-visible:bg-accent h-8 w-8 transition-all duration-200"
          />
          <span class="sr-only">GitHub</span>
        </Link>
        <Link
          href="https://www.linkedin.com/in/grantdkeller/"
          target="_blank"
          class="icon-link group bg-background-dark hover:bg-accent-hover
            focus-visible:bg-accent-hover hidden p-2 md:block"
        >
          <IconLinkedIn
            class="text-emphasis group-hover:text-background-dark
              group-focus-visible:text-background-dark h-8 w-8 transition-all
              duration-200"
          />
          <span class="sr-only">LinkedIn</span>
        </Link>
      </div>

      <div class="flex overflow-hidden">
        <Link
          href="/Grant Keller Senior UX Engineer Resume 2025.pdf"
          target="_blank"
          variant="hoverAccent"
          class="bg-background-dark hover:bg-accent-hover
            hover:text-background-dark focus-visible:bg-background-dark hidden
            items-center gap-1.5 border-0 px-6 py-4 font-mono text-sm
            leading-none tracking-wide transition-all duration-200 md:flex"
        >
          <span>Resume</span>
        </Link>
        <button
          data-open-modal="hire_me_modal"
          aria-label="Contact"
          class="text-background-dark bg-emphasis hover:bg-highlight
            outline-emphasis hover:outline-highlight relative flex items-center
            px-6 py-2 font-mono text-sm tracking-wide outline-0 transition-all
            duration-150 hover:cursor-pointer"
        >
          <span class="inline-block leading-none">Contact</span>
        </button>
      </div>
    </div>
  </div>
</div>
