---
import Link from "./Link.astro";
import Nav from "./Nav.astro";
import SimpleModeToggle from "./SimpleModeToggle.astro";
import IconGitHub from "./icons/IconGitHub.astro";
import IconLinkedIn from "./icons/IconLinkedIn.astro";
import IconMenu from "./icons/IconMenu.astro";
import arrowDown from "../images/icons/icon_arrow-down.png";
import arrowUp from "../images/icons/icon_arrow-up.png";
import headshotDithered from "../images/headshots/grant-headshot-dithered.png";
---

<div
  id="header__main"
  class="sticky top-0 left-0 z-150 block w-full justify-between py-0 pr-0 pl-0
    shadow-sm duration-100"
>
  <div
    class="border-box pattern-dots flex w-full items-stretch justify-between
      md:border-l"
  >
    <div
      class="border-fainter box-border hidden items-stretch gap-0.5 py-1 pl-0.5
        sm:flex"
    >
      <a
        id="home-link"
        href="#building"
        aria-label="Scroll to next section"
        data-state="at-hero"
        class="home-link focus-visible:bg-accent-hover bg-background-dark
          relative block h-8 w-8 shrink-0 overflow-hidden focus-visible:z-1"
      >
        <img
          src={arrowDown.src}
          alt=""
          width="32"
          height="32"
          class="home-link__icon home-link__icon--down absolute inset-0"
        />
        <img
          src={headshotDithered.src}
          alt=""
          width="32"
          height="32"
          class="home-link__icon home-link__icon--face absolute inset-0"
        />
        <img
          src={arrowUp.src}
          alt=""
          width="32"
          height="32"
          class="home-link__icon home-link__icon--up absolute inset-0"
        />
      </a>
      <Nav />
    </div>
    <div
      class="relative w-full overflow-hidden"
      role="presentation"
      aria-hidden="true"
    >
      <div class="absolute top-1/2 -left-2 flex -translate-y-1/2">
        <p
          class="text-background-dark mr-4 font-mono text-7xl leading-none
            font-bold tracking-wide whitespace-nowrap opacity-20
            text-shadow-[0_0_0.01em_var(--color-faint),0_0_0.02em_var(--color-faint),0_0_0.04em_var(--color-faint)]"
        >
          STX \x02 0x47 0x4B
        </p>
      </div>
    </div>
    <div class="ml-auto flex gap-1 pl-px text-sm">
      <SimpleModeToggle />
      <div class="hidden items-center gap-1 md:flex">
        <Link
          href="https://github.com/gdkeller"
          target="_blank"
          variant="subtle"
          class="icon-link group hover:bg-accent-hover bg-background-dark
            focus-visible:bg-accent-hover hidden h-8 w-8 items-center
            justify-center p-2 focus-visible:z-1 md:flex"
        >
          <IconGitHub
            class="text-emphasis group-hover:text-background-dark
              group-focus-visible:text-background-dark h-8 w-10
              transition-colors duration-200"
          />
          <span class="sr-only">GitHub</span>
        </Link>
        <Link
          href="https://www.linkedin.com/in/grantdkeller/"
          target="_blank"
          variant="subtle"
          class="icon-link group bg-background-dark hover:bg-accent-hover
            focus-visible:bg-accent-hover hidden h-8 w-8 items-center
            justify-center focus-visible:z-1 md:flex"
        >
          <IconLinkedIn
            class="text-emphasis group-hover:text-background-dark
              group-focus-visible:text-background-dark h-6 w-6 transition-colors
              duration-200"
          />
          <span class="sr-only">LinkedIn</span>
        </Link>
      </div>

      <div class="flex gap-0.5">
        <Link
          href="/Grant Keller Senior UX Engineer Resume 2025.pdf"
          target="_blank"
          variant="hoverAccent"
          class="bg-background-dark hover:bg-accent-hover
            hover:text-background-dark focus-visible:bg-accent-hover
            focus-visible:text-background-dark my-0.5 hidden items-center
            border-0 px-4 py-2 font-mono text-xs leading-none tracking-wide
            transition-colors duration-200 focus-visible:z-1 sm:flex"
        >
          <span>Resume</span>
        </Link>
        <button
          data-open-modal="hire_me_modal"
          aria-label="Contact"
          class="text-background-dark bg-emphasis hover:bg-highlight
            focus-visible:bg-highlight relative my-0.5 hidden items-center px-6
            py-2 font-mono text-xs tracking-wide transition-colors duration-150
            hover:cursor-pointer focus-visible:z-1 sm:flex"
        >
          <span>Contact</span>
        </button>
        <button
          data-open-modal="mobile_menu"
          aria-label="Open menu"
          class="text-background-dark bg-emphasis hover:bg-highlight
            focus-visible:bg-highlight relative flex h-10 w-10 items-center
            justify-center transition-colors duration-150 hover:cursor-pointer
            focus-visible:z-1 sm:hidden"
        >
          <IconMenu class="h-6 w-6" />
        </button>
      </div>
    </div>
  </div>
</div>

<style>
  #header__main :global(a:focus-visible),
  #header__main :global(button:focus-visible) {
    outline-offset: 0px;
  }

  .home-link__icon {
    display: none;
  }
  .home-link__icon--down,
  .home-link__icon--up {
    image-rendering: pixelated;
  }
  .home-link[data-state="at-hero"] .home-link__icon--down {
    display: block;
  }
  .home-link[data-state="past-hero"] .home-link__icon--face {
    display: block;
  }
  .home-link[data-state="past-hero"]:hover .home-link__icon--face,
  .home-link[data-state="past-hero"]:focus-visible .home-link__icon--face {
    display: none;
  }
  .home-link[data-state="past-hero"]:hover .home-link__icon--up,
  .home-link[data-state="past-hero"]:focus-visible .home-link__icon--up {
    display: block;
  }
</style>

<script>
  const homeLink = document.getElementById("home-link");
  const hero = document.getElementById("hero");

  if (homeLink && hero) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          homeLink.dataset.state = "at-hero";
          homeLink.setAttribute("href", "#building");
          homeLink.setAttribute("aria-label", "Scroll to next section");
        } else {
          homeLink.dataset.state = "past-hero";
          homeLink.setAttribute("href", "#hero");
          homeLink.setAttribute("aria-label", "Back to top");
        }
      },
      { threshold: 0 },
    );
    observer.observe(hero);
  }
</script>
