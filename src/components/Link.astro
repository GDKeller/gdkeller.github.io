---
interface Props {
  href: string;
  target?: "_blank" | "_self" | "_parent" | "_top";
  class?: string;
  variant?: "default" | "noUnderline" | "subtle" | "hoverAccent";
}

const { href, target, class: className, variant = "default" } = Astro.props;
const relAttr = target === "_blank" ? "noopener noreferrer" : undefined;

const variantStyles = {
  default: "text-highlight underline hover:text-highlight-hover",
  noUnderline: "text-highlight hover:text-highlight-hover",
  subtle: "text-emphasis no-underline hover:text-emphasis-hover",
  hoverAccent: "text-emphasis no-underline hover:text-accent-hover",
};
---

<a
  class:list={[
    "hover:cursor-pointer",
    variantStyles[variant],
    className,
  ]}
  href={href}
  target={target}
  rel={relAttr}><slot /></a
>
