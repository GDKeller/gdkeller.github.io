---
import DateRange from "./DateRange.astro";
import Link from "./Link.astro";
import ProjectSingleImage from "./ProjectSingleImage.astro";
import SkillBadge from "./SkillBadge.astro";

interface Props {
  title: string;
  subtitle?: string;
  organization: string;
  organizationWebsite?: string;
  logo?: { src: string; alt: string };
  startMonthYear?: string;
  endMonthYear?: string;
  tech?: string[];
  image?: { src: string; alt: string };
}

const {
  title,
  subtitle,
  organization,
  organizationWebsite,
  logo,
  startMonthYear,
  endMonthYear,
  tech,
  image,
} = Astro.props;
---

<div class="entry-frame relative mb-24 xl:mb-32">
  <div
    class="entry-card relative grid grid-cols-1 pb-12 md:grid-cols-[1fr_10rem]
      lg:grid-cols-[1fr_12rem] xl:grid-cols-[1fr_18rem] xl:pb-20 2xl:pb-24"
  >
    <span class="entry-backdrop" aria-hidden="true"></span>

    <div
      class="flex flex-col items-start md:col-start-1 md:row-start-1 md:flex-row
        md:items-start"
    >
      {
        logo && (
          <div class="logo relative z-20 mr-2 shrink-0">
            <ProjectSingleImage
              imagePath={logo.src}
              altText={logo.alt}
              class="max-h-20 -translate-x-2 -translate-y-6 md:max-h-24
                md:-translate-x-4 md:-translate-y-4 lg:max-h-32 xl:max-h-40
                xl:-translate-x-8 xl:-translate-y-8 2xl:max-h-48"
            />
          </div>
        )
      }
      <div class="flex w-full justify-between">
        <div
          class="flex flex-col justify-start pb-8 pl-8 md:pt-8 md:pr-4 md:pl-0"
        >
          <h3
            class="text-accent font-display relative z-110 mb-4 text-xl
              leading-snug tracking-wider sm:text-2xl md:text-xl lg:text-3xl
              xl:text-4xl"
          >
            {title}
          </h3>

          {
            subtitle && (
              <p
                class="text-emphasis relative z-110 mb-4 block text-lg
                  leading-none font-light tracking-wider md:text-base lg:text-xl
                  xl:text-2xl"
              >
                {subtitle}
              </p>
            )
          }

          <div
            class="relative z-110 flex flex-col items-baseline gap-y-2
              sm:flex-row sm:flex-wrap"
          >
            <p
              class="text-emphasis block text-xl leading-none font-light
                tracking-wide md:text-base lg:text-xl lg:tracking-wider
                xl:text-2xl"
            >
              {
                organizationWebsite ? (
                  <Link
                    href={organizationWebsite}
                    target="_blank"
                    variant="subtle"
                  >
                    {organization}
                  </Link>
                ) : (
                  organization
                )
              }
            </p>
            <span
              class="text-accent mx-2 hidden leading-none sm:inline-block
                md:mx-0 lg:mx-4"
              aria-hidden="true">&nbsp;᠅&nbsp;</span
            >
            <DateRange
              start={startMonthYear}
              end={endMonthYear}
              class="font-mono text-sm leading-none font-extralight
                whitespace-nowrap lg:text-base xl:text-lg"
            />
          </div>
        </div>
      </div>
    </div>

    {
      tech && tech.length > 0 && (
        <div
          class="skills-list relative z-110 w-full md:col-start-2
            md:row-start-1"
        >
          <p class="sr-only">Skills:&nbsp;</p>
          <div
            class="border-faint pb-4 pl-8 md:border-b-2 md:border-l-2 md:pt-24
              md:pl-4 lg:pt-32 lg:pl-4 xl:pb-8 xl:pl-8"
          >
            <ul
              class="flex w-full flex-wrap text-left font-mono md:max-w-40
                md:flex-col lg:max-w-64"
            >
              {tech.map((t) => (
                <li
                  class="text-2xs mr-2 mb-2 flex items-center md:mr-auto md:mb-4
                    md:items-start lg:text-sm xl:text-base"
                >
                  <span
                    aria-hidden="true"
                    class="text-accent triplecolon mr-2 leading-[0.75em]
                      font-light md:hidden lg:mr-4 lg:block 2xl:mr-6"
                  >
                    :::
                  </span>
                  <SkillBadge
                    tag="span"
                    class="text-emphasis font-extralight uppercase"
                  >
                    {t}
                  </SkillBadge>
                </li>
              ))}
            </ul>
          </div>
        </div>
      )
    }

    <div
      class="prose entry-body list-custom-wrapper font-light tracking-wide"
      style="display: contents"
    >
      <div class="pt-8 pr-8 pl-8 lg:pb-4 lg:pl-12 xl:pl-16">
        {
          image && (
            <div class="mb-10">
              <ProjectSingleImage imagePath={image.src} altText={image.alt} />
            </div>
          )
        }
        <slot />
      </div>
    </div>
  </div>
</div>

<style>
  @reference "../styles/global.css";

  .entry-backdrop {
    position: absolute;
    inset: 0;
    z-index: 2;
    background: var(--color-background-dark);
    clip-path: polygon(0 0, calc(100% - 10rem) 0, 100% 4rem, 100% 100%, 0 100%);
  }

  .entry-frame::after {
    content: "";
    position: absolute;
    inset: -1px;
    z-index: 1;
    pointer-events: none;
    background: var(--color-faint);
    clip-path: polygon(0 0, calc(100% - 5rem) 0, 100% 4rem, 100% 100%, 0 100%);
  }

  @media screen and (min-width: 768px) {
    .entry-frame::after {
      inset: -2px;
    }
  }

  .entry-frame::before {
    z-index: 0;
    filter: blur(2rem);
    background: radial-gradient(
      circle,
      color-mix(in oklch, var(--color-accent) 100%, transparent) 0%,
      transparent 100%
    );
    content: "";
    top: 0;
    left: 0;
    height: 10rem;
    width: 10rem;
    position: absolute;
    opacity: 0.3;
    transform: translate3d(-25%, -25%, 0);
  }

  @media screen and (min-width: 1024px) {
    .entry-frame::before {
      height: 12rem;
      width: 12rem;
    }
  }

  @media screen and (min-width: 1280px) {
    .entry-frame::before {
      height: 14rem;
      width: 14rem;
    }
  }

  @media screen and (min-width: 1536px) {
    .entry-frame::before {
      height: 16rem;
      width: 16rem;
    }
  }

  .skills-list {
    z-index: 110;
    isolation: isolate;
  }

  @media (prefers-contrast: more) {
    .entry-frame::after {
      background: var(--color-emphasis);
    }
    .entry-frame::before {
      display: none;
    }
  }
</style>
