---
import { Image } from "astro:assets";
import Headshot from "./Headshot.astro";
import HeroBackground from "./HeroBackground.astro";
import LogoCarousel from "./LogoCarousel.astro";
import frameUpper from "../images/hero_frame/hero_frame-upper.webp";
import frameLower from "../images/hero_frame/hero_frame-lower.webp";
import headshotBackground from "../images/elements/headshot_bg_tint2_500_2x.webp";
---

<section
  id="hero"
  class="relative z-50 flex min-h-[calc(100vh-3rem)] w-full max-w-full flex-col justify-end gap-0 overflow-hidden px-2 pt-0 pb-2 sm:px-8 sm:pt-10 lg:pt-12 lg:pb-16"
>
  <HeroBackground />
  <Image
    src={frameUpper}
    alt=""
    class="pointer-events-none absolute top-0 left-0 z-100 w-full select-none"
    loading="eager"
  />
  <Image
    src={frameLower}
    alt=""
    class="pointer-events-none absolute bottom-0 left-0 z-100 w-full select-none"
    loading="eager"
  />
  <div
    id="hero__content"
    class="relative z-50 mx-auto mt-auto mb-auto flex w-full max-w-full px-6 pt-4 pb-4 sm:mr-0 sm:ml-0 sm:pr-4 sm:pl-4 md:px-0 md:pt-6 md:pr-6 md:pl-6 lg:p-0"
  >
    <div id="hero-content-wrapper" class="mx-auto grid grid-cols-[auto_1fr]">
      <div
        class="shadow-accent/15 relative mt-2 mb-6 flex w-full -rotate-[0.3deg] flex-col items-center justify-center overflow-visible p-0.5 px-0.5 pt-0 shadow-2xl sm:mr-auto sm:mb-auto sm:ml-auto sm:w-auto sm:flex-row sm:justify-start md:flex-col md:items-center"
      >
        <div class="absolute top-0 left-0 z-10 h-full w-full -translate-y-[1%]">
          <Image
            src={headshotBackground}
            alt=""
            class="relative h-full scale-105 object-fill object-top"
            loading="eager"
          />
        </div>
        <div
          class="border-background/10 relative z-20 block h-auto w-full max-w-24 overflow-hidden border-2 sm:w-1/3 md:w-full md:max-w-64 lg:max-w-80"
        >
          <Headshot />
        </div>
        <div
          class="text-md grid-col text-background relative z-20 mt-4 mb-4 grid w-full grid-cols-[auto_1fr] grid-rows-[auto] items-end border-black/20 pr-2 font-mono leading-none font-light"
        >
          <span class="headshot-fieldlabel">Operative</span>
          <h1
            class="border-b border-l border-black/20 pb-1 pl-4 text-base leading-none font-normal lg:text-2xl"
          >
            Grant Keller
          </h1>
          <span class="headshot-fieldlabel">Assignment</span>
          <span
            class="border-b border-l border-black/20 py-1 pl-4 text-sm leading-none lg:text-base"
            >UX/Design Engineer</span
          >
          <span class="headshot-fieldlabel headshot-fieldlabel__last border-b-0">Territory</span>
          <span class="border-l border-black/20 pt-1 pb-0 pl-4 text-sm leading-none lg:text-sm"
            >Los Angeles CA, USA</span
          >
        </div>
        <div
          class="pointer-events-none absolute top-0 left-0 z-10 h-full w-full"
          aria-hidden="true"
          style={`mask-image: url(${headshotBackground.src}); mask-mode: alpha; mask-size: 105% 105%; mask-position: 50% 70%; mask-repeat: no-repeat; -webkit-mask-image: url(${headshotBackground.src}); -webkit-mask-mode: alpha; -webkit-mask-size: 105% 105%; -webkit-mask-position: 50% 70%; -webkit-mask-repeat: no-repeat;`}
        >
          <span
            class="text-reduced absolute right-0 bottom-0 translate-x-2 translate-y-0 -rotate-2 font-mono text-2xl leading-none font-normal whitespace-pre opacity-30 mix-blend-multiply lg:text-3xl"
            role="presentation">34.0549°N,118.2426°W</span
          >
        </div>
        <div
          class="pointer-events-none absolute -top-1 left-1 z-30 h-full w-full overflow-hidden opacity-100 mix-blend-darken"
          aria-hidden="true"
        >
          <span
            class="via-subtle from-emphasis absolute top-0 right-0 h-[25%] w-[45%] translate-x-[60%] translate-y-[15%] bg-radial from-0% to-transparent to-100% blur-md"
          >
          </span>
        </div>
        <span
          class="from-background/90 absolute right-0 bottom-0 z-0 h-[130%] w-[200%] translate-x-[30%] translate-y-[12%] bg-radial from-0% to-transparent to-70% opacity-100 blur-3xl"
        >
        </span>
      </div>
      <div class="relative z-20 mt-8 ml-34 flex flex-col">
        <p class="relative flex flex-col items-start sm:text-lg md:mb-8 xl:mb-24">
          <span class="hero-headline -ml-[2ch]">Deep space</span>
          <span class="hero-headline mb-1 -ml-[1ch]">deep sea</span>
          <span class="sr-only">&nbsp;</span>
          <span
            class="text-emphasis tracking tracking-huge text-shadow-background/80 font-mono leading-none font-light text-shadow-md lg:text-base xl:text-base"
            >and everywhere in between</span
          >
        </p>
        <div class="relative mr-auto ml-0">
          <p class="text-foundation font-prompt text-shadow-black/30 text-shadow-lg">
            <span
              class="text-accent text-shadow-background/70 inline-block leading-tight font-normal tracking-wider text-shadow-lg xl:text-4xl"
              >Frontend architecture&nbsp;
            </span>
            <span class="block">
              <span
                class="text-foundation text-shadow-background/70 mr-1 ml-[1ch] inline-block leading-none font-extralight tracking-wide text-shadow-lg xl:text-3xl"
                >for
              </span>
              <span class="sr-only">&nbsp;</span>
              <span
                class="text-foundation text-shadow-background/70 tracking-wider text-shadow-lg xl:text-4xl"
                >ambitious ideas</span
              >
            </span>
          </p>
          <div
            class="absolute bottom-0 left-1/2 -translate-x-[60%] translate-y-1/2 scale-[150%] rotate-15 opacity-50 mix-blend-overlay blur-3xl"
          >
            <svg class="h-[80vh]" viewBox="0 0 256 512" aria-hidden="true">
              <defs>
                <linearGradient id="hero-wedge-gradient" x1="0" y1="1" x2="0" y2="0">
                  <stop offset="0" stop-color="var(--color-secondary-dark)" stop-opacity="0.3"
                  ></stop>
                  <stop offset="0.6" stop-color="var(--color-accent)" stop-opacity="0.3"></stop>
                  <stop offset="0.9" stop-color="var(--color-accent-hover)" stop-opacity="0.2"
                  ></stop>
                </linearGradient>
              </defs>
              <path d="M 17 64 A 128 128 0 0 1 239 64 L 128 512 Z" fill="url(#hero-wedge-gradient)"
              ></path>
            </svg>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="left-0 z-20 mt-auto mb-0 h-8 max-w-full overflow-hidden">
    <LogoCarousel />
  </div>

  <style lang="scss">
    @reference "../styles/global.css";
    .headshot-fieldlabel {
      @apply xl:text-2xs relative border-b border-black/20 px-2 py-1 text-xs leading-none font-medium tracking-wide uppercase;
    }
    .headshot-fieldlabel__last {
      @apply border-b-0 pb-0;
    }

    .hero-headline {
      @apply font-display text-foundation z-30 leading-[0.8em] font-black tracking-normal break-keep whitespace-nowrap uppercase md:text-6xl lg:text-7xl xl:text-9xl;
      text-shadow:
        0.01em 0.01em 0.01em color-mix(in srgb, var(--color-accent), transparent 0%),
        0.015em 0.02em 0.125em color-mix(in srgb, var(--color-accent), transparent 95%),
        0.01em 0.015em 0.3em color-mix(in srgb, var(--color-accent), transparent 95%),
        0.01em 0.015em 0.6em color-mix(in srgb, var(--color-accent), transparent 50%),
        -0.02em 0.01em 0.02em color-mix(in srgb, var(--color-accent), transparent 10%);
    }
  </style>
</section>
