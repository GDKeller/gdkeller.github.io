---
import { Picture, getImage } from "astro:assets";
import Headshot from "./Headshot.astro";
import HeroBackground from "./HeroBackground.astro";
import LogoCarousel from "./LogoCarousel.astro";
import frameUpper from "../images/hero/hero_frame-upper.png";
import frameLower from "../images/hero/hero_frame-lower.png";
import headshotBackground from "../images/elements/headshot_bg_w2670_AR-1-606.png";

// Pre-generate AVIF + WebP of the mask texture so the CSS mask-image can
// negotiate format via image-set(). The source WebP is tiny, but this keeps
// every asset on the same pipeline and shaves the WebP fallback for AVIF
// browsers.
const maskAvif = await getImage({
  src: headshotBackground,
  format: "avif",
  width: 600,
});
const maskWebp = await getImage({
  src: headshotBackground,
  format: "webp",
  width: 600,
});
const maskImage = `image-set(url("${maskAvif.src}") type("image/avif"), url("${maskWebp.src}") type("image/webp"))`;
---

<section
  id="hero"
  class="bg-background relative mb-0 flex w-full max-w-full flex-col
    justify-start gap-0 overflow-hidden px-2 pt-0 pb-4 sm:px-8 sm:pt-10 sm:pb-4
    md:min-h-[calc(100vh-2.125rem)] md:justify-end md:pb-8 lg:pt-12 lg:pb-8
    xl:pb-16 2xl:pb-20 portrait:min-h-auto"
>
  <HeroBackground />
  <Picture
    src={frameUpper}
    alt=""
    widths={[800, 1280, 1920]}
    sizes="100vw"
    formats={["avif", "webp"]}
    fallbackFormat="webp"
    loading="eager"
    fetchpriority="high"
    class="pointer-events-none absolute top-0 left-0 z-132 w-full select-none"
  />
  <Picture
    src={frameLower}
    alt=""
    widths={[800, 1280, 1920]}
    sizes="100vw"
    formats={["avif", "webp"]}
    class="pointer-events-none absolute -bottom-1 left-0 z-131 w-full
      select-none"
    fallbackFormat="webp"
    loading="eager"
  />
  <span
    class="frame-left bg-background-dark absolute top-0 left-0 z-130 h-full
      w-[2.7vw]"
  ></span>
  <span
    class="frame-right bg-background-dark absolute top-0 right-0 z-130 h-full
      w-[2.7vw]"
  ></span>
  <div
    id="hero__content"
    class="mx-auto mt-0 flex w-full max-w-full px-2 pt-4 pb-4 sm:mr-0 sm:ml-0
      sm:pr-4 sm:pl-4 md:mt-auto md:mb-auto md:px-6 md:pt-6 lg:p-0"
  >
    <div
      id="hero-content-wrapper"
      class="mx-auto grid grid-rows-[auto_1fr_auto] md:my-8 md:mt-2 md:mb-8
        md:grid-cols-[auto_1fr] md:grid-rows-1"
    >
      <div
        id="photo"
        class="shadow-accent/15 relative z-110 row-start-2 mt-0 ml-0 flex w-full
          rotate-[-0.3deg] flex-row items-start justify-start overflow-visible
          p-0.5 px-0.5 pt-0 shadow-2xl sm:mr-auto sm:mb-auto sm:ml-auto
          sm:w-auto sm:justify-start md:row-start-1 md:mt-2 md:w-full
          md:flex-col md:items-center"
      >
        <div class="absolute top-0 left-0 h-full w-full md:translate-y-[-1%]">
          <Picture
            src={headshotBackground}
            alt=""
            widths={[300, 520, 648, 972]}
            sizes="(max-width: 767px) 523px, (min-width: 768px) 343px, 33vw"
            formats={["avif", "webp"]}
            fallbackFormat="webp"
            loading="eager"
            priority={true}
            fetchpriority="high"
            class="h-full object-fill md:scale-102 md:rotate-0 md:object-top"
          />
        </div>
        <div
          class="border-background/20 shadow-background-dark/20 z-40 mt-2 mb-1
            ml-1 block h-auto w-full overflow-hidden border-2 shadow-md md:mt-0
            md:mb-0 md:ml-0 md:w-full md:max-w-48 lg:max-h-[60vh] lg:max-w-56
            xl:max-w-80"
        >
          <Headshot />
        </div>
        <div
          class="headshot-fields text-md grid-col text-background-dark
            border-background-dark/20 z-40 mx-auto mb-1 flex w-full
            grid-rows-[auto] flex-col pt-4 text-left font-mono leading-none
            font-light sm:pt-8 md:pt-0 lg:mx-0 lg:mb-2 lg:grid
            lg:grid-cols-[auto_1fr] lg:grid-rows-[auto] lg:items-end xl:mb-4
            xl:pr-2"
        >
          <span
            class="headshot-fieldlabel text-2xs relative border-b
              border-black/20 pt-4 pb-1 pl-3 leading-none font-light
              tracking-wider uppercase sm:pt-6 sm:pb-2 sm:pl-5 sm:text-base
              sm:font-extralight md:hidden md:py-1 md:font-normal
              md:tracking-wide lg:mt-0 lg:mb-0 lg:block lg:px-1 lg:pt-3
              lg:tracking-wide xl:px-2"
            >Operative</span
          >
          <h1
            class="border-background-dark/20 relative z-110 ml-1 border-b
              border-l pt-2 pb-1 pl-2 text-base leading-none font-medium sm:pl-4
              sm:text-3xl md:ml-0 md:pl-6 md:text-lg lg:pl-2 xl:pl-4
              xl:text-2xl"
          >
            Grant Keller
          </h1>
          <span
            class="headshot-fieldlabel text-2xs relative border-b
              border-black/20 pt-4 pb-1 pl-3 leading-none font-light
              tracking-wider uppercase sm:pt-6 sm:pb-2 sm:pl-5 sm:text-base
              sm:font-extralight md:hidden md:py-1 md:font-normal
              md:tracking-wide lg:mt-0 lg:mb-0 lg:block lg:px-1 lg:pt-3
              lg:tracking-wide xl:px-2"
            >Assignment</span
          >
          <span
            class="border-background-dark/20 z-110 mb-0 ml-1 border-b border-l
              pt-1 pb-1 pl-2 text-xs leading-none font-normal tracking-tight
              sm:pl-4 sm:text-xl md:ml-0 md:pl-6 md:text-sm md:font-light
              md:tracking-normal lg:pt-3 lg:pb-1 lg:pl-2 lg:text-xs
              lg:font-normal xl:py-2 xl:pl-4 xl:text-base"
            >UX/Design Engineer</span
          >
          <span
            class="headshot-fieldlabel headshot-fieldlabel__last text-2xs
              relative border-b-0 border-black/20 pt-4 pb-1 pl-3 leading-none
              font-light tracking-wider uppercase sm:pt-6 sm:pb-2 sm:pl-5
              sm:text-base sm:font-extralight md:hidden md:border-b-0 md:py-1
              md:pb-0 md:font-normal md:tracking-wide lg:mt-0 lg:mb-auto
              lg:block lg:px-1 lg:pt-3 lg:tracking-wide xl:px-2"
            >Territory</span
          >
          <span
            class="border-background-dark/20 text-2xs z-110 ml-1 border-b
              border-l pt-1 pb-1 pl-2 leading-none font-normal sm:pl-4
              sm:text-lg md:ml-0 md:hidden md:border-b-0 md:pb-0 lg:mt-0
              lg:block lg:pt-3 lg:pb-2 lg:pl-2 xl:pt-2 xl:pl-4 xl:text-sm"
            >Los Angeles CA, USA</span
          >
        </div>
        <div
          class="pointer-events-none absolute top-0 left-0 z-80 h-full w-full"
          aria-hidden="true"
          role="presentation"
          style={`mask-image: ${maskImage}; mask-mode: alpha; mask-size: 105% 105%; mask-position: 50% 70%; mask-repeat: no-repeat; -webkit-mask-image: ${maskImage}; -webkit-mask-mode: alpha; -webkit-mask-size: 105% 105%; -webkit-mask-position: 50% 70%; -webkit-mask-repeat: no-repeat;`}
        >
          <span
            class="text-fainter absolute right-0 bottom-0 z-100 translate-x-2
              translate-y-0 -rotate-2 font-mono text-2xl leading-none
              font-normal whitespace-pre opacity-50 mix-blend-multiply
              sm:-translate-x-2 sm:-translate-y-1/4 sm:text-4xl md:translate-x-2
              md:translate-y-0 md:text-sm md:opacity-30 lg:text-3xl xl:text-2xl"
            >34.0549°N,118.2426°W</span
          >
        </div>
        <div
          class="pointer-events-none absolute -top-1 left-1 z-30 h-full w-full
            overflow-hidden opacity-100 mix-blend-darken"
          aria-hidden="true"
        >
          <span
            class="via-accent-subtle from-emphasis absolute top-0 right-0 hidden
              h-[25%] w-[45%] translate-x-[60%] translate-y-[15%] bg-radial
              from-0% to-transparent to-100% blur-md md:block"
          >
          </span>
        </div>
        <span
          class="from-background/90 absolute right-0 bottom-0 -z-1 h-[130%]
            w-[200%] translate-x-[30%] translate-y-[12%] bg-radial from-0%
            to-transparent to-70% opacity-100 blur-3xl"
        >
        </span>
      </div>
      <div
        class="mt-0 mb-auto contents md:mt-8 md:ml-20 md:flex md:flex-col
          lg:ml-26 xl:ml-34"
      >
        <div
          id="headline"
          class="relative row-start-1 mx-auto mt-[15vw] mb-[12vw] md:row-auto
            md:mt-0 md:mb-16 lg:mb-16 xl:mb-32"
        >
          <p
            class="pointer-events-none absolute inset-0 flex flex-col
              items-start text-4xl md:items-start md:text-lg"
            aria-hidden="true"
          >
            <span
              class="hero-headline hero-headline--ghost font-display
                pointer-events-none text-[14vw] leading-[0.8em] font-black
                tracking-normal break-keep whitespace-nowrap text-transparent
                uppercase mix-blend-screen select-none md:ml-[-2ch] md:text-7xl
                lg:text-8xl xl:text-9xl"
              >Deep space</span
            >
            <span
              class="hero-headline hero-headline--ghost font-display
                pointer-events-none mb-1 ml-[1ch] text-[14vw] leading-[0.8em]
                font-black tracking-normal break-keep whitespace-nowrap
                text-transparent uppercase mix-blend-screen select-none
                md:ml-[-1ch] md:text-7xl lg:text-8xl xl:text-9xl"
              >deep sea</span
            >
          </p>
          <p
            class="relative z-110 my-auto flex flex-col items-start
              md:items-start"
          >
            <span
              class="hero-headline font-display text-foundation text-[14vw]
                leading-[0.8em] font-black tracking-normal break-keep
                whitespace-nowrap uppercase md:ml-[-2ch] md:text-7xl lg:text-8xl
                xl:text-9xl"
              >Deep space</span
            >
            <span
              class="hero-headline font-display text-foundation mb-2 ml-[1ch]
                text-[14vw] leading-[0.8em] font-black tracking-normal
                break-keep whitespace-nowrap uppercase md:ml-[-1ch] md:text-7xl
                lg:text-8xl xl:mb-2 xl:text-9xl"
              >deep sea</span
            >
            <span class="sr-only">&nbsp;</span>
            <span
              class="text-emphasis md:tracking-huge
                text-shadow-background-dark/60 md:text-2xs xl:text-shadow-xl
                relative z-110 mx-auto text-center font-mono text-[4vw]
                leading-none font-light tracking-widest text-shadow-lg
                sm:text-2xl sm:tracking-widest md:ml-0 md:text-left lg:text-sm
                xl:text-lg"
              >and everywhere in between</span
            >
          </p>
        </div>
        <div
          id="subhed"
          class="z-110 row-start-3 mx-auto mb-[15vw] pt-8 md:row-auto md:my-0
            md:ml-0 md:pt-0"
        >
          <p
            class="text-foundation font-body z-140 leading-tight
              text-shadow-black/30 text-shadow-lg md:relative md:translate-0"
          >
            <span
              class="text-accent text-shadow-background/70 inline-block text-2xl
                leading-[0.75em] font-normal tracking-wider text-shadow-lg
                sm:text-4xl md:text-2xl md:leading-snug lg:text-3xl xl:text-4xl"
              >Frontend architecture&nbsp;
            </span>
            <span class="block">
              <span
                class="text-foundation text-shadow-background/70 mr-[0.25em]
                  ml-[1ch] text-lg leading-none font-light tracking-widest
                  text-shadow-lg sm:text-3xl md:inline-block md:text-xl
                  lg:text-2xl xl:text-3xl"
                >for
              </span>
              <span class="sr-only">&nbsp;</span>
              <span
                class="text-foundation text-shadow-background/70 text-2xl
                  tracking-wider text-shadow-lg sm:text-4xl md:text-2xl
                  lg:text-3xl xl:text-4xl"
                >ambitious ideas</span
              >
            </span>
          </p>
          <div
            class="absolute bottom-0 left-1/2 z-10 translate-x-[-60%]
              translate-y-1/2 scale-[150%] rotate-15 opacity-30 mix-blend-screen
              blur-3xl"
          >
            <svg class="h-[80vh]" viewBox="0 0 256 512" aria-hidden="true">
              <defs>
                <linearGradient
                  id="hero-wedge-gradient"
                  x1="0"
                  y1="1"
                  x2="0"
                  y2="0"
                >
                  <stop
                    offset="0"
                    stop-color="var(--color-undertone)"
                    stop-opacity="0.3"></stop>
                  <stop
                    offset="0.6"
                    stop-color="var(--color-accent)"
                    stop-opacity="0.3"></stop>
                  <stop
                    offset="0.9"
                    stop-color="var(--color-accent-hover)"
                    stop-opacity="0.2"></stop>
                </linearGradient>
              </defs>
              <path
                d="M 17 64 A 128 128 0 0 1 239 64 L 128 512 Z"
                fill="url(#hero-wedge-gradient)"></path>
            </svg>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div
    class="left-0 z-20 mb-[3vw] h-[5vh] w-full max-w-full overflow-hidden
      md:mb-0 md:h-[3vh] xl:h-[5vh] 2xl:h-[5vh]"
  >
    <LogoCarousel />
  </div>

  <style lang="scss">
    @reference "../styles/main.css";

    .hero-headline {
      text-shadow:
        0 0 0.04em color-mix(in srgb, var(--color-background), transparent 50%),
        0 0 0.015em var(--color-accent-subtle),
        0 0 0.02em var(--color-accent-subtle),
        0 0 0.03em var(--color-accent),
        0 0 0.05em var(--color-accent);
    }

    .hero-headline--ghost {
      text-shadow:
        0.01em 0.01em 0.03em
          color-mix(in srgb, var(--color-accent), transparent 10%),
        -0.02em 0.01em 0.04em
          color-mix(in srgb, var(--color-accent), transparent 85%),
        0.01em 0.015em 0.1em
          color-mix(in srgb, var(--color-accent), transparent 70%),
        0.01em 0.015em 0.2em
          color-mix(in srgb, var(--color-accent), transparent 70%),
        0.01em 0.02em 0.25em
          color-mix(in srgb, var(--color-accent), transparent 80%),
        0.02em 0.01em 1.5em
          color-mix(in srgb, var(--color-undertone), transparent 45%);
    }
  </style>
</section>
