---
import { Image } from "astro:assets";
import Headshot from "./Headshot.astro";
import HeroBackground from "./HeroBackground.astro";
import LogoCarousel from "./LogoCarousel.astro";
import frameUpper from "../images/hero_frame/hero_frame-upper.webp";
import frameLower from "../images/hero_frame/hero_frame-lower.webp";
import headshotBackground from "../images/elements/headshot_bg_tint_500_2x.webp";
---

<section
  id="hero"
  class="relative z-50 flex min-h-[calc(100vh-3rem)] w-full max-w-full flex-col justify-end gap-0 overflow-hidden px-2 pt-0 pb-2 sm:px-8 sm:pt-10 lg:pt-12 lg:pb-16"
>
  <HeroBackground />
  <Image
    src={frameUpper}
    alt=""
    class="pointer-events-none absolute top-0 left-0 z-100 w-full select-none"
    loading="eager"
  />
  <Image
    src={frameLower}
    alt=""
    class="pointer-events-none absolute bottom-0 left-0 z-100 w-full select-none"
    loading="eager"
  />
  <div
    id="hero__content"
    class="relative z-50 mx-auto mt-auto mb-auto flex w-full max-w-full px-6 pt-4 pb-4 sm:mr-0 sm:ml-0 sm:pr-4 sm:pl-4 md:px-0 md:pt-6 md:pr-6 md:pl-6 lg:p-0"
  >
    <div id="hero-content-wrapper" class="mx-auto grid grid-cols-[auto_1fr]">
      <div
        class="relative mt-2 mb-6 flex w-full flex-col items-center justify-center overflow-visible p-0.5 px-0.5 pt-0 shadow-2xl shadow-black sm:mr-auto sm:mb-auto sm:ml-auto sm:w-auto sm:flex-row sm:justify-start md:flex-col md:items-center"
      >
        <div class="absolute top-0 left-0 z-10 h-full w-full -translate-y-[1%]">
          <Image
            src={headshotBackground}
            alt=""
            class="relative h-full scale-105 object-fill object-top"
            loading="eager"
          />
        </div>
        <div
          class="relative z-20 block h-auto w-full max-w-24 overflow-hidden sm:w-1/3 md:w-full md:max-w-64 lg:max-w-80"
        >
          <Headshot />
        </div>
        <div
          class="text-md grid-col z-10 mt-2 grid w-full grid-cols-[auto_1fr] grid-rows-[auto] items-end border-black/20 pr-2 pb-3 font-mono leading-none font-light text-black"
        >
          <span class="headshot-fieldlabel">Operative</span>
          <h1
            class="border-b border-l border-black/20 py-1 pl-4 text-base leading-none font-medium lg:text-2xl"
          >
            Grant Keller
          </h1>
          <span class="headshot-fieldlabel">Assignment</span>
          <span class="border-b border-l border-black/20 py-1 pl-4 text-sm leading-none lg:text-lg"
            >UX/Design Engineer</span
          >
          <span class="headshot-fieldlabel headshot-fieldlabel__last border-b-0">Territory</span>
          <span class="border-l border-black/20 pt-1 pb-0 pl-4 text-sm leading-none lg:text-base"
            >Los Angeles CA USA</span
          >
          <span
            class="col-start-2 border-l border-black/20 pt-1 pl-4 text-xs leading-none lg:text-xs"
            >34.0549° N, 118.2426° W</span
          >
        </div>
        <span
          class="from-accent/30 absolute top-1/2 right-0 z-0 h-full w-[150%] translate-x-1/4 -translate-y-1/2 bg-radial from-0% to-transparent to-70%"
        >
        </span>
      </div>
      <div class="z-20 mt-2 flex flex-col md:ml-24 lg:ml-12 xl:ml-16">
        <p
          class="relative isolate z-30 mr-auto flex w-full flex-col items-start sm:ml-0 sm:text-lg md:mb-8 md:text-2xl lg:text-xl/tight xl:mb-24"
        >
          <span class="hero-headline">Deep space</span>
          <span
            class="text-background bg-emphasis display-none sr-only absolute -left-[3.8em] z-50 -my-5 inline-flex h-8 w-8 items-center justify-center place-self-center rounded-full font-mono text-sm leading-normal tracking-wider uppercase"
          >
            &nbsp;to&nbsp;
          </span>
          <span class="hero-headline mb-4 ml-8">deep sea</span>
          <span class="sr-only">&nbsp;</span>
          <span
            class="text-emphasis lg:text-md relative z-30 mt-0 ml-20 pl-4 font-mono leading-none font-extralight tracking-widest xl:text-xl"
            >and everywhere in between</span
          >
        </p>
        <div class="max-w-[60ch] pl-24">
          <p class="text-foundation font-prompt text-shadow-black/30 text-shadow-lg">
            <span
              class="text-accent inline-block leading-tight font-extralight tracking-wider xl:text-4xl"
              >Frontend architecture&nbsp;
            </span>
            <span class="sr-only">&nbsp;</span>
            <span class="block">
              <span
                class="text-foundation mr-1 ml-1 inline-block leading-none font-extralight tracking-wider xl:text-3xl"
                >for
              </span>
              <span class="sr-only">&nbsp;</span>
              <span class="text-foundation tracking-wider xl:text-4xl">ambitious ideas.</span>
            </span>
          </p>
        </div>
      </div>
    </div>
  </div>

  <div class="left-0 z-20 mt-auto mb-0 h-8 max-w-full overflow-hidden">
    <LogoCarousel />
  </div>

  <style lang="scss">
    @reference "../styles/global.css";
    .headshot-fieldlabel {
      @apply xl:text-2xs relative border-b border-black/20 px-2 py-1 text-xs leading-none font-medium tracking-wide uppercase;
    }
    .headshot-fieldlabel__last {
      @apply border-b-0 pb-0;
    }

    .hero-headline {
      @apply font-display text-foundation text-shadow-accent/90 z-30 leading-[0.8em] font-black tracking-tight break-keep whitespace-nowrap uppercase text-shadow-sm md:text-6xl lg:text-7xl xl:text-9xl;
    }
  </style>
</section>
