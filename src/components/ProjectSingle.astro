---
import { render } from "astro:content";
import DateRange from "./DateRange.astro";
import Link from "./Link.astro";
import ProjectSingleImage from "./ProjectSingleImage.astro";
import SkillBadge from "./SkillBadge.astro";

const { project } = Astro.props;

const { data } = project;
const {
  title,
  projectName,
  client,
  clientLogo,
  startMonthYear,
  endMonthYear,
  clientWebsite,
  image,
  imageAlt,
  imageAlign,
  tech,
} = data;

const { Content } = await render(project);
---

<div class="job-frame relative mb-24">
  <div class="job-card flex items-stretch">
    <span class="job-backdrop" aria-hidden="true"></span>
    <div class="flex-1">
      <div class="flex flex-col items-start md:flex-row md:items-start">
        {
          clientLogo && (
            <div class="logo relative z-20 mr-2 shrink-0 -translate-x-4 lg:mr-4 lg:-translate-y-4">
              <ProjectSingleImage
                imagePath={clientLogo.src}
                altText={clientLogo.alt}
              />
            </div>
          )
        }
        <div class="flex w-full justify-between pr-4 pb-4">
          <div class="flex flex-col justify-start pt-12">
            <h3
              class="text-accent font-display relative z-110 mb-4 text-2xl leading-none tracking-wider md:text-2xl lg:text-3xl"
            >
              {title}
            </h3>

            {
              projectName && (
                <p class="text-emphasis relative z-110 mb-2 block leading-none font-light tracking-wider lg:text-xl">
                  {projectName}
                </p>
              )
            }
            <div class="relative z-110 flex flex-wrap items-baseline gap-y-2">
              <p
                class="text-emphasis block leading-none font-light tracking-wider lg:text-base"
              >
                {
                  clientWebsite ? (
                    <Link href={clientWebsite} target="_blank" variant="subtle">
                      {client}
                    </Link>
                  ) : (
                    client
                  )
                }
              </p>
              <span class="text-accent mx-4 hidden leading-none sm:inline-block"
                >&nbsp;᠅&nbsp;</span
              >
              <DateRange
                start={startMonthYear}
                end={endMonthYear}
                class="font-mono text-sm leading-none font-extralight"
              />
            </div>
          </div>
        </div>
      </div>

      <div
        class:list={[
          "relative z-110 px-12 pt-12 pr-8 pb-4",
          { "flex flex-col": imageAlign !== undefined },
          { "lg:flex-row-reverse": imageAlign === "right" },
          { "lg:flex-row": imageAlign === "left" },
        ]}
      >
        {
          image && (
            <div
              class:list={[
                "mb-10 shrink-0 lg:w-1/4",
                { "lg:mr-10": imageAlign === "left" },
                { "lg:ml-10": imageAlign === "right" },
              ]}
            >
              <ProjectSingleImage
                imagePath={image}
                altText={imageAlt || projectName}
              />
            </div>
          )
        }
        <div
          class="job-body list-custom-wrapper prose max-w-[70ch] font-light tracking-wide lg:flex-1"
        >
          <Content />
        </div>
      </div>
    </div>

    {
      tech && (
        <div class="skills-list border-faint relative z-110 mr-0 ml-auto w-full max-w-64 border-l-2 pt-8 pr-4 pb-4 pl-4">
          <p class="sr-only">Skills:&nbsp;</p>
          <ul class="flex max-w-40 flex-col text-left font-mono">
            {tech.map((t: string) => (
              <li class="mb-4 flex items-center">
                <span
                  aria-hidden="true"
                  class="triplecolon text-accent mr-4 text-sm leading-none font-light"
                >
                  :::
                </span>
                <SkillBadge
                  tag="span"
                  class="text-emphasis font-extralight whitespace-nowrap uppercase"
                >
                  {t}
                </SkillBadge>
              </li>
            ))}
          </ul>
        </div>
      )
    }
  </div>

  <style>
    @reference "../styles/global.css";
    .job-card {
      .project-image img {
        @apply max-h-20 sm:max-h-20 md:max-h-24 lg:max-h-32;
      }
    }
    .job-body {
      p {
        @apply mb-4;

        &:last-child {
          @apply mb-0;
        }
      }

      ul {
        @apply mt-8;
      }
      li {
        @apply mb-2 pl-6;
      }

      a {
        @apply hover:text-highlight underline transition-colors;
      }

      blockquote {
        @apply text-emphasis relative text-base leading-normal italic md:text-sm lg:text-sm lg:leading-loose;
        cite {
          @apply mt-8 block text-right font-mono text-xs font-extralight not-italic md:text-xs;

          &::before {
            @apply content-['—_'];
          }
        }
      }

      details {
        @apply mt-8 pt-8;
        interpolate-size: allow-keywords;
      }

      details::details-content {
        block-size: 0;
        overflow: clip;
        opacity: 0;
        transition:
          block-size 350ms ease,
          content-visibility 350ms allow-discrete,
          opacity 250ms ease;
      }

      details[open]::details-content {
        block-size: auto;
        opacity: 1;
        margin-bottom: 4rem;
      }

      @media (prefers-reduced-motion: reduce) {
        details::details-content {
          transition: none;
        }
      }

      summary {
        @apply text-accent hover:text-accent-hover mb-8 ml-auto flex w-fit cursor-pointer items-center gap-3 px-4 py-2 font-mono text-sm tracking-widest uppercase transition-colors select-none;
        list-style: none;
      }

      summary::-webkit-details-marker {
        display: none;
      }

      summary::after {
        content: "[+]";
      }

      details[open] > summary::after {
        content: "[−]";
      }
    }

    .job-body :global(img) {
      @apply w-full;
    }

    .job-backdrop {
      position: absolute;
      inset: 0;
      z-index: 2;
      background: var(--color-background-dark);
      clip-path: polygon(
        0 0,
        calc(100% - 10rem) 0,
        100% 4rem,
        100% 100%,
        0 100%
      );
    }

    .job-frame::after {
      content: "";
      position: absolute;
      inset: -2px;
      z-index: 1;
      pointer-events: none;
      background: var(--color-faint);
      clip-path: polygon(
        0 0,
        calc(100% - 5rem) 0,
        100% 4rem,
        100% 100%,
        0 100%
      );
    }

    .job-frame::before {
      z-index: 0;
      filter: blur(2rem);
      background: radial-gradient(
        circle,
        color-mix(in oklch, var(--color-accent) 100%, transparent) 0%,
        transparent 100%
      );
      content: "";
      top: 0;
      left: 0;
      height: 10rem;
      width: 10rem;
      position: absolute;
      opacity: 0.2;
      transform: translate3d(-25%, -25%, 0);
    }

    .skills-list {
      z-index: 110;
      isolation: isolate;
    }

    @media (prefers-contrast: more) {
      .job-frame::after {
        background: var(--color-emphasis);
      }
      .job-frame::before {
        display: none;
      }
    }
  </style>
</div>
