---
import { render } from "astro:content";
import EntryCard from "./EntryCard.astro";

const { project } = Astro.props;
const { data } = project;
const { Content } = await render(project);

const image = data.image
  ? { src: data.image, alt: data.imageAlt ?? data.projectName }
  : undefined;
---

<EntryCard
  title={data.title}
  subtitle={data.projectName}
  organization={data.client}
  organizationWebsite={data.clientWebsite}
  logo={data.clientLogo}
  startMonthYear={data.startMonthYear}
  endMonthYear={data.endMonthYear}
  tech={data.tech}
  image={image}
  imageAlign={data.imageAlign}
>
  <Content />
</EntryCard>
