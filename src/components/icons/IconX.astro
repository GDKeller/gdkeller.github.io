---
type Props = {
  class?: string;
};

const { class: className } = Astro.props;
---

<svg
  class={className}
  viewBox="0 0 256 256"
  fill="none"
  stroke="currentColor"
  stroke-width="16"
  stroke-linecap="round"
  stroke-linejoin="round"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <polygon points="48 40 96 40 208 216 160 216 48 40"></polygon>
  <line x1="113.88" y1="143.53" x2="48" y2="216"></line>
  <line x1="208" y1="40" x2="142.12" y2="112.47"></line>
</svg>
