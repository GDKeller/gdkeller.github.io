---
const email = "contact@grantkeller.dev";
const linkedinHandle = "grantdkeller";
const githubHandle = "gdkeller";
const xHandle = "GrantDKeller";
const resumeHref = "/Grant Keller Senior UX Engineer Resume 2025.pdf";

import IconArrowRight from "./icons/IconArrowRight.astro";
import IconCopy from "./icons/IconCopy.astro";
import IconDownload from "./icons/IconDownload.astro";
import IconGitHub from "./icons/IconGitHub.astro";
import IconLinkedIn from "./icons/IconLinkedIn.astro";
import IconX from "./icons/IconX.astro";
---

<div class="contact-card relative z-10">
  <div class="mx-auto mb-12 flex w-min flex-col">
    <button
      type="button"
      class="contact-primary__copy group xs:flex-row xs:ml-4 xs:px-4 xs:pr-16
        border-highlight text-highlight hover:border-highlight-hover
        hover:text-highlight-hover focus-visible:border-highlight-hover
        focus-visible:text-highlight-hover relative z-10 mb-6 flex
        cursor-pointer flex-col-reverse items-center gap-4 border-0 border-b
        bg-transparent py-8 pb-3 text-left transition-colors sm:pr-20"
      data-copy-email={email}
      aria-label={`Copy ${email} to clipboard`}
    >
      <span
        class="contact-primary__email xs:text-xl font-mono text-base
          tracking-wide">{email}</span
      >
      <span
        class="contact-primary__state xs:bottom-1 xs:-translate-y-1/2
          xs:place-self-end text-2xs text-highlight
          group-hover:text-highlight-hover absolute right-8 bottom-10 z-10
          inline-flex shrink-0 items-center gap-1.5 pb-1 font-mono uppercase
          transition-colors sm:right-12"
        aria-hidden="true"
      >
        <IconCopy class="h-4 w-4" />
        <span
          class="contact-primary__state-label text-highlight
            group-hover:text-highlight-hover
            group-focus-visible:text-highlight-hover text-2xs absolute bottom-0
            left-full mr-1 translate-x-1 -translate-y-1/3 font-mono tracking-wide
            transition-colors">Copy</span
        >
      </span>
    </button>
    <a
      href={`mailto:${email}`}
      class="contact-primary__send text-foundation
        hover:border-highlight-hover focus-visible:border-highlight-hover
        hover:text-highlight-hover focus-visible:text-highlight-hover text-2xs
        border-faint z-10 mr-0 ml-auto inline-flex flex-1 items-center gap-1.5
        border border-dashed px-2 py-2 font-mono tracking-wide whitespace-nowrap
        uppercase transition-colors"
    >
      <IconArrowRight class="h-3 w-3" />
      <span>Open in mail client</span>
    </a>
  </div>

  <div class="border-faint relative z-10 border-t-2">
    <a
      href={resumeHref}
      target="_blank"
      rel="noopener noreferrer"
      class="link-resume group text-emphasis hover:text-highlight-hover
        focus-visible:text-accent-hover z-10 inline-flex items-center gap-2 px-8
        py-6"
    >
      <IconDownload class="h-4 w-4" />
      <span class="font-mono leading-3"> Resume </span>
      <span
        class="group-hover:text-highlight-hover text-2xs font-mono leading-3
          tracking-wider">[PDF]</span
      >
    </a>
  </div>

  <ul
    class="contact-secondary border-faint relative z-10 grid list-none
      grid-cols-3 border-t-2"
  >
    <li>
      <a
        href={`https://www.linkedin.com/in/${linkedinHandle}/`}
        target="_blank"
        rel="noopener noreferrer"
        class="contact-link group text-emphasis hover:text-accent-hover
          focus-visible:text-accent-hover relative z-10 flex min-w-0 flex-col
          gap-2 px-4 py-6 transition-colors sm:px-8"
      >
        <span
          class="xs:justify-start inline-flex items-center justify-center gap-2"
        >
          <IconLinkedIn class="xs:h-5 xs:w-5 h-12 w-12 shrink-0" />
          <span class="xs:block font-display hidden text-sm tracking-wide"
            >LinkedIn</span
          >
        </span>
        <span
          class="xs:block text-foundation group-hover:text-accent-hover
            group-focus-visible:text-accent-hover hidden truncate font-mono
            text-xs transition-colors">@{linkedinHandle}</span
        >
      </a>
    </li>
    <li class="border-faint border-l-2">
      <a
        href={`https://github.com/${githubHandle}`}
        target="_blank"
        rel="noopener noreferrer"
        class="contact-link group text-emphasis hover:text-accent-hover
          focus-visible:text-accent-hover relative z-10 flex min-w-0 flex-col
          gap-2 px-4 py-6 transition-colors sm:px-8"
      >
        <span
          class="xs:justify-start inline-flex items-center justify-center gap-2"
        >
          <IconGitHub class="xs:h-5 xs:w-5 h-12 w-12 shrink-0" />
          <span class="xs:block font-display hidden text-sm tracking-wide"
            >GitHub</span
          >
        </span>
        <span
          class="xs:block text-foundation group-hover:text-accent-hover
            group-focus-visible:text-accent-hover hidden truncate font-mono
            text-xs transition-colors">@{githubHandle}</span
        >
      </a>
    </li>
    <li class="border-faint border-l-2">
      <a
        href={`https://x.com/${xHandle}`}
        target="_blank"
        rel="noopener noreferrer"
        class="contact-link group text-emphasis hover:text-accent-hover
          focus-visible:text-accent-hover relative z-10 flex min-w-0 flex-col
          gap-2 px-4 py-6 transition-colors sm:px-8"
      >
        <span
          class="xs:justify-start inline-flex items-center justify-center gap-2"
        >
          <IconX class="xs:h-5 xs:w-5 h-12 w-12 shrink-0" />
          <span class="xs:block font-display hidden text-sm tracking-wide"
            >X</span
          >
        </span>
        <span
          class="xs:block text-foundation group-hover:text-accent-hover
            group-focus-visible:text-accent-hover hidden truncate font-mono
            text-xs transition-colors">@{xHandle}</span
        >
      </a>
    </li>
  </ul>
</div>

<script>
  document.addEventListener("click", async (event) => {
    const target = event.target as HTMLElement | null;
    const button = target?.closest<HTMLButtonElement>("[data-copy-email]");
    if (!button) return;

    const value = button.dataset.copyEmail;
    if (!value) return;

    try {
      await navigator.clipboard.writeText(value);
    } catch {
      return;
    }

    const label = button.querySelector<HTMLElement>(
      ".contact-primary__state-label",
    );
    if (!label) return;

    label.textContent = "Copied";
    window.setTimeout(() => {
      label.textContent = "Copy";
    }, 1500);
  });
</script>
