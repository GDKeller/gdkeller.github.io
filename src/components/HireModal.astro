---
const email = "contact@grantkeller.dev";
const linkedinHandle = "grantdkeller";
const githubHandle = "gdkeller";
const xHandle = "GrantDKeller";
const resumeHref = "/Grant Keller Senior UX Engineer Resume 2025.pdf";
---

<dialog
  id="hire_me_modal"
  class="hire-modal open:flex"
  aria-labelledby="hire-modal-title"
>
  <article class="hire-frame relative w-full max-w-lg">
    <span class="hire-backdrop" aria-hidden="true"></span>

    <form method="dialog" class="hire-close-form">
      <button type="submit" class="hire-close" aria-label="Close dialog">
        <svg
          class="h-4 w-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </form>

    <div class="hire-panel">
      <header class="hire-header">
        <h2
          id="hire-modal-title"
          class="font-decorative text-emphasis text-3xl leading-none tracking-wide"
        >
          Open channel
        </h2>
      </header>

      <div class="hire-primary">
        <button
          type="button"
          class="hire-primary__copy"
          data-copy-email={email}
          aria-label={`Copy ${email} to clipboard`}
        >
          <span class="hire-primary__email font-mono">{email}</span>
          <span class="hire-primary__state" aria-hidden="true">
            <svg
              class="h-4 w-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <rect
                x="9"
                y="9"
                width="11"
                height="11"
                rx="1.5"
                stroke-width="2"></rect>
              <path
                d="M5 15H4a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h10a1 1 0 0 1 1 1v1"
                stroke-width="2"
                stroke-linecap="round"></path>
            </svg>
            <span class="hire-primary__state-label"></span>
          </span>
        </button>
        <a href={`mailto:${email}`} class="hire-primary__send">
          <svg
            class="h-3 w-3"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M5 12h14M13 6l6 6-6 6"></path>
          </svg>
          <span>Open in mail client</span>
        </a>
      </div>

      <ul class="hire-secondary">
        <li>
          <a
            href={`https://www.linkedin.com/in/${linkedinHandle}/`}
            target="_blank"
            rel="noopener noreferrer"
            class="hire-link group"
          >
            <span class="hire-link__head">
              <svg
                class="hire-link__icon shrink-0"
                fill="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                ></path>
              </svg>
              <span class="hire-link__name font-mono">LinkedIn</span>
            </span>
            <span class="hire-link__handle font-mono">@{linkedinHandle}</span>
          </a>
        </li>
        <li>
          <a
            href={`https://github.com/${githubHandle}`}
            target="_blank"
            rel="noopener noreferrer"
            class="hire-link group"
          >
            <span class="hire-link__head">
              <svg
                class="hire-link__icon shrink-0"
                fill="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
                ></path>
              </svg>
              <span class="hire-link__name font-mono">GitHub</span>
            </span>
            <span class="hire-link__handle font-mono">@{githubHandle}</span>
          </a>
        </li>
        <li>
          <a
            href={`https://x.com/${xHandle}`}
            target="_blank"
            rel="noopener noreferrer"
            class="hire-link group"
          >
            <span class="hire-link__head">
              <svg
                class="hire-link__icon shrink-0"
                fill="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
                ></path>
              </svg>
              <span class="hire-link__name font-mono">X</span>
            </span>
            <span class="hire-link__handle font-mono">@{xHandle}</span>
          </a>
        </li>
      </ul>

      <a
        href={resumeHref}
        target="_blank"
        rel="noopener noreferrer"
        class="hire-resume group"
      >
        <svg
          class="h-3.5 w-3.5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M12 4v12m0 0l-4-4m4 4l4-4M4 20h16"></path>
        </svg>
        <span
          class="font-mono text-foundation group-hover:text-accent-hover transition-colors"
        >
          Resume
        </span>
        <span class="font-mono text-subtle text-[0.65rem] tracking-[0.2em]">
          PDF
        </span>
      </a>
    </div>

    <span class="hire-scanlines" aria-hidden="true"></span>
  </article>

  <form method="dialog" class="hire-modal__backdrop fixed inset-0 -z-10">
    <button class="h-full w-full cursor-default" aria-label="Close dialog"
      >close</button
    >
  </form>
</dialog>

<style>
  @reference "../styles/global.css";

  /* Clip-path with a notched bottom-right corner. Repeated as a CSS
     custom property so backdrop, frame stroke, and scanlines all match. */
  .hire-frame {
    --hire-clip: polygon(
      0 0,
      100% 0,
      100% calc(100% - 3rem),
      calc(100% - 4rem) 100%,
      0 100%
    );
  }

  .hire-modal {
    position: fixed;
    inset: 0;
    z-index: 999;
    width: 100dvw;
    height: 100dvh;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: none;
    padding: 1rem;
    max-width: 100vw;
    max-height: 100vh;
  }

  .hire-modal::backdrop {
    background: color-mix(in oklch, var(--color-background) 80%, transparent);
    backdrop-filter: blur(8px);
  }

  /* Frame stroke: 1px outline behind the backdrop, same clip-path */
  .hire-frame::after {
    content: "";
    position: absolute;
    inset: -1px;
    z-index: 1;
    pointer-events: none;
    background: var(--color-faint);
    clip-path: var(--hire-clip);
  }

  .hire-backdrop {
    position: absolute;
    inset: 0;
    z-index: 2;
    background: var(--color-background);
    clip-path: var(--hire-clip);
  }

  .hire-panel {
    position: relative;
    z-index: 3;
    padding: 2rem 1.75rem 2.75rem 1.75rem;
  }

  /* Close button: sits flush in the top-right corner */
  .hire-close-form {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    z-index: 5;
  }

  .hire-close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border: 0;
    background: transparent;
    color: var(--color-emphasis);
    cursor: pointer;
    transition: color 0.18s ease;
  }

  .hire-close:hover,
  .hire-close:focus-visible {
    color: var(--color-accent-hover);
  }

  .hire-header {
    margin-bottom: 1.5rem;
  }

  /* Primary email block: the whole row is a copy button. Send is a smaller
     mailto fallback below. The left accent stripe binds them together. */
  .hire-primary {
    margin-bottom: 1.5rem;
    border-left: 2px solid var(--color-accent);
  }

  .hire-primary__copy {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    width: 100%;
    padding: 0.85rem 1.125rem;
    background: transparent;
    border: 0;
    text-align: left;
    cursor: pointer;
    color: var(--color-accent);
    transition: color 0.18s ease;
  }

  .hire-primary__copy:hover,
  .hire-primary__copy:focus-visible {
    color: var(--color-accent-hover);
  }

  .hire-primary__email {
    font-size: 0.95rem;
    overflow-wrap: anywhere;
    color: inherit;
  }

  @media (min-width: 380px) {
    .hire-primary__email {
      font-size: 1.05rem;
    }
  }

  @media (min-width: 640px) {
    .hire-primary__email {
      font-size: 1.125rem;
    }
  }

  .hire-primary__state {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    flex-shrink: 0;
    color: var(--color-emphasis);
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
  }

  .hire-primary__state-label:empty {
    display: none;
  }

  .hire-primary__send {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-left: 1.125rem;
    padding: 0.35rem 0;
    color: var(--color-foundation);
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    transition: color 0.18s ease;
  }

  .hire-primary__send:hover,
  .hire-primary__send:focus-visible {
    color: var(--color-accent-hover);
  }

  /* Secondary: borderless rows for LinkedIn / GitHub / X.
     Stacks on narrow widths, sits in a row when there's room. */
  .hire-secondary {
    list-style: none;
    margin: 0 0 1.25rem 0;
    padding: 0.875rem 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.625rem;
    border-top: 1px solid var(--color-faint);
    border-bottom: 1px solid var(--color-faint);
  }

  @media (min-width: 420px) {
    .hire-secondary {
      grid-template-columns: repeat(3, 1fr);
      gap: 0.5rem;
    }
  }

  .hire-link {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    padding: 0.25rem 0;
    color: var(--color-emphasis);
    transition: color 0.18s ease;
    min-width: 0;
  }

  .hire-link:hover,
  .hire-link:focus-visible {
    color: var(--color-accent-hover);
  }

  .hire-link__head {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .hire-link__icon {
    width: 1.25rem;
    height: 1.25rem;
  }

  .hire-link__name {
    font-size: 0.85rem;
    letter-spacing: 0.02em;
  }

  .hire-link__handle {
    color: var(--color-foundation);
    font-size: 0.78rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: color 0.18s ease;
  }

  .hire-link:hover .hire-link__handle,
  .hire-link:focus-visible .hire-link__handle {
    color: var(--color-accent-hover);
  }

  /* Tertiary: resume as a plain text link, not a card */
  .hire-resume {
    display: inline-flex;
    align-items: baseline;
    gap: 0.5rem;
    color: var(--color-foundation);
    transition: color 0.18s ease;
  }

  .hire-resume:hover,
  .hire-resume:focus-visible {
    color: var(--color-accent-hover);
  }

  /* Scanline overlay clipped to the panel shape */
  .hire-scanlines {
    position: absolute;
    inset: 0;
    z-index: 4;
    pointer-events: none;
    clip-path: var(--hire-clip);
    background: repeating-linear-gradient(
      0deg,
      transparent 0,
      transparent 2px,
      color-mix(in oklch, var(--color-accent) 6%, transparent) 2px,
      color-mix(in oklch, var(--color-accent) 6%, transparent) 3px
    );
    mix-blend-mode: screen;
    opacity: 0.5;
    animation: hire-scan-shift 0.25s linear infinite;
  }

  @keyframes hire-scan-shift {
    from {
      transform: translate3d(0, 0, 0);
    }
    to {
      transform: translate3d(0, 3px, 0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hire-scanlines {
      animation: none;
    }
  }

  @media (prefers-contrast: more) {
    .hire-frame::after {
      background: var(--color-emphasis);
    }
    .hire-scanlines {
      display: none;
    }
  }
</style>

<script>
  document.addEventListener("click", async (event) => {
    const target = event.target as HTMLElement | null;
    const button = target?.closest<HTMLButtonElement>("[data-copy-email]");
    if (!button) return;

    const value = button.dataset.copyEmail;
    if (!value) return;

    try {
      await navigator.clipboard.writeText(value);
    } catch {
      return;
    }

    const label = button.querySelector<HTMLElement>(
      ".hire-primary__state-label",
    );
    if (!label) return;

    label.textContent = "Copied";
    window.setTimeout(() => {
      label.textContent = "";
    }, 1500);
  });
</script>
