---
const email = "contact@grantkeller.dev";
const linkedinHandle = "grantdkeller";
const githubHandle = "gdkeller";
const xHandle = "GrantDKeller";
const resumeHref = "/Grant Keller Senior UX Engineer Resume 2025.pdf";
---

<dialog
  id="hire_me_modal"
  class="hire-modal fixed inset-0 z-100 h-dvh max-h-screen w-dvw max-w-screen
    items-center justify-center border-none bg-transparent p-4 open:flex"
  aria-labelledby="hire-modal-title"
>
  <article class="hire-frame relative w-full max-w-lg">
    <span
      class="hire-backdrop bg-background-dark absolute inset-0 z-2"
      aria-hidden="true"></span>

    <form method="dialog" class="absolute top-0 right-0 z-5">
      <button
        type="submit"
        class="text-background-dark border-background-dark hover:text-emphasis
          hover:bg-background-dark focus-visible:bg-background-dark
          focus-visible:text-emphasis flex h-16 w-16 cursor-pointer items-center
          justify-center border-0 border-l-2 bg-transparent transition-colors"
        aria-label="Close dialog"
      >
        <svg
          class="h-8 w-8"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </form>

    <div class="relative z-3">
      <header class="border-faint bg-emphasis border-b py-2 pl-8">
        <h2
          id="hire-modal-title"
          class="font-decorative text-background-dark text-5xl leading-none
            tracking-wide"
        >
          Open a channel
        </h2>
      </header>

      <div class="flex w-full flex-col">
        <button
          type="button"
          class="hire-primary__copy group text-highlight
            hover:text-highlight-hover focus-visible:text-highlight-hover flex
            w-auto cursor-pointer items-center gap-4 border-0 bg-transparent
            py-8 pr-4 pl-8 text-left transition-colors"
          data-copy-email={email}
          aria-label={`Copy ${email} to clipboard`}
        >
          <span class="hire-primary__email font-mono text-xl tracking-wide"
            >{email}</span
          >
          <span
            class="hire-primary__state text-accent group-hover:text-accent-hover
              inline-flex shrink-0 items-center gap-1.5 place-self-end pb-1
              font-mono uppercase"
            aria-hidden="true"
          >
            <svg
              class="h-4 w-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <rect x="9" y="9" width="11" height="11" rx="1.5" stroke-width="2"
              ></rect>
              <path
                d="M5 15H4a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h10a1 1 0 0 1 1 1v1"
                stroke-width="2"
                stroke-linecap="round"></path>
            </svg>
            <span
              class="hire-primary__state-label text-accent
                group-hover:text-accent-hover group-focus-visible:text-emphasis
                text-2xs mr-1 font-mono tracking-wide transition-colors"
              >Copy</span
            >
          </span>
        </button>
        <a
          href={`mailto:${email}`}
          class="hire-primary__send text-foundation hover:text-accent-hover
            focus-visible:text-accent-hover text-2xs mr-0 ml-auto inline-flex
            flex-1 items-center justify-end gap-1.5 px-4 pt-5 pb-4 font-mono
            tracking-wide whitespace-nowrap uppercase transition-colors"
        >
          <svg
            class="h-3 w-3"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M5 12h14M13 6l6 6-6 6"></path>
          </svg>
          <span>Open in mail client</span>
        </a>
      </div>

      <ul
        class="hire-secondary border-faint xs:grid-cols-3 grid list-none
          grid-cols-1 border-y"
      >
        <li>
          <a
            href={`https://www.linkedin.com/in/${linkedinHandle}/`}
            target="_blank"
            rel="noopener noreferrer"
            class="hire-link group text-emphasis hover:text-accent-hover
              focus-visible:text-accent-hover flex min-w-0 flex-col gap-2 px-8
              py-6 transition-colors"
          >
            <span class="inline-flex items-center gap-2">
              <svg
                class="h-5 w-5 shrink-0"
                fill="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                ></path>
              </svg>
              <span class="font-display text-sm tracking-wide">LinkedIn</span>
            </span>
            <span
              class="text-foundation group-hover:text-accent-hover
                group-focus-visible:text-accent-hover truncate font-mono text-xs
                transition-colors"
              >@{linkedinHandle}</span
            >
          </a>
        </li>
        <li class="border-faint border-l">
          <a
            href={`https://github.com/${githubHandle}`}
            target="_blank"
            rel="noopener noreferrer"
            class="hire-link group text-emphasis hover:text-accent-hover
              focus-visible:text-accent-hover flex min-w-0 flex-col gap-2 px-8
              py-6 transition-colors"
          >
            <span class="inline-flex items-center gap-2">
              <svg
                class="h-5 w-5 shrink-0"
                fill="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
                ></path>
              </svg>
              <span class="font-display text-sm tracking-wide">GitHub</span>
            </span>
            <span
              class="text-foundation group-hover:text-accent-hover
                group-focus-visible:text-accent-hover truncate font-mono text-xs
                transition-colors"
              >@{githubHandle}</span
            >
          </a>
        </li>
        <li class="border-faint border-l">
          <a
            href={`https://x.com/${xHandle}`}
            target="_blank"
            rel="noopener noreferrer"
            class="hire-link group text-emphasis hover:text-accent-hover
              focus-visible:text-accent-hover flex min-w-0 flex-col gap-2 px-8
              py-6 transition-colors"
          >
            <span class="inline-flex items-center gap-2">
              <svg
                class="h-5 w-5 shrink-0"
                fill="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
                ></path>
              </svg>
              <span class="font-display text-sm tracking-wide">X</span>
            </span>
            <span
              class="text-foundation group-hover:text-accent-hover
                group-focus-visible:text-accent-hover truncate font-mono text-xs
                transition-colors"
              >@{xHandle}</span
            >
          </a>
        </li>
      </ul>

      <div>
        <a
          href={resumeHref}
          target="_blank"
          rel="noopener noreferrer"
          class="link-resume group text-foundation hover:bg-emphasis
            hover:text-background-dark focus-visible:text-accent-hover
            inline-flex w-full items-baseline gap-2 px-8 py-4 transition-colors"
        >
          <svg
            class="h-4 w-4 translate-y-0.5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 4v12m0 0l-4-4m4 4l4-4M4 20h16"></path>
          </svg>
          <span class="font-mono leading-3"> Resume </span>
          <span
            class="text-accent group-hover:text-background-dark text-2xs
              font-mono leading-3"
          >
            PDF
          </span>
        </a>
      </div>
    </div>
  </article>

  <form method="dialog" class="hire-modal__backdrop fixed inset-0 -z-10">
    <button
      class="text-background-dark h-full w-full cursor-default"
      aria-label="Close dialog">close</button
    >
  </form>
</dialog>

<style>
  @reference "../styles/global.css";

  /* Clip-path with a notched bottom-right corner. Repeated as a CSS
     custom property so backdrop and frame stroke match. */
  .hire-frame {
    --hire-clip: polygon(
      0 0,
      100% 0,
      100% calc(100% - 3rem),
      calc(100% - 4rem) 100%,
      0 100%
    );
  }

  .hire-modal::backdrop {
    background: color-mix(in oklch, var(--color-background) 80%, transparent);
    backdrop-filter: blur(8px);
  }

  /* Frame stroke: 1px outline behind the backdrop, same clip-path */
  .hire-frame::after {
    @apply bg-faint pointer-events-none absolute -inset-0.5 z-1;
    content: "";
    clip-path: var(--hire-clip);
  }
  .hire-frame .link-resume {
    clip-path: var(--hire-clip);
  }

  .hire-backdrop {
    clip-path: var(--hire-clip);
  }

  @media (prefers-contrast: more) {
    .hire-frame::after {
      background: var(--color-emphasis);
    }
  }
</style>

<script>
  document.addEventListener("click", async (event) => {
    const target = event.target as HTMLElement | null;
    const button = target?.closest<HTMLButtonElement>("[data-copy-email]");
    if (!button) return;

    const value = button.dataset.copyEmail;
    if (!value) return;

    try {
      await navigator.clipboard.writeText(value);
    } catch {
      return;
    }

    const label = button.querySelector<HTMLElement>(
      ".hire-primary__state-label",
    );
    if (!label) return;

    label.textContent = "Copied";
    window.setTimeout(() => {
      label.textContent = "Copy";
    }, 1500);
  });
</script>
