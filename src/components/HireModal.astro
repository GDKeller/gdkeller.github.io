---
const email = "contact@grantkeller.dev";
const linkedinHandle = "grantdkeller";
const githubHandle = "gdkeller";
const xHandle = "GrantDKeller";
const resumeHref = "/Grant Keller Senior UX Engineer Resume 2025.pdf";

import Overlays from "./Overlays.astro";
---

<dialog
  id="hire_me_modal"
  class="hire-modal fixed inset-0 h-dvh max-h-screen w-dvw max-w-screen
    items-center justify-center border-none bg-transparent p-4 open:flex"
  aria-labelledby="hire-modal-title"
>
  <article class="hire-frame relative w-full max-w-lg">
    <span
      class="hire-backdrop bg-background-dark absolute inset-0 z-2"
      aria-hidden="true"></span>
    <form
      method="dialog"
      class="close-button-frame absolute top-0 right-0 z-5 translate-x-2
        -translate-y-1/2"
    >
      <button
        type="submit"
        class="text-emphasis close-button bg-background-dark
          hover:text-background-dark hover:bg-emphasis focus-visible:bg-emphasis
          focus-visible:text-background-dark hover:border-emphasis relative flex
          h-14 w-14 cursor-pointer items-center justify-center"
        aria-label="Close dialog"
      >
        <span class="absolute -inset-0.5">
          <Overlays
            position="absolute"
            blend={false}
            scanlinesClass="z-2"
            scanlinesOpacityClass="opacity-5"
            noiseClass="z-1"
            noiseOpacityClass="opacity-6"
          />
        </span>
        <svg
          class="z-10 h-6 w-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </form>

    <div class="relative">
      <header class="border-faint flex">
        <h2
          id="hire-modal-title"
          class="text-emphasis bg-background-dark border-faint relative isolate
            z-8 mr-auto flex -translate-x-0.5 -translate-y-1/2 overflow-hidden
            border-2 py-4 pr-8 pl-8 font-mono text-base leading-none font-light
            tracking-wide uppercase"
        >
          <span class="absolute -inset-0.5">
            <Overlays
              position="absolute"
              blend={false}
              scanlinesClass="z-2"
              scanlinesOpacityClass="opacity-5"
              noiseClass="z-1"
              noiseOpacityClass="opacity-6"
            />
          </span>
          <span class="z-10">Transmission</span>
        </h2>
      </header>

      <div class="mx-auto mb-12 flex w-min flex-col">
        <button
          type="button"
          class="hire-primary__copy group border-highlight text-highlight
            hover:border-highlight-hover focus-visible:border-highlight-hover
            hover:text-highlight-hover focus-visible:text-highlight-hover
            relative z-10 mb-4 ml-4 flex cursor-pointer flex-col items-center
            gap-4 border-0 border-b bg-transparent py-8 pr-20 pb-3 pl-4
            text-left transition-colors"
          data-copy-email={email}
          aria-label={`Copy ${email} to clipboard`}
        >
          <span class="hire-primary__email font-mono text-xl tracking-wide"
            >{email}</span
          >
          <span
            class="hire-primary__state text-highlight
              group-hover:text-highlight-hover text-2xs absolute right-12
              bottom-1 z-10 inline-flex shrink-0 -translate-y-1/2 items-center
              gap-1.5 place-self-end pb-1 font-mono uppercase transition-colors"
            aria-hidden="true"
          >
            <svg
              class="h-4 w-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <rect x="9" y="9" width="11" height="11" rx="1.5" stroke-width="2"
              ></rect>
              <path
                d="M5 15H4a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h10a1 1 0 0 1 1 1v1"
                stroke-width="2"
                stroke-linecap="round"></path>
            </svg>
            <span
              class="hire-primary__state-label text-highlight
                group-hover:text-highlight-hover
                group-focus-visible:text-highlight-hover text-2xs absolute
                bottom-0 left-full mr-1 translate-x-1 -translate-y-1/3 font-mono
                tracking-wide transition-colors"
              >Copy</span
            >
          </span>
        </button>
        <a
          href={`mailto:${email}`}
          class="hire-primary__send text-foundation hover:border-highlight-hover
            focus-visible:border-highlight-hover hover:text-highlight-hover
            focus-visible:text-highlight-hover text-2xs border-faint z-10 mr-0
            ml-auto inline-flex flex-1 items-center gap-1.5 border border-dashed
            px-2 py-2 font-mono tracking-wide whitespace-nowrap uppercase
            transition-colors"
        >
          <svg
            class="h-3 w-3"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M5 12h14M13 6l6 6-6 6"></path>
          </svg>
          <span>Open in mail client</span>
        </a>
      </div>

      <div class="border-faint relative z-10 border-t-2">
        <a
          href={resumeHref}
          target="_blank"
          rel="noopener noreferrer"
          class="link-resume group text-emphasis hover:text-highlight-hover
            focus-visible:text-accent-hover z-10 inline-flex items-center gap-2
            px-8 py-6"
        >
          <svg
            class="h-4 w-4"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 4v12m0 0l-4-4m4 4l4-4M4 20h16"></path>
          </svg>
          <span class="font-mono leading-3"> Resume </span>
          <span
            class="group-hover:text-highlight-hover text-2xs font-mono leading-3
              tracking-wider"
          >
            [PDF]
          </span>
        </a>
      </div>

      <ul
        class="hire-secondary border-faint xs:grid-cols-3 relative z-10 grid
          list-none grid-cols-1 border-t-2"
      >
        <li>
          <a
            href={`https://www.linkedin.com/in/${linkedinHandle}/`}
            target="_blank"
            rel="noopener noreferrer"
            class="hire-link group text-emphasis hover:text-accent-hover
              focus-visible:text-accent-hover relative z-10 flex min-w-0
              flex-col gap-2 px-8 py-6 transition-colors"
          >
            <span class="inline-flex items-center gap-2">
              <svg
                class="h-5 w-5 shrink-0"
                fill="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                ></path>
              </svg>
              <span class="font-display text-sm tracking-wide">LinkedIn</span>
            </span>
            <span
              class="text-foundation group-hover:text-accent-hover
                group-focus-visible:text-accent-hover truncate font-mono text-xs
                transition-colors"
              >@{linkedinHandle}</span
            >
          </a>
        </li>
        <li class="border-faint border-l-2">
          <a
            href={`https://github.com/${githubHandle}`}
            target="_blank"
            rel="noopener noreferrer"
            class="hire-link group text-emphasis hover:text-accent-hover
              focus-visible:text-accent-hover relative z-10 flex min-w-0
              flex-col gap-2 px-8 py-6 transition-colors"
          >
            <span class="inline-flex items-center gap-2">
              <svg
                class="h-5 w-5 shrink-0"
                fill="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
                ></path>
              </svg>
              <span class="font-display text-sm tracking-wide">GitHub</span>
            </span>
            <span
              class="text-foundation group-hover:text-accent-hover
                group-focus-visible:text-accent-hover truncate font-mono text-xs
                transition-colors"
              >@{githubHandle}</span
            >
          </a>
        </li>
        <li class="border-faint border-l-2">
          <a
            href={`https://x.com/${xHandle}`}
            target="_blank"
            rel="noopener noreferrer"
            class="hire-link group text-emphasis hover:text-accent-hover
              focus-visible:text-accent-hover relative z-10 flex min-w-0
              flex-col gap-2 px-8 py-6 transition-colors"
          >
            <span class="inline-flex items-center gap-2">
              <svg
                class="h-5 w-5 shrink-0"
                fill="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
                ></path>
              </svg>
              <span class="font-display text-sm tracking-wide">X</span>
            </span>
            <span
              class="text-foundation group-hover:text-accent-hover
                group-focus-visible:text-accent-hover truncate font-mono text-xs
                transition-colors"
              >@{xHandle}</span
            >
          </a>
        </li>
      </ul>
    </div>
    <div
      class="pointer-events-none absolute -inset-0.5 z-4 overflow-hidden"
      aria-hidden="true"
    >
      <Overlays
        position="absolute"
        scanlinesClass="z-2"
        scanlinesOpacityClass="opacity-5"
        noiseClass="z-1"
        noiseOpacityClass="opacity-6"
      />
    </div>
  </article>
  <form method="dialog" class="hire-modal__backdrop fixed inset-0 -z-10">
    <button
      class="text-background-dark h-full w-full cursor-default"
      aria-label="Close dialog">close</button
    >
  </form>
</dialog>

<style lang="scss">
  @reference "../styles/global.css";

  /* Clip-path with a notched bottom-right corner. Repeated as a CSS
     custom property so backdrop and frame stroke match. */
  .hire-frame {
    --clip-tr: polygon(0 0, calc(100% - 20%) 0, 100% 20%, 100% 100%, 0 100%);
    --clip-br: polygon(
      0 0,
      100% 0,
      100% calc(100% - 2rem),
      calc(100% - 2rem) 100%,
      0 100%
    );
  }

  .close-button {
    clip-path: var(--clip-tr);
  }

  /* Border ring lives on the form wrapper so it paints before the button
     in tree order. Putting it on .close-button itself doesn't work: the
     button's clip-path creates a stacking context, which traps a negative
     z-index ::before above the button's own background. */
  .close-button-frame::before {
    @apply bg-faint absolute -top-0.5 -right-0.5 -bottom-0.5 -left-0.5;
    content: "";
    clip-path: var(--clip-tr);
  }

  .hire-modal::backdrop {
    background: color-mix(in oklch, var(--color-background) 90%, transparent);
    backdrop-filter: blur(8px);
  }

  /* Frame stroke: 1px outline behind the backdrop, same clip-path */
  .hire-frame::after {
    @apply bg-faint pointer-events-none absolute -inset-0.5 z-1;
    content: "";
    clip-path: var(--clip-br);
  }

  .hire-backdrop {
    clip-path: var(--clip-br);
  }

  @media (prefers-contrast: more) {
    .hire-frame::after {
      background: var(--color-emphasis);
    }
  }

  /* Lock page scroll while the modal is open. `:has()` targets the
     html element when the dialog has the [open] attribute set by
     showModal(). `scrollbar-gutter: stable` prevents content shift
     when the scrollbar disappears. */
  :global(html:has(dialog#hire_me_modal[open])) {
    overflow: hidden;
    scrollbar-gutter: stable;
  }
</style>

<script>
  document.addEventListener("click", async (event) => {
    const target = event.target as HTMLElement | null;
    const button = target?.closest<HTMLButtonElement>("[data-copy-email]");
    if (!button) return;

    const value = button.dataset.copyEmail;
    if (!value) return;

    try {
      await navigator.clipboard.writeText(value);
    } catch {
      return;
    }

    const label = button.querySelector<HTMLElement>(
      ".hire-primary__state-label",
    );
    if (!label) return;

    label.textContent = "Copied";
    window.setTimeout(() => {
      label.textContent = "Copy";
    }, 1500);
  });
</script>
