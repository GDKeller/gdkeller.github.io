---
const email = "contact@grantkeller.dev";
const linkedinHandle = "grantdkeller";
const githubHandle = "gdkeller";
const xHandle = "GrantDKeller";
const resumeHref = "/Grant Keller Senior UX Engineer Resume 2025.pdf";

import Overlays from "./Overlays.astro";
import IconArrowRight from "./icons/IconArrowRight.astro";
import IconClose from "./icons/IconClose.astro";
import IconCopy from "./icons/IconCopy.astro";
import IconDownload from "./icons/IconDownload.astro";
import IconGitHub from "./icons/IconGitHub.astro";
import IconLinkedIn from "./icons/IconLinkedIn.astro";
import IconX from "./icons/IconX.astro";
---

<dialog
  id="hire_me_modal"
  class="hire-modal fixed inset-0 h-dvh max-h-screen w-dvw max-w-screen
    items-center justify-center border-none bg-transparent p-4 open:flex"
  aria-labelledby="hire-modal-title"
>
  <article class="hire-frame relative w-full max-w-lg">
    <span
      class="hire-backdrop bg-background-dark absolute inset-0 z-2"
      aria-hidden="true"></span>
    <form
      method="dialog"
      class="close-button-frame absolute top-0 right-0 z-5 -translate-y-1/2
        sm:translate-x-2"
    >
      <button
        type="submit"
        class="text-emphasis close-button bg-background-dark
          hover:text-background-dark hover:bg-emphasis focus-visible:bg-emphasis
          focus-visible:text-background-dark hover:border-emphasis relative flex
          h-14 w-14 cursor-pointer items-center justify-center"
        aria-label="Close dialog"
      >
        <span class="absolute -inset-0.5">
          <Overlays
            position="absolute"
            blend={false}
            scanlinesClass="z-2"
            scanlinesOpacityClass="opacity-5"
            noiseClass="z-1"
            noiseOpacityClass="opacity-6"
          />
        </span>
        <IconClose class="z-10 h-6 w-6" />
      </button>
    </form>

    <div class="relative">
      <header class="border-faint flex">
        <h2
          id="hire-modal-title"
          class="text-emphasis bg-background-dark border-faint relative isolate
            z-8 mr-auto flex -translate-x-0.5 -translate-y-1/2 overflow-hidden
            border-2 py-5 pr-8 pl-8 font-mono text-base leading-none font-light
            tracking-wide uppercase"
        >
          <span class="absolute -inset-0.5">
            <Overlays
              position="absolute"
              blend={false}
              scanlinesClass="z-2"
              scanlinesOpacityClass="opacity-5"
              noiseClass="z-1"
              noiseOpacityClass="opacity-6"
            />
          </span>
          <span class="z-10">Transmission</span>
        </h2>
      </header>

      <div class="mx-auto mb-12 flex w-min flex-col">
        <button
          type="button"
          class="hire-primary__copy group relative z-10 flex flex-col-reverse
            items-center gap-4 xs:flex-row mb-6 py-8 pb-3 xs:ml-4 xs:px-4
            xs:pr-16 sm:pr-20 cursor-pointer border-0 border-b border-highlight
            bg-transparent text-left text-highlight transition-colors
            hover:border-highlight-hover hover:text-highlight-hover
            focus-visible:border-highlight-hover
            focus-visible:text-highlight-hover"
          data-copy-email={email}
          aria-label={`Copy ${email} to clipboard`}
        >
          <span
            class="hire-primary__email font-mono text-base xs:text-xl
              tracking-wide"
            >{email}</span
          >
          <span
            class="hire-primary__state absolute right-8 sm:right-12 bottom-10
              xs:bottom-1 xs:-translate-y-1/2 xs:place-self-end z-10 inline-flex
              shrink-0 items-center gap-1.5 pb-1 font-mono text-2xs uppercase
              text-highlight group-hover:text-highlight-hover transition-colors"
            aria-hidden="true"
          >
            <IconCopy class="h-4 w-4" />
            <span
              class="hire-primary__state-label text-highlight
                group-hover:text-highlight-hover
                group-focus-visible:text-highlight-hover text-2xs absolute
                bottom-0 left-full mr-1 translate-x-1 -translate-y-1/3 font-mono
                tracking-wide transition-colors"
              >Copy</span
            >
          </span>
        </button>
        <a
          href={`mailto:${email}`}
          class="hire-primary__send text-foundation hover:border-highlight-hover
            focus-visible:border-highlight-hover hover:text-highlight-hover
            focus-visible:text-highlight-hover text-2xs border-faint z-10 mr-0
            ml-auto inline-flex flex-1 items-center gap-1.5 border border-dashed
            px-2 py-2 font-mono tracking-wide whitespace-nowrap uppercase
            transition-colors"
        >
          <IconArrowRight class="h-3 w-3" />
          <span>Open in mail client</span>
        </a>
      </div>

      <div class="border-faint relative z-10 border-t-2">
        <a
          href={resumeHref}
          target="_blank"
          rel="noopener noreferrer"
          class="link-resume group text-emphasis hover:text-highlight-hover
            focus-visible:text-accent-hover z-10 inline-flex items-center gap-2
            px-8 py-6"
        >
          <IconDownload class="h-4 w-4" />
          <span class="font-mono leading-3"> Resume </span>
          <span
            class="group-hover:text-highlight-hover text-2xs font-mono leading-3
              tracking-wider"
          >
            [PDF]
          </span>
        </a>
      </div>

      <ul
        class="hire-secondary border-faint relative z-10 grid list-none
          grid-cols-3 border-t-2"
      >
        <li>
          <a
            href={`https://www.linkedin.com/in/${linkedinHandle}/`}
            target="_blank"
            rel="noopener noreferrer"
            class="hire-link group text-emphasis hover:text-accent-hover
              focus-visible:text-accent-hover relative z-10 flex min-w-0
              flex-col gap-2 px-4 py-6 transition-colors sm:px-8"
          >
            <span
              class="inline-flex items-center justify-center xs:justify-start
                gap-2"
            >
              <IconLinkedIn class="h-12 w-12 xs:h-5 xs:w-5 shrink-0" />
              <span class="hidden xs:block font-display text-sm tracking-wide"
                >LinkedIn</span
              >
            </span>
            <span
              class="hidden xs:block truncate font-mono text-xs text-foundation
                group-hover:text-accent-hover
                group-focus-visible:text-accent-hover transition-colors"
              >@{linkedinHandle}</span
            >
          </a>
        </li>
        <li class="border-faint border-l-2">
          <a
            href={`https://github.com/${githubHandle}`}
            target="_blank"
            rel="noopener noreferrer"
            class="hire-link group text-emphasis hover:text-accent-hover
              focus-visible:text-accent-hover relative z-10 flex min-w-0
              flex-col gap-2 px-4 py-6 transition-colors sm:px-8"
          >
            <span
              class="inline-flex items-center justify-center xs:justify-start
                gap-2"
            >
              <IconGitHub class="h-12 w-12 xs:h-5 xs:w-5 shrink-0" />
              <span class="hidden xs:block font-display text-sm tracking-wide"
                >GitHub</span
              >
            </span>
            <span
              class="hidden xs:block truncate font-mono text-xs text-foundation
                group-hover:text-accent-hover
                group-focus-visible:text-accent-hover transition-colors"
              >@{githubHandle}</span
            >
          </a>
        </li>
        <li class="border-faint border-l-2">
          <a
            href={`https://x.com/${xHandle}`}
            target="_blank"
            rel="noopener noreferrer"
            class="hire-link group text-emphasis hover:text-accent-hover
              focus-visible:text-accent-hover relative z-10 flex min-w-0
              flex-col gap-2 px-4 py-6 transition-colors sm:px-8"
          >
            <span
              class="inline-flex items-center justify-center xs:justify-start
                gap-2"
            >
              <IconX class="h-12 w-12 xs:h-5 xs:w-5 shrink-0" />
              <span class="hidden xs:block font-display text-sm tracking-wide"
                >X</span
              >
            </span>
            <span
              class="hidden xs:block truncate font-mono text-xs text-foundation
                group-hover:text-accent-hover
                group-focus-visible:text-accent-hover transition-colors"
              >@{xHandle}</span
            >
          </a>
        </li>
      </ul>
    </div>
    <div
      class="pointer-events-none absolute -inset-0.5 z-4 overflow-hidden"
      aria-hidden="true"
    >
      <Overlays
        position="absolute"
        scanlinesClass="z-2"
        scanlinesOpacityClass="opacity-5"
        noiseClass="z-1"
        noiseOpacityClass="opacity-6"
      />
    </div>
  </article>
  <form method="dialog" class="hire-modal__backdrop fixed inset-0 -z-10">
    <button
      class="text-background-dark h-full w-full cursor-default"
      aria-label="Close dialog">close</button
    >
  </form>
</dialog>

<style lang="scss">
  @reference "../styles/main.css";

  /* Clip-path with a notched bottom-right corner. Repeated as a CSS
     custom property so backdrop and frame stroke match. */
  .hire-frame {
    --clip-tr: polygon(0 0, calc(100% - 20%) 0, 100% 20%, 100% 100%, 0 100%);
  }

  .close-button {
    clip-path: var(--clip-tr);
  }

  /* Border ring lives on the form wrapper so it paints before the button
     in tree order. Putting it on .close-button itself doesn't work: the
     button's clip-path creates a stacking context, which traps a negative
     z-index ::before above the button's own background. */
  .close-button-frame::before {
    @apply bg-faint absolute -top-0.5 -right-0.5 -bottom-0.5 -left-0.5;
    content: "";
    clip-path: var(--clip-tr);
  }

  .hire-modal::backdrop {
    background: color-mix(in oklch, var(--color-background) 90%, transparent);
    backdrop-filter: blur(8px);
  }

  /* Frame stroke: 1px outline behind the backdrop, same clip-path */
  .hire-frame::after {
    @apply bg-faint pointer-events-none absolute -inset-0.5 z-1;
    content: "";
  }

  @media (prefers-contrast: more) {
    .hire-frame::after {
      background: var(--color-emphasis);
    }
  }

  /* Lock page scroll while the modal is open. `:has()` targets the
     html element when the dialog has the [open] attribute set by
     showModal(). `scrollbar-gutter: stable` prevents content shift
     when the scrollbar disappears. */
  :global(html:has(dialog#hire_me_modal[open])) {
    overflow: hidden;
    scrollbar-gutter: stable;
  }
</style>

<script>
  document.addEventListener("click", async (event) => {
    const target = event.target as HTMLElement | null;
    const button = target?.closest<HTMLButtonElement>("[data-copy-email]");
    if (!button) return;

    const value = button.dataset.copyEmail;
    if (!value) return;

    try {
      await navigator.clipboard.writeText(value);
    } catch {
      return;
    }

    const label = button.querySelector<HTMLElement>(
      ".hire-primary__state-label",
    );
    if (!label) return;

    label.textContent = "Copied";
    window.setTimeout(() => {
      label.textContent = "Copy";
    }, 1500);
  });
</script>
