---
// Layered cyberpunk background for hero section
import { Image } from "astro:assets";
import heroImg1 from "../images/Texturelabs_LensFX_173L.webp";
import heroImg2 from "../images/Texturelabs_LensFX_127L.webp";
import heroImg3 from "../images/Texturelabs_Sky_151L.webp";
---

<div class="hero-bg absolute inset-0 -z-10 overflow-hidden" id="hero-bg">
  <!-- Layer 0a: Background Image -->
  <Image
    src={heroImg1}
    alt=""
    class="absolute inset-0 h-full w-full object-cover opacity-30 mix-blend-soft-light brightness-50"
    loading="eager"
  />
  <!-- Layer 0b: Background Image -->
  <Image
    src={heroImg2}
    alt=""
    class="absolute inset-0 h-full w-[150vw] max-w-none -translate-x-1/8 object-cover opacity-30 brightness-30 contrast-150"
    loading="eager"
  />

  <!-- Layer 0c: Background Image -->
  <Image
    src={heroImg3}
    alt=""
    class="absolute inset-0 h-full w-full object-cover opacity-50 mix-blend-overlay brightness-50"
    loading="eager"
  />

  <!-- Scan Lines -->
  <div class="scanlines pointer-events-none absolute inset-0"></div>

  <!-- Noise -->
  <div class="noise pointer-events-none absolute inset-0"></div>
</div>

<style>
  /* Scan Lines */
  .scanlines {
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      color-mix(in oklch, var(--color-black) 3%, transparent) 2px,
      color-mix(in oklch, var(--color-black) 3%, transparent) 4px
    );
    opacity: 0.5;
  }

  /* Noise */
  .noise {
    opacity: 0.03;
    animation: noise-shift 0.2s steps(10) infinite;
  }

  .noise::before {
    content: "";
    position: absolute;
    inset: -50%;
    width: 200%;
    height: 200%;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
  }

  @keyframes noise-shift {
    0% {
      transform: translate(0, 0);
    }
    10% {
      transform: translate(-5%, -5%);
    }
    20% {
      transform: translate(5%, 5%);
    }
    30% {
      transform: translate(-3%, 3%);
    }
    40% {
      transform: translate(3%, -3%);
    }
    50% {
      transform: translate(-5%, 5%);
    }
    60% {
      transform: translate(5%, -5%);
    }
    70% {
      transform: translate(-3%, -3%);
    }
    80% {
      transform: translate(3%, 3%);
    }
    90% {
      transform: translate(-5%, 0);
    }
    100% {
      transform: translate(0, 0);
    }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .noise {
      animation: none;
    }
  }
</style>
