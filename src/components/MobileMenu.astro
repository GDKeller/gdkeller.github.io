---
import ContactCard from "./ContactCard.astro";
import Overlays from "./Overlays.astro";
import IconArrowRight from "./icons/IconArrowRight.astro";
import IconClose from "./icons/IconClose.astro";

const navLinks = [
  { href: "#building", label: "Building" },
  { href: "#skills", label: "Skills" },
  { href: "#jobs", label: "Experience" },
  { href: "#projects", label: "Projects" },
];
---

<dialog
  id="mobile_menu"
  class="mobile-menu fixed inset-0 h-dvh max-h-screen w-dvw max-w-screen
    items-start justify-center overflow-y-auto overscroll-contain border-none
    bg-transparent p-4 pt-8 open:flex"
  aria-labelledby="mobile-menu-title"
>
  <article class="mobile-menu-frame relative w-full max-w-md">
    <span
      class="mobile-menu-backdrop bg-background-dark absolute inset-0 z-2"
      aria-hidden="true"></span>
    <form
      method="dialog"
      class="close-button-frame absolute top-0 right-0 z-5 -translate-y-1/2
        sm:translate-x-2"
    >
      <button
        type="submit"
        class="text-emphasis close-button bg-background-dark
          hover:text-background-dark hover:bg-emphasis focus-visible:bg-emphasis
          focus-visible:text-background-dark hover:border-emphasis relative flex
          h-14 w-14 cursor-pointer items-center justify-center"
        aria-label="Close menu"
      >
        <span class="absolute -inset-0.5">
          <Overlays
            position="absolute"
            blend={false}
            scanlinesClass="z-2"
            scanlinesOpacityClass="opacity-5"
            noiseClass="z-1"
            noiseOpacityClass="opacity-6"
          />
        </span>
        <IconClose class="z-10 h-6 w-6" />
      </button>
    </form>

    <div class="relative">
      <header class="border-faint flex">
        <h2
          id="mobile-menu-title"
          class="text-emphasis bg-background-dark border-faint relative isolate
            z-8 mr-auto flex -translate-x-0.5 -translate-y-1/2 overflow-hidden
            border-2 py-5 pr-8 pl-8 font-mono text-base leading-none font-light
            tracking-wide uppercase"
        >
          <span class="absolute -inset-0.5">
            <Overlays
              position="absolute"
              blend={false}
              scanlinesClass="z-2"
              scanlinesOpacityClass="opacity-5"
              noiseClass="z-1"
              noiseOpacityClass="opacity-6"
            />
          </span>
          <span class="z-10">Directory</span>
        </h2>
      </header>

      <nav aria-label="Primary" class="relative z-10">
        <ul class="border-faint list-none border-t-2">
          {
            navLinks.map(({ href, label }) => (
              <li class="border-faint border-b-2 last:border-b-0">
                <a
                  href={href}
                  class="mobile-nav-link group text-emphasis
                    hover:text-highlight-hover focus-visible:text-highlight-hover
                    flex min-h-12 items-center justify-between gap-4 px-6 py-4
                    font-mono text-base tracking-wide uppercase transition-colors"
                >
                  <span>{label}</span>
                  <IconArrowRight
                    class="text-emphasis group-hover:text-highlight-hover
                      group-focus-visible:text-highlight-hover h-4 w-4
                      transition-colors"
                  />
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <ContactCard />
    </div>

    <div
      class="pointer-events-none absolute -inset-0.5 z-4 overflow-hidden"
      aria-hidden="true"
    >
      <Overlays
        position="absolute"
        scanlinesClass="z-2"
        scanlinesOpacityClass="opacity-5"
        noiseClass="z-1"
        noiseOpacityClass="opacity-6"
      />
    </div>
  </article>
  <form method="dialog" class="mobile-menu__backdrop fixed inset-0 -z-10">
    <button
      class="text-background-dark h-full w-full cursor-default"
      aria-label="Close menu">close</button
    >
  </form>
</dialog>

<style lang="scss">
  @reference "../styles/main.css";

  .mobile-menu-frame {
    --clip-tr: polygon(0 0, calc(100% - 20%) 0, 100% 20%, 100% 100%, 0 100%);
  }

  .close-button {
    clip-path: var(--clip-tr);
  }

  .close-button-frame::before {
    @apply bg-faint absolute -top-0.5 -right-0.5 -bottom-0.5 -left-0.5;
    content: "";
    clip-path: var(--clip-tr);
  }

  .mobile-menu::backdrop {
    background: color-mix(in oklch, var(--color-background) 90%, transparent);
    backdrop-filter: blur(8px);
  }

  .mobile-menu-frame::after {
    @apply bg-faint pointer-events-none absolute -inset-0.5 z-1;
    content: "";
  }

  @media (prefers-contrast: more) {
    .mobile-menu-frame::after {
      background: var(--color-emphasis);
    }
  }

  :global(html:has(dialog#mobile_menu[open])) {
    overflow: hidden;
  }
</style>

<script>
  /* Close the dialog on in-page anchor clicks. Two reasons: (1) UX, the modal
     shouldn't stay stranded over the scroll destination; (2) the :has() rule
     above locks html overflow while the menu is open, so the dialog has to
     close before the browser's native scroll-to-hash can take effect. */
  const dialog = document.getElementById(
    "mobile_menu",
  ) as HTMLDialogElement | null;

  dialog?.addEventListener(
    "click",
    (event) => {
      const target = event.target as HTMLElement | null;
      const link = target?.closest<HTMLAnchorElement>('a[href^="#"]');
      if (!link || !dialog.contains(link)) return;
      dialog.close();
    },
    true,
  );
</script>
