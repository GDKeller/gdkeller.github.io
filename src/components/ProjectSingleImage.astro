---
import { Picture } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  imagePath: string;
  altText: string;
  widths?: number[];
  sizes?: string;
}

const { imagePath, altText, widths = [200, 400, 800], sizes = "(min-width: 768px) 25vw, 60vw" } =
  Astro.props;

const images = import.meta.glob<{ default: ImageMetadata }>([
  "/src/images/projects/*/*.{jpeg,jpg,png,gif,webp}",
  "/src/images/logos/clients/original/*.{jpeg,jpg,png,gif,webp}",
  "/src/images/logos/jobs/*.{jpeg,jpg,png,gif,webp}",
]);

if (!images[imagePath]) {
  console.error(`Image not found: ${imagePath}`);
}
---

<div class="project-image relative">
  {
    images[imagePath] ? (
      <Picture
        src={images[imagePath]()}
        alt={altText ?? "Project"}
        widths={widths}
        sizes={sizes}
        formats={["avif", "webp"]}
        fallbackFormat="webp"
        loading="lazy"
        class="w-auto object-contain"
      />
    ) : null
  }
</div>
