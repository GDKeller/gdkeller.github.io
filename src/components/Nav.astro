---
const { class: className } = Astro.props;

const navLinks = [
  { href: "#building", label: "Building" },
  { href: "#skills", label: "Skills" },
  { href: "#jobs", label: "Experience" },
  { href: "#projects", label: "Projects" },
];
---

<nav
  id="main-nav"
  class:list={[
    "relative mr-auto flex items-stretch gap-x-1 pr-px md:px-px",
    className,
  ]}
>
  {
    navLinks.map(({ href, label }) => (
      <a
        href={href}
        data-section={href.slice(1)}
        class="nav-link hover:text-emphasis-hover text-emphasis
          bg-background-dark relative flex items-center px-2 font-mono text-sm
          font-light tracking-wide transition-colors md:text-sm xl:text-base"
      >
        {label}
      </a>
    ))
  }
</nav>

<style>
  .nav-link {
    position: relative;
    transition: color 500ms ease;
  }

  .nav-link::before {
    content: "▲";
    position: absolute;
    color: var(--color-emphasis);
    font-size: 0.3rem;
    left: 50%;
    bottom: 0;
    line-height: 0.75;
    transform: translateX(-50%) translateY(50%) scale3d(3, 0, 1);
    transform-origin: center;
    opacity: 0;
    transition:
      transform 500ms ease,
      opacity 150ms ease;
  }

  .nav-link:hover,
  .nav-link:focus-visible {
    color: var(--color-accent-hover);
  }

  .nav-link:focus-visible {
    z-index: 2;
  }

  .nav-link:hover::before,
  .nav-link:focus-visible::before {
    transform: translateX(-50%) translateY(100%) scale3d(3, 1, 1);
    animation: pointerBounce 500ms ease-in-out infinite both;
    opacity: 1;
  }

  @keyframes pointerBounce {
    0% {
      color: var(--color-accent);
      transform: translateX(-50%) translateY(100%) scale3d(3, 1, 1);
    }
    50% {
      color: var(--color-accent-hover);
      transform: translateX(-50%) translateY(180%) scale3d(3, 1, 1);
    }
    100% {
      color: var(--color-accent);
      transform: translateX(-50%) translateY(100%) scale3d(3, 1, 1);
    }
  }

  .nav-link.active::before {
    opacity: 0;
  }

  .nav-link::after {
    content: "▲";
    position: absolute;
    color: var(--color-emphasis);
    font-size: 0.3rem;
    left: 50%;
    bottom: 0;
    line-height: 0.75;
    transform: translateX(-50%) translateY(50%) scale3d(3, 0, 1);
    transform-origin: center;
    opacity: 0;
    transition:
      transform 500ms ease,
      opacity 150ms ease;
  }

  .nav-link.active {
    color: var(--color-accent);
  }

  .nav-link.active::after {
    transform: translateX(-50%) translateY(80%) scale3d(3, 1, 1);
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-link,
    .nav-link::before,
    .nav-link::after {
      animation: none;
      transition: none;
    }
  }
</style>

<script>
  const navLinks = document.querySelectorAll<HTMLAnchorElement>(
    "#main-nav .nav-link",
  );
  const sections = Array.from(navLinks)
    .map((link) => document.getElementById(link.dataset.section!))
    .filter(Boolean) as HTMLElement[];

  function setActiveSection() {
    const scrollY = window.scrollY;
    const viewportHeight = window.innerHeight;
    const triggerPoint = scrollY + viewportHeight * 0.3;

    let activeSection: HTMLElement | null = null;

    for (const section of sections) {
      const rect = section.getBoundingClientRect();
      const sectionTop = rect.top + scrollY;

      if (sectionTop <= triggerPoint) {
        activeSection = section;
      }
    }

    if (activeSection) {
      navLinks.forEach((l) => l.classList.remove("active"));
      const link = document.querySelector(
        `[data-section="${activeSection.id}"]`,
      );
      link?.classList.add("active");
    }
  }

  // Throttle scroll handler with requestAnimationFrame
  let ticking = false;
  window.addEventListener(
    "scroll",
    () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          setActiveSection();
          ticking = false;
        });
        ticking = true;
      }
    },
    { passive: true },
  );
  setActiveSection();
</script>
