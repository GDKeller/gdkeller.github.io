---

---

<footer class="pt-40 font-body bg-background">
  <!-- CTA Section -->
  <div class="container max-w-2xl px-8 pb-32 mx-auto text-center">
    <h3 class="mb-6 font-mono text-4xl text-emphasis md:text-4xl">
      Send a Wire
    </h3>
    <div class="flex flex-col justify-center gap-4 sm:flex-row">
      <button
        data-open-modal="hire_me_modal"
        class="inline-flex items-center justify-center px-8 py-4 text-base font-medium transition-all duration-200 text-background-dark bg-accent hover:bg-accent-hover"
      >
        Get in Touch
        <svg
          class="w-5 h-5 ml-2"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
        </svg>
      </button>
      <a
        href="/Grant Keller Senior UX Engineer Resume 2025.pdf"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center px-8 py-4 text-base font-medium transition-all duration-200 border hover:border-accent-hover text-emphasis border-accent bg-background-dark"
      >
        <span class="relative z-110">Download Resume</span>
        <svg
          class="w-5 h-5 ml-2"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
          ></path>
        </svg>
      </a>
    </div>
  </div>

  <!-- Site Info -->
  <div class="px-8 py-8 text-center border-t border-fainter bg-background-dark">
    <div class="container mx-auto">
      <p class="font-mono text-sm">
        <span class="inline-block"
          >Built with <a
            class="text-emphasis hover:text-emphasis-hover hover:underline"
            href="https://astro.build/"
            target="_blank"
            rel="noopener noreferrer">Astro</a
          >,
          <a
            class="text-emphasis hover:text-emphasis-hover hover:underline"
            href="https://tailwindcss.com/"
            target="_blank"
            rel="noopener noreferrer">Tailwind</a
          > & <a
            class="text-emphasis hover:text-emphasis-hover hover:underline"
            href="https://gsap.com/"
            target="_blank"
            rel="noopener noreferrer">GSAP</a
          ></span
        >
        <span class="mx-4">᠅</span>
        <span class="inline-block"
          ><a
            class="text-emphasis hover:text-emphasis-hover hover:underline"
            href="https://github.com/GDKeller/gdkeller.github.io"
            target="_blank"
            rel="noopener noreferrer">View source</a
          ></span
        >
        <span class="mx-4">᠅</span>
        <span class="inline-block">© 0x7EA Grant Keller</span>
      </p>
    </div>
  </div>
</footer>
