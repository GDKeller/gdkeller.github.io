---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import gridTile from "../images/elements/grid-tile.webp";
import HeadingSection from "./HeadingSection.astro";

const entries = (await getCollection("current")).sort(
  (a, b) => (a.data.order ?? 99) - (b.data.order ?? 99),
);

const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/images/current/*.{webp,jpg,jpeg,png}",
);

const resolveImage = async (filename?: string) => {
  if (!filename) return null;
  const loader = images[`/src/images/current/${filename}`];
  return loader ? (await loader()).default : null;
};

const statusLabel = {
  live: "LIVE",
  beta: "BETA",
  "launching-soon": "LAUNCHING SOON",
} as const;

const items = await Promise.all(
  entries.map(async (entry) => ({
    entry,
    image: await resolveImage(entry.data.image),
  })),
);
---

<section class="relative overflow-hidden py-32" aria-labelledby="currently-building-label">
  <div
    class="border-emphasis/70 pointer-events-none absolute inset-0 border-b-2 bg-repeat opacity-10 mix-blend-screen blur-[0.02rem] contrast-50"
    style={`background-image: url(${gridTile.src}); background-size: 50vw auto;`}
  >
  </div>

  <div class="relative mx-auto max-w-7xl px-6 pt-16 pb-24 md:px-10 md:pt-20 md:pb-28">
    <div class="flex items-end">
      <HeadingSection
        text="Currently Building"
        as="h2"
        align="left"
        size="md"
        treatment="inverted"
        class="translate-y-1/2"
      />

      <div class="border-faint flex-1 border-b-2"></div>
      <div class="decorator-bar relative isolate pt-4 pr-8 pb-2 pl-4">
        <p
          class="text-faint text-2xs flex items-center font-mono leading-none font-extralight tracking-widest uppercase"
        >
          <span>Active Operations</span>
          <span class="text-subtle triplecolon mr-3 ml-2 font-light" aria-hidden="true">:::</span>
          <span>qty 5</span>
        </p>
      </div>
    </div>

    <div class="border-faint bg-background-dark border-2 border-t-0 pt-8" data-builds>
      <!-- Active viewer -->
      <div class="relative p-6 md:p-8">
        {
          items.map(({ entry, image }, idx) => {
            const { data } = entry;
            return (
              <div class:list={[idx > 0 && "hidden"]} data-panel={entry.slug}>
                <div class="flex flex-col gap-6 md:flex-row md:items-stretch md:gap-10">
                  <div class="callout-frame border-faint bg-background-dark relative aspect-video flex-1 border-0">
                    <span class="bracket tl" aria-hidden="true" />
                    <span class="bracket tr" aria-hidden="true" />
                    <span class="bracket bl" aria-hidden="true" />
                    <span class="bracket br" aria-hidden="true" />

                    {data.video ? (
                      <div class="relative z-110 flex h-full items-center p-2">
                        <video
                          autoplay
                          loop
                          muted
                          playsinline
                          class="laptop-rounded-top block h-full w-full object-cover object-top"
                          poster={image?.src}
                        >
                          <source src={`/video/${data.video}`} type="video/mp4" />
                        </video>
                      </div>
                    ) : image ? (
                      <Image
                        src={image}
                        alt={data.imageAlt ?? data.title}
                        class="relative z-110 h-full w-full object-cover object-top"
                        loading="lazy"
                        widths={[400, 800, 1200]}
                        sizes="(min-width: 768px) 55vw, 90vw"
                      />
                    ) : (
                      <div class="placeholder-cell flex h-full items-center justify-center">
                        <span class="text-foundation bg-background-dark px-16 py-8 font-mono text-sm tracking-widest uppercase">
                          {data.status ? statusLabel[data.status] : "IN PROGRESS"}
                        </span>
                      </div>
                    )}
                  </div>

                  <div class="flex flex-col justify-start pt-4 md:w-2/5">
                    <div class="mt-0 flex flex-col items-start">
                      <h3 class="text-accent font-prompt relative z-110 origin-bottom text-lg font-medium tracking-wider md:text-2xl">
                        {data.title}
                      </h3>
                      <div class="before:border-subtle relative mt-2 flex w-full justify-between pr-2 before:absolute before:top-0 before:left-0 before:h-0 before:w-full before:border-t before:bg-none before:content-['']">
                        {data.type && (
                          <span class="text-emphasis project__type relative z-110 mb-auto pr-8 pb-2 pl-4 font-mono text-xs leading-none tracking-widest">
                            {data.type}
                          </span>
                        )}
                        {data.tech && data.tech.length > 0 && (
                          <p class="text-emphasis relative z-110 py-2 font-mono text-xs font-extralight tracking-wide uppercase">
                            {data.tech.map((t: string, i: number) => (
                              <>
                                {i > 0 && <span class="text-accent"> / </span>}
                                {t}
                              </>
                            ))}
                          </p>
                        )}
                      </div>
                    </div>
                    <p class="text-foundation relative z-110 mt-8 max-w-[48ch] text-base leading-normal tracking-normal">
                      {data.description}
                    </p>
                    <div class="mt-auto mr-auto ml-0">
                      {data.url && (
                        <a
                          href={data.url}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="button-arrow border-highlight hover:bg-highlight text-highlight hover:text-background-dark mt-auto mb-0 flex items-center justify-self-end overflow-hidden border-b py-2 pr-8 pl-4 font-mono text-xs tracking-widest uppercase"
                        >
                          <span class="button-arrow__label relative z-110">View Site</span>
                        </a>
                      )}
                    </div>
                  </div>
                </div>
              </div>
            );
          })
        }
      </div>

      <!-- Thumbnail row -->
      <div
        class="border-faint grid grid-cols-2 gap-4 border-t-2 p-6 sm:grid-cols-3 md:grid-cols-5 md:p-8"
      >
        {
          items.map(({ entry, image }, idx) => {
            const { data } = entry;
            return (
              <button
                type="button"
                class:list={[
                  "thumb group relative flex cursor-pointer flex-col border transition-all duration-200",
                  idx === 0 && "is-active",
                ]}
                data-thumb={entry.slug}
                aria-label={`View ${data.title}`}
                aria-pressed={idx === 0 ? "true" : "false"}
              >
                {image ? (
                  <Image
                    src={image}
                    alt=""
                    class="block aspect-16/10 w-full object-cover"
                    loading="lazy"
                    widths={[200, 400]}
                    sizes="(min-width: 768px) 15vw, 40vw"
                  />
                ) : (
                  <div class="placeholder-cell flex aspect-16/10 flex-1 items-center justify-center">
                    <span class="text-foundation bg-background-dark text-2xs relative z-110 px-4 py-4 font-mono tracking-widest uppercase">
                      {data.title}
                    </span>
                  </div>
                )}
                <div class="thumb-title bg-emphasis group-hover:bg-accent m-0 mt-auto flex h-12 px-2 transition-colors duration-200">
                  <p class="text-background-dark text-2xs relative z-110 m-auto leading-none font-medium tracking-wide lg:text-xs">
                    {data.title}
                  </p>
                </div>
              </button>
            );
          })
        }
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  @reference "../styles/global.css";

  .button-arrow {
    position: relative;
    isolation: isolate;
    clip-path: polygon(0 0, 100% 0, 100% 50%, 100% 100%, 0 100%);
    transition:
      clip-path 340ms cubic-bezier(0.16, 1, 0.3, 1),
      background-color 200ms ease-out,
      color 200ms ease-out;

    &::before {
      content: "";
      position: absolute;
      inset: 0;
      z-index: 1;
      pointer-events: none;
      background: linear-gradient(
        110deg,
        transparent 5%,
        var(--color-highlight-hover),
        transparent 75%
      );
      transform: translate3d(-80%, 0, 0);
      mix-blend-mode: screen;
    }

    &__label {
      display: inline-block;
      transform-origin: left center;
    }

    &:hover {
      clip-path: polygon(0 0, calc(100% - 14px) 0, 100% 50%, calc(100% - 14px) 100%, 0 100%);
    }

    &:hover::before {
      animation: button-arrow-shine 900ms cubic-bezier(0.16, 1, 0.3, 1) 250ms forwards;
    }

    &:hover &__label {
      animation: button-arrow-label-skew 480ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }
  }

  @keyframes button-arrow-shine {
    from {
      transform: translate3d(-80%, 0, 0);
    }
    to {
      transform: translate3d(180%, 0, 0);
    }
  }

  @keyframes button-arrow-label-skew {
    0% {
      transform: skewX(0deg);
    }
    22% {
      transform: skewX(-8deg);
    }
    100% {
      transform: skewX(0deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .button-arrow {
      transition-duration: 0ms;
    }
    .button-arrow:hover::before,
    .button-arrow:hover .button-arrow__label {
      animation: none;
    }
  }

  .decorator-bar {
    position: relative;

    &::before {
      content: "";
      position: absolute;
      top: -2px;
      right: 0px;
      bottom: 0px;
      left: -2px;
      z-index: -2;
      background: var(--color-faint);
      clip-path: polygon(0 0, calc(100% - 1.5rem) 0, 100% 1.25rem, 100% 100%, 0 100%);
    }

    &::after {
      content: "";
      position: absolute;
      inset: 0;
      top: 0px;
      left: 0px;
      right: 2px;
      bottom: 0px;
      z-index: -1;
      background: var(--color-background-dark);
      clip-path: polygon(0 0, calc(100% - 2.25rem) 0, 100% 1.25rem, 100% 100%, 0 100%);
    }
  }

  .project {
    &__type {
      position: relative;
      isolation: isolate;

      &::before {
        content: "";
        position: absolute;
        top: 0;
        right: -1px;
        bottom: -1px;
        left: -1px;
        z-index: -2;
        background: var(--color-accent);
        clip-path: polygon(0 0, 100% 0, 100% calc(100% - 1.3rem), calc(100% - 1rem) 100%, 0 100%);
      }

      &::after {
        content: "";
        position: absolute;
        inset: 0;
        z-index: -1;
        background: var(--color-background-dark);
        clip-path: polygon(0 0, 100% 0, 100% calc(100% - 3rem), calc(100% - 1rem) 100%, 0 100%);
      }
    }
  }

  .thumb {
    @apply border-faint;

    &:hover {
      @apply border-accent;
      transform: translateY(-0.1rem);
    }

    &.is-active,
    &.is-active:hover {
      @apply border-accent;
    }

    &.is-active .thumb-title {
      @apply bg-accent;
    }
  }

  .bracket {
    position: absolute;
    opacity: 0.3;

    &::before,
    &::after {
      content: "";
      position: absolute;
      background-color: var(--color-emphasis);
    }

    &::before {
      width: 1px;
      height: 0.6rem;
    }

    &::after {
      width: 0.6rem;
      height: 1px;
    }

    &.tl {
      top: 0;
      left: 0;

      &::before {
        top: -0.6rem;
        left: -1px;
      }
      &::after {
        top: -1px;
        left: -0.6rem;
      }
    }

    &.tr {
      top: 0;
      right: 0;

      &::before {
        top: -0.6rem;
        right: -1px;
      }
      &::after {
        top: -1px;
        right: -0.6rem;
      }
    }

    &.bl {
      bottom: 0;
      left: 0;

      &::before {
        bottom: -0.6rem;
        left: -1px;
      }
      &::after {
        bottom: -1px;
        left: -0.6rem;
      }
    }

    &.br {
      bottom: 0;
      right: 0;

      &::before {
        bottom: -0.6rem;
        right: -1px;
      }
      &::after {
        bottom: -1px;
        right: -0.6rem;
      }
    }
  }

  .placeholder-cell {
    background: repeating-linear-gradient(
      45deg,
      transparent 0px,
      transparent 1rem,
      var(--color-faint) 1rem,
      var(--color-faint) 1.1rem
    );
  }

  @media (prefers-reduced-motion: reduce) {
    .thumb {
      transition: border-color 0.3s;
    }
    .thumb:hover,
    .thumb:nth-child(even):hover {
      transform: none;
    }
  }
</style>

<script>
  function initCurrentlyBuilding() {
    const root = document.querySelector<HTMLElement>("[data-builds]");
    if (!root) return;

    const panels = root.querySelectorAll<HTMLElement>("[data-panel]");
    const thumbs = root.querySelectorAll<HTMLButtonElement>("[data-thumb]");

    const setActive = (slug: string) => {
      panels.forEach((p) => p.classList.toggle("hidden", p.dataset.panel !== slug));
      thumbs.forEach((t) => {
        const active = t.dataset.thumb === slug;
        t.classList.toggle("is-active", active);
        t.setAttribute("aria-pressed", String(active));
      });
    };

    thumbs.forEach((thumb) => {
      thumb.addEventListener("click", () => {
        const slug = thumb.dataset.thumb;
        if (slug) setActive(slug);
      });
    });
  }

  document.addEventListener("DOMContentLoaded", initCurrentlyBuilding);
  document.addEventListener("astro:page-load", initCurrentlyBuilding);
</script>
