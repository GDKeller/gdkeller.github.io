---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import gridTile from "../images/ui/grid-tile.webp";

const entries = (await getCollection("current")).sort(
  (a, b) => (a.data.order ?? 99) - (b.data.order ?? 99),
);

const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/images/current/*.{webp,jpg,jpeg,png}",
);

const resolveImage = (filename?: string) => {
  if (!filename) return null;
  const key = `/src/images/current/${filename}`;
  return images[key] ?? null;
};

const statusLabel = {
  live: "LIVE",
  beta: "BETA",
  "launching-soon": "LAUNCHING SOON",
} as const;

const rotations = [
  "-rotate-[3.5deg]",
  "rotate-[2.8deg]",
  "-rotate-[2.2deg]",
  "rotate-[4deg]",
  "-rotate-[3deg]",
];

const itemsWithVisual = await Promise.all(
  entries.map(async (entry, idx) => {
    const loader = resolveImage(entry.data.image);
    const resolvedImage = loader ? (await loader()).default : null;
    return {
      entry,
      resolvedImage,
      rotation: rotations[idx] ?? "",
      refNum: `01.${String(idx + 1).padStart(2, "0")}`,
    };
  }),
);
---

<section
  class="currently-building relative isolate z-0 overflow-hidden"
  aria-labelledby="currently-building-label"
>
  <div
    class="substrate pointer-events-none absolute inset-0 z-0"
    style={`background-image: url(${gridTile.src})`}
  >
  </div>

  <div class="relative z-20 mx-auto max-w-7xl px-6 pt-16 pb-24 md:px-10 md:pt-20 md:pb-28">
    <header class="inscription mb-12 md:mb-16">
      <div class="inscription-rule" aria-hidden="true"></div>
      <p
        class="text-foundation/50 mb-1.5 font-mono text-[0.7rem] font-medium tracking-[0.22em] uppercase md:text-[0.75rem]"
      >
        <span>PLATE&nbsp;01</span>
        <span class="mx-2.5 opacity-40" aria-hidden="true">/</span>
        <span>ACTIVE&nbsp;WORK</span>
        <span class="mx-2.5 opacity-40" aria-hidden="true">/</span>
        <span>SHEET&nbsp;01&nbsp;OF&nbsp;08</span>
      </p>
      <h2
        id="currently-building-label"
        class="font-bokor text-emphasis text-5xl leading-[0.95] md:text-6xl lg:text-7xl"
      >
        Currently Building
      </h2>
    </header>

    <ul
      class="workbench relative grid grid-cols-1 gap-y-16 md:grid-cols-12 md:gap-x-10 md:gap-y-14"
    >
      {
        itemsWithVisual.map(({ entry, resolvedImage, rotation, refNum }) => {
          const { data } = entry;
          const isFocal = data.focal === true;
          const isPlaceholder = !resolvedImage;
          const status = data.status;
          const brand = data.brand;

          return (
            <li
              class:list={[
                "workbench-item group relative",
                rotation,
                isFocal ? "md:col-span-6 md:row-span-2" : "md:col-span-3",
              ]}
            >
              <a
                href={data.url}
                target="_blank"
                rel="noopener noreferrer"
                class="block h-full w-full no-underline"
                aria-label={`${data.title} — ${data.description}`}
              >
                <div class="callout-frame relative">
                  <span class="bracket tl" aria-hidden="true" />
                  <span class="bracket tr" aria-hidden="true" />
                  <span class="bracket bl" aria-hidden="true" />
                  <span class="bracket br" aria-hidden="true" />

                  <span class="ref-num font-mono">{refNum}</span>

                  {brand === "davant" && <span class="brand-label font-mono">DAVANT</span>}

                  {resolvedImage ? (
                    <Image
                      src={resolvedImage}
                      alt={data.imageAlt ?? data.title}
                      class="block w-full"
                      loading="lazy"
                      widths={[400, 800, 1200]}
                      sizes={
                        isFocal
                          ? "(min-width: 1024px) 50vw, 90vw"
                          : "(min-width: 1024px) 25vw, (min-width: 768px) 33vw, 90vw"
                      }
                    />
                  ) : (
                    <div class="placeholder-cell" aria-hidden="true">
                      <span class="text-foundation/45 font-mono text-[0.65rem] tracking-[0.3em] uppercase">
                        {status ? statusLabel[status] : "IN PROGRESS"}
                      </span>
                    </div>
                  )}
                </div>

                <div class="entry-meta mt-3">
                  <div class="meta-header flex items-baseline gap-3">
                    <h3 class="font-bayon text-emphasis text-xl leading-tight md:text-2xl">
                      {data.title}
                    </h3>
                    {status && (
                      <span class="text-foundation/45 font-mono text-[0.6rem] tracking-[0.18em] uppercase">
                        {statusLabel[status]}
                      </span>
                    )}
                  </div>
                  <p class="text-foundation/70 mt-1 text-sm leading-relaxed">{data.description}</p>
                  {data.tech && data.tech.length > 0 && (
                    <p class="text-foundation/50 mt-2 font-mono text-[0.65rem] tracking-[0.12em] uppercase">
                      {data.tech.join(" / ")}
                    </p>
                  )}
                </div>
              </a>
            </li>
          );
        })
      }
    </ul>
  </div>
</section>

<style>
  .currently-building {
    background: var(--color-background);
  }

  .substrate {
    background-size: 50vw auto;
    background-repeat: repeat;
    opacity: 0.15;
  }

  .inscription-rule {
    height: 1px;
    width: 5rem;
    background: rgba(255, 255, 255, 0.2);
    margin-bottom: 0.75rem;
  }

  @media (min-width: 768px) {
    .inscription-rule {
      width: 7rem;
    }
  }

  /* --- Workbench items --- */

  .workbench-item {
    transform-origin: center center;
    transition:
      transform 0.3s cubic-bezier(0.22, 1, 0.36, 1),
      rotate 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .workbench-item:hover {
    transform: translateY(-3px);
    rotate: 0deg;
  }

  /* --- Callout frame (diagram box) --- */

  .callout-frame {
    position: relative;
    border: 1px solid rgba(255, 255, 255, 0.1);
    transition: border-color 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .workbench-item:hover .callout-frame {
    border-color: rgba(16, 185, 129, 0.3);
  }

  .bracket {
    position: absolute;
    width: 10px;
    height: 10px;
    border-color: rgba(255, 255, 255, 0.25);
    border-style: solid;
    z-index: 2;
    transition: border-color 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .workbench-item:hover .bracket {
    border-color: rgba(16, 185, 129, 0.5);
  }

  .bracket.tl {
    top: -1px;
    left: -1px;
    border-width: 1px 0 0 1px;
  }
  .bracket.tr {
    top: -1px;
    right: -1px;
    border-width: 1px 1px 0 0;
  }
  .bracket.bl {
    bottom: -1px;
    left: -1px;
    border-width: 0 0 1px 1px;
  }
  .bracket.br {
    bottom: -1px;
    right: -1px;
    border-width: 0 1px 1px 0;
  }

  .ref-num {
    position: absolute;
    top: 0.5rem;
    left: 0.6rem;
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    color: rgba(255, 255, 255, 0.3);
    z-index: 2;
  }

  .brand-label {
    position: absolute;
    top: 0.5rem;
    right: 0.6rem;
    font-size: 0.55rem;
    font-weight: 500;
    letter-spacing: 0.25em;
    color: rgba(255, 255, 255, 0.2);
    z-index: 2;
  }

  /* --- Placeholder (Davant Studio v2) --- */

  .placeholder-cell {
    aspect-ratio: 16 / 10;
    display: flex;
    align-items: center;
    justify-content: center;
    background: repeating-linear-gradient(
      45deg,
      transparent 0px,
      transparent 14px,
      rgba(255, 255, 255, 0.02) 14px,
      rgba(255, 255, 255, 0.02) 15px
    );
  }

  /* --- Mobile: flatten rotations --- */

  @media (max-width: 767px) {
    .workbench-item {
      rotate: 0deg !important;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .workbench-item {
      transition: none;
    }
    .workbench-item:hover {
      transform: none;
      rotate: inherit;
    }
    .callout-frame,
    .bracket {
      transition: none;
    }
  }
</style>
