---
import { getCollection } from "astro:content";
import { Picture, getImage } from "astro:assets";
import type { ImageMetadata } from "astro";
import gridTile from "../images/elements/grid-tile.webp";
import HeadingSection from "./HeadingSection.astro";

const entries = (await getCollection("current")).sort(
  (a, b) => (a.data.order ?? 99) - (b.data.order ?? 99),
);

const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/images/current/*.{webp,jpg,jpeg,png}",
);

const resolveImage = async (filename?: string) => {
  if (!filename) return null;
  const loader = images[`/src/images/current/${filename}`];
  return loader ? (await loader()).default : null;
};

const statusLabel = {
  live: "LIVE",
  beta: "BETA",
  "launching-soon": "LAUNCHING SOON",
} as const;

const items = await Promise.all(
  entries.map(async (entry) => ({
    entry,
    image: await resolveImage(entry.data.image),
    videoBase: entry.data.video?.replace(/\.[^/.]+$/, "") ?? null,
  })),
);

// Pre-generate AVIF + WebP variants for the tile background so browsers can
// negotiate format via CSS image-set(). Width 1200 covers the largest tile
// (50vw on a 2400px viewport).
const gridTileAvif = await getImage({
  src: gridTile,
  format: "avif",
  width: 1200,
});
const gridTileWebp = await getImage({
  src: gridTile,
  format: "webp",
  width: 1200,
});
const gridTileBg = `image-set(url("${gridTileAvif.src}") type("image/avif"), url("${gridTileWebp.src}") type("image/webp"))`;
---

<section
  class="relative overflow-hidden py-32"
  id="building"
  aria-labelledby="currently-building-label"
>
  <div
    class="border-emphasis/70 pointer-events-none absolute inset-0 border-b-2
      bg-repeat opacity-10 mix-blend-screen blur-[0.02rem] contrast-50"
    style={`background-image: ${gridTileBg}; background-size: 50vw auto;`}
  >
  </div>

  <div
    class="relative mx-auto max-w-7xl px-2 pt-16 pb-24 sm:px-4 md:px-8 md:pt-20
      md:pb-28"
  >
    <div class="flex items-end">
      <HeadingSection
        text="Currently Building"
        as="h2"
        align="left"
        size="md"
        treatment="inverted"
        class="translate-y-1/2"
      />

      <div class="border-faint flex-1 border-b-2"></div>
      <div
        class="decorator-bar relative isolate hidden pt-4 pr-8 pb-2 pl-4
          md:block"
      >
        <p
          class="text-faint text-2xs flex items-center font-mono leading-none
            font-extralight tracking-widest uppercase"
        >
          <span>Active Operations</span>
          <span
            class="text-accent-subtle triplecolon mr-3 ml-2 hidden font-light
              lg:block"
            aria-hidden="true">:::</span
          >
          <span class="hidden lg:block">qty 5</span>
        </p>
      </div>
    </div>

    <div
      class="border-faint bg-background-dark border-2 border-t-0 pt-8"
      data-builds
    >
      <!-- Active viewer -->
      <div class="relative p-2 md:p-8">
        {
          items.map(({ entry, image, videoBase }, idx) => {
            const { data } = entry;
            return (
              <div class:list={[idx > 0 && "hidden"]} data-panel={entry.id}>
                <div
                  class="flex flex-col md:flex-row md:items-stretch md:gap-8
                    lg:gap-10"
                >
                  <div
                    class="callout-frame border-faint bg-background-dark
                      relative aspect-video flex-1 border-0"
                  >
                    <span class="bracket tl" aria-hidden="true" />
                    <span class="bracket tr" aria-hidden="true" />
                    <span class="bracket bl" aria-hidden="true" />
                    <span class="bracket br" aria-hidden="true" />

                    {videoBase ? (
                      <div class="relative z-110 flex h-full items-center p-2">
                        <video
                          autoplay
                          loop
                          muted
                          playsinline
                          preload="none"
                          data-lazy-video
                          class="laptop-rounded-top block h-full w-full
                            object-cover object-top"
                          poster={image?.src}
                        >
                          <source
                            type="video/webm"
                            data-src-sm={`/video/${videoBase}-640.webm`}
                            data-src-lg={`/video/${videoBase}-1280.webm`}
                          />
                          <source
                            type="video/mp4"
                            data-src-sm={`/video/${videoBase}-640.mp4`}
                            data-src-lg={`/video/${videoBase}-1280.mp4`}
                          />
                        </video>
                      </div>
                    ) : image ? (
                      <Picture
                        src={image}
                        alt={data.imageAlt ?? data.title}
                        widths={[400, 800, 1200, 1400, 2400]}
                        sizes="(min-width: 768px) 55vw, 90vw"
                        quality={75}
                        formats={["avif", "webp"]}
                        fallbackFormat="jpg"
                        loading="lazy"
                        class="relative z-110 h-full w-full object-cover
                          object-top"
                      />
                    ) : (
                      <div
                        class="placeholder-cell flex h-full items-center
                          justify-center"
                      >
                        <span
                          class="text-foundation bg-background-dark px-16 py-8
                            font-mono text-sm tracking-widest uppercase"
                        >
                          {data.status
                            ? statusLabel[data.status]
                            : "IN PROGRESS"}
                        </span>
                      </div>
                    )}
                  </div>

                  <div
                    class="flex flex-col justify-start px-4 pt-4 pb-4 md:w-2/5
                      md:px-0 md:pb-0"
                  >
                    <div class="mt-0 flex flex-col items-start">
                      <h3
                        class="text-accent font-display relative z-110
                          origin-bottom text-lg font-medium tracking-wider
                          md:text-base lg:text-xl xl:text-2xl"
                      >
                        {data.title}
                      </h3>
                      <div
                        class="before:border-accent-subtle relative mt-2 flex
                          w-full justify-between pr-2 before:absolute
                          before:top-0 before:left-0 before:h-0 before:w-full
                          before:border-t before:bg-none before:content-['']"
                      >
                        {data.type && (
                          <span
                            class="text-emphasis project__type text-2xs relative
                              z-110 mb-auto pt-1 pr-2 pb-2 pl-2 font-mono
                              leading-none tracking-widest lg:pr-8 lg:pl-4
                              lg:text-xs"
                          >
                            {data.type}
                          </span>
                        )}
                        {data.tech && data.tech.length > 0 && (
                          <p
                            class="text-2xs text-emphasis relative z-110 py-2
                              font-mono font-extralight tracking-wide uppercase
                              lg:text-xs"
                          >
                            {data.tech.map((t: string, i: number) => (
                              <>
                                {i > 0 && <span class="text-accent"> / </span>}
                                {t}
                              </>
                            ))}
                          </p>
                        )}
                      </div>
                    </div>
                    <p
                      class="text-foundation relative z-110 mt-8 mb-8
                        max-w-[48ch] text-base leading-normal tracking-normal
                        md:mb-8"
                    >
                      {data.description}
                    </p>
                    <div class="mt-auto ml-auto">
                      {data.url && (
                        <a
                          href={data.url}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="button-arrow border-highlight
                            hover:bg-highlight text-highlight
                            hover:text-background-dark mt-auto mb-0 flex
                            items-center justify-self-end overflow-hidden
                            border-b py-2 pr-8 pl-4 font-mono text-xs
                            tracking-widest uppercase"
                        >
                          <span class="button-arrow__label relative z-110">
                            View Site
                          </span>
                        </a>
                      )}
                    </div>
                  </div>
                </div>
              </div>
            );
          })
        }
      </div>

      <!-- Thumbnail row -->
      <div
        class="border-faint grid gap-1 border-t-2 p-4 sm:grid-cols-3 sm:gap-2
          md:grid-cols-5 lg:gap-4 lg:p-8"
      >
        {
          items.map(({ entry, image }, idx) => {
            const { data } = entry;
            return (
              <button
                type="button"
                class:list={[
                  `thumb group relative flex cursor-pointer border
                  transition-all duration-200 sm:flex-col`,
                  idx === 0 && "is-active",
                ]}
                data-thumb={entry.id}
                aria-label={`View ${data.title}`}
                aria-pressed={idx === 0 ? "true" : "false"}
              >
                {image ? (
                  <Picture
                    src={image}
                    alt=""
                    widths={[200, 400]}
                    sizes="(min-width: 768px) 15vw, 40vw"
                    formats={["avif", "webp"]}
                    fallbackFormat="jpg"
                    loading="lazy"
                    class="block w-1/3 origin-top object-cover max-sm:h-12
                      sm:m-0 sm:aspect-16/10 sm:h-auto sm:w-full
                      sm:object-center"
                  />
                ) : (
                  <div
                    class="placeholder-cell flex aspect-16/10 h-12 w-1/3 flex-1
                      items-center justify-center overflow-hidden sm:h-auto
                      sm:w-full"
                  >
                    <span
                      class="text-foundation bg-background-dark text-2xs
                        relative z-110 p-1 font-mono tracking-widest uppercase
                        sm:px-4 sm:py-4"
                    >
                      {data.title}
                    </span>
                  </div>
                )}
                <div
                  class="thumb-title bg-emphasis group-hover:bg-accent m-0 flex
                    h-full w-2/3 px-2 transition-colors duration-200 sm:h-12
                    sm:w-full"
                >
                  <p
                    class="text-background-dark text-2xs relative z-110 m-auto
                      leading-none font-medium tracking-wide lg:text-xs"
                  >
                    {data.title}
                  </p>
                </div>
              </button>
            );
          })
        }
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  @reference "../styles/main.css";

  .button-arrow {
    position: relative;
    isolation: isolate;
    clip-path: polygon(0 0, 100% 0, 100% 50%, 100% 100%, 0 100%);
    transition:
      clip-path 340ms cubic-bezier(0.16, 1, 0.3, 1),
      background-color 200ms ease-out,
      color 200ms ease-out;

    &::before {
      content: "";
      position: absolute;
      inset: 0;
      z-index: 1;
      pointer-events: none;
      background: linear-gradient(
        110deg,
        transparent 5%,
        var(--color-highlight-hover),
        transparent 75%
      );
      transform: translate3d(-80%, 0, 0);
      mix-blend-mode: screen;
    }

    &__label {
      display: inline-block;
      transform-origin: left center;
    }

    &:hover {
      clip-path: polygon(
        0 0,
        calc(100% - 14px) 0,
        100% 50%,
        calc(100% - 14px) 100%,
        0 100%
      );
    }

    &:hover::before {
      animation: button-arrow-shine 900ms cubic-bezier(0.16, 1, 0.3, 1) 250ms
        forwards;
    }

    &:hover &__label {
      animation: button-arrow-label-skew 480ms cubic-bezier(0.22, 1, 0.36, 1)
        forwards;
    }
  }

  @keyframes button-arrow-shine {
    from {
      transform: translate3d(-80%, 0, 0);
    }
    to {
      transform: translate3d(180%, 0, 0);
    }
  }

  @keyframes button-arrow-label-skew {
    0% {
      transform: skewX(0deg);
    }
    22% {
      transform: skewX(-8deg);
    }
    100% {
      transform: skewX(0deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .button-arrow {
      transition-duration: 0ms;
    }
    .button-arrow:hover::before,
    .button-arrow:hover .button-arrow__label {
      animation: none;
    }
  }

  .decorator-bar {
    position: relative;

    &::before {
      content: "";
      position: absolute;
      top: -2px;
      right: 0px;
      bottom: 0px;
      left: -2px;
      z-index: -2;
      background: var(--color-faint);
      clip-path: polygon(
        0 0,
        calc(100% - 1.5rem) 0,
        100% 1.25rem,
        100% 100%,
        0 100%
      );
    }

    &::after {
      content: "";
      position: absolute;
      inset: 0;
      top: 0px;
      left: 0px;
      right: 2px;
      bottom: 0px;
      z-index: -1;
      background: var(--color-background-dark);
      clip-path: polygon(
        0 0,
        calc(100% - 2.25rem) 0,
        100% 1.25rem,
        100% 100%,
        0 100%
      );
    }
  }

  .project {
    &__type {
      position: relative;
      isolation: isolate;

      &::before {
        content: "";
        position: absolute;
        top: 0;
        right: -1px;
        bottom: -1px;
        left: -1px;
        z-index: -2;
        background: var(--color-accent);

        @media (min-width: 1024px) {
          clip-path: polygon(
            0 0,
            100% 0,
            100% calc(100% - 1.3rem),
            calc(100% - 1rem) 100%,
            0 100%
          );
        }
      }

      &::after {
        content: "";
        position: absolute;
        inset: 0;
        z-index: -1;
        background: var(--color-background-dark);

        @media (min-width: 1024px) {
          clip-path: polygon(
            0 0,
            100% 0,
            100% calc(100% - 3rem),
            calc(100% - 1rem) 100%,
            0 100%
          );
        }
      }
    }
  }

  .thumb {
    @apply border-faint;

    &:hover {
      @apply border-accent;
      transform: translateY(-0.1rem);
    }

    &.is-active,
    &.is-active:hover {
      @apply border-accent;
    }

    &.is-active .thumb-title {
      @apply bg-accent;
    }
  }

  .bracket {
    @apply absolute hidden opacity-30 md:block;

    &::before,
    &::after {
      content: "";
      @apply bg-emphasis absolute;
    }

    &::before {
      width: 1px;
      height: 0.6rem;
    }

    &::after {
      width: 0.6rem;
      height: 1px;
    }

    &.tl {
      top: 0;
      left: 0;

      &::before {
        top: -0.6rem;
        left: -1px;
      }
      &::after {
        top: -1px;
        left: -0.6rem;
      }
    }

    &.tr {
      top: 0;
      right: 0;

      &::before {
        top: -0.6rem;
        right: -1px;
      }
      &::after {
        top: -1px;
        right: -0.6rem;
      }
    }

    &.bl {
      bottom: 0;
      left: 0;

      &::before {
        bottom: -0.6rem;
        left: -1px;
      }
      &::after {
        bottom: -1px;
        left: -0.6rem;
      }
    }

    &.br {
      bottom: 0;
      right: 0;

      &::before {
        bottom: -0.6rem;
        right: -1px;
      }
      &::after {
        bottom: -1px;
        right: -0.6rem;
      }
    }
  }

  .placeholder-cell {
    background: repeating-linear-gradient(
      45deg,
      transparent 0px,
      transparent 1rem,
      var(--color-faint) 1rem,
      var(--color-faint) 1.1rem
    );
  }

  @media (prefers-reduced-motion: reduce) {
    .thumb {
      transition: border-color 0.3s;
    }
    .thumb:hover,
    .thumb:nth-child(even):hover {
      transform: none;
    }
  }
</style>

<script>
  function initCurrentlyBuilding() {
    const root = document.querySelector<HTMLElement>("[data-builds]");
    if (!root) return;

    const panels = root.querySelectorAll<HTMLElement>("[data-panel]");
    const thumbs = root.querySelectorAll<HTMLButtonElement>("[data-thumb]");

    const setActive = (slug: string) => {
      panels.forEach((p) =>
        p.classList.toggle("hidden", p.dataset.panel !== slug),
      );
      thumbs.forEach((t) => {
        const active = t.dataset.thumb === slug;
        t.classList.toggle("is-active", active);
        t.setAttribute("aria-pressed", String(active));
      });
    };

    thumbs.forEach((thumb) => {
      thumb.addEventListener("click", () => {
        const slug = thumb.dataset.thumb;
        if (slug) setActive(slug);
      });
    });

    const hydrateVideo = (video: HTMLVideoElement) => {
      const sources = video.querySelectorAll<HTMLSourceElement>(
        "source[data-src-lg]",
      );
      if (!sources.length) return;
      const isSmall = window.matchMedia("(max-width: 767px)").matches;
      let changed = false;
      sources.forEach((source) => {
        if (source.src) return;
        const next = isSmall ? source.dataset.srcSm : source.dataset.srcLg;
        if (!next) return;
        source.src = next;
        source.removeAttribute("data-src-sm");
        source.removeAttribute("data-src-lg");
        changed = true;
      });
      if (changed) video.load();
    };

    const videos = root.querySelectorAll<HTMLVideoElement>(
      "video[data-lazy-video]",
    );
    if (!videos.length) return;

    if (typeof IntersectionObserver === "undefined") {
      videos.forEach(hydrateVideo);
      return;
    }

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          hydrateVideo(entry.target as HTMLVideoElement);
          io.unobserve(entry.target);
        });
      },
      { rootMargin: "200px" },
    );
    videos.forEach((v) => io.observe(v));
  }

  document.addEventListener("DOMContentLoaded", initCurrentlyBuilding);
  document.addEventListener("astro:page-load", initCurrentlyBuilding);
</script>
