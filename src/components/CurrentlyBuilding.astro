---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import gridTile from "../images/ui/grid-tile.webp";
import EmbossedText from "./EmbossedText.astro";

const entries = (await getCollection("current")).sort(
  (a, b) => (a.data.order ?? 99) - (b.data.order ?? 99),
);

const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/images/current/*.{webp,jpg,jpeg,png}",
);

const resolveImage = (filename?: string) => {
  if (!filename) return null;
  const key = `/src/images/current/${filename}`;
  return images[key] ?? null;
};

const statusLabel = {
  live: "LIVE",
  beta: "BETA",
  "launching-soon": "LAUNCHING SOON",
} as const;

const itemsWithVisual = await Promise.all(
  entries.map(async (entry, idx) => {
    const loader = resolveImage(entry.data.image);
    const resolvedImage = loader ? (await loader()).default : null;
    return {
      entry,
      resolvedImage,
      refNum: `01.${String(idx + 1).padStart(2, "0")}`,
    };
  }),
);

const activeItem = itemsWithVisual[0];
const thumbItems = itemsWithVisual.slice(1);
---

<section
  class="bg-background relative isolate z-0 overflow-hidden"
  aria-labelledby="currently-building-label"
>
  <div
    class="pointer-events-none absolute inset-0 z-0 bg-repeat opacity-15"
    style={`background-image: url(${gridTile.src}); background-size: 50vw auto;`}
  >
  </div>

  <div class="relative z-20 mx-auto max-w-7xl px-6 pt-16 pb-24 md:px-10 md:pt-20 md:pb-28">
    <header class="mb-12 md:mb-16">
      <h2
        id="currently-building-label"
        class="font-bokor text-emphasis text-5xl md:text-6xl lg:text-4xl"
      >
        Currently Building
      </h2>
    </header>
    <div class="flex items-end">
      <div
        class="border-faint/80 rounded-tl-lg rounded-tr-lg border-t border-r border-l bg-black pt-4 pr-6 pl-2"
      >
        <EmbossedText text="Operations" height={20} />
      </div>
      <div class="border-faint/80 flex-1 border-b"></div>
      <div class="border-faint/80 border-b">
        <p
          class="text-subtle text-body-2xs pr-2 pb-2 font-mono font-medium tracking-widest uppercase"
        >
          <span>Plate&nbsp;01</span>
          <span class="mx-1" aria-hidden="true">::</span>
          <span>Active&nbsp;Work</span>
          <span class="mx-1" aria-hidden="true">::</span>
          <span>Sheet&nbsp;01&nbsp;OF&nbsp;08</span>
        </p>
      </div>
    </div>

    <div class="border-faint/80 border-x border-b bg-black" data-cb-root>
      <!-- Active viewer -->
      <div class="p-6 md:p-8" data-cb-viewer>
        {
          itemsWithVisual.map(({ entry, resolvedImage }, idx) => {
            const { data } = entry;
            return (
              <div class:list={["cb-viewer-panel", idx > 0 && "hidden"]} data-cb-panel={entry.slug}>
                <div class="flex flex-col gap-6 md:flex-row md:gap-10">
                  <div class="callout-frame relative aspect-video flex-1 overflow-hidden border border-white/10 bg-black">
                    <span class="bracket tl" aria-hidden="true" />
                    <span class="bracket tr" aria-hidden="true" />
                    <span class="bracket bl" aria-hidden="true" />
                    <span class="bracket br" aria-hidden="true" />

                    {data.video ? (
                      <div class="flex h-full items-center p-2">
                        <video
                          autoplay
                          loop
                          muted
                          playsinline
                          class="block h-full w-full rounded-t-[3%] object-cover object-top"
                          poster={resolvedImage?.src}
                        >
                          <source src={`/video/${data.video}`} type="video/mp4" />
                        </video>
                      </div>
                    ) : resolvedImage ? (
                      <Image
                        src={resolvedImage}
                        alt={data.imageAlt ?? data.title}
                        class="h-full w-full object-cover object-top"
                        loading="lazy"
                        widths={[400, 800, 1200]}
                        sizes="(min-width: 768px) 55vw, 90vw"
                      />
                    ) : (
                      <div class="placeholder-cell flex h-full items-center justify-center">
                        <span class="text-foundation text-body-xs font-mono tracking-widest uppercase">
                          {data.status ? statusLabel[data.status] : "IN PROGRESS"}
                        </span>
                      </div>
                    )}
                  </div>

                  <div class="flex flex-col justify-center md:w-2/5">
                    <div class="flex items-baseline justify-between gap-3">
                      <h3 class="font-bayon text-emphasis text-2xl md:text-3xl">{data.title}</h3>
                      {data.type && (
                        <span class="text-accent text-body-2xs font-mono tracking-widest uppercase">
                          {data.type}
                        </span>
                      )}
                    </div>
                    <p class="text-foundation text-body-sm mt-3 max-w-[48ch]">{data.description}</p>
                    {data.tech && data.tech.length > 0 && (
                      <p class="text-emphasis text-body-2xs mt-4 font-mono font-light tracking-wider uppercase">
                        {data.tech.join(" / ")}
                      </p>
                    )}
                    {data.url && (
                      <a
                        href={data.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-accent text-body-xs mt-6 inline-block font-mono tracking-wider uppercase transition-colors hover:text-emerald-300"
                      >
                        View Project &rarr;
                      </a>
                    )}
                  </div>
                </div>
              </div>
            );
          })
        }
      </div>

      <!-- Thumbnail row -->
      <div
        class="border-faint/80 grid grid-cols-2 gap-4 border-t p-6 sm:grid-cols-3 md:grid-cols-5 md:p-8"
        data-cb-thumbs
      >
        {
          itemsWithVisual.map(({ entry, resolvedImage }, idx) => {
            const { data } = entry;
            return (
              <button
                type="button"
                class:list={[
                  "cb-thumb group relative cursor-pointer border bg-black transition-all",
                  idx === 0 ? "border-emerald-500/50" : "border-white/10 hover:border-white/25",
                ]}
                data-cb-thumb={entry.slug}
                aria-label={`View ${data.title}`}
                aria-pressed={idx === 0 ? "true" : "false"}
              >
                {resolvedImage ? (
                  <Image
                    src={resolvedImage}
                    alt=""
                    class="block w-full"
                    loading="lazy"
                    widths={[200, 400]}
                    sizes="(min-width: 768px) 15vw, 40vw"
                  />
                ) : (
                  <div class="placeholder-cell flex aspect-[16/10] items-center justify-center">
                    <span class="text-foundation text-body-2xs font-mono tracking-widest uppercase">
                      {data.title}
                    </span>
                  </div>
                )}
                <div class="p-2">
                  <p class="text-emphasis text-body-2xs font-mono tracking-wider">{data.title}</p>
                </div>
              </button>
            );
          })
        }
      </div>
    </div>
  </div>
</section>

<style>
  .cb-thumb {
    transition:
      transform 0.3s cubic-bezier(0.22, 1, 0.36, 1),
      border-color 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .cb-thumb:hover {
    transform: rotate(1.5deg) translateY(-2px);
  }
  .cb-thumb:nth-child(even):hover {
    transform: rotate(-1.5deg) translateY(-2px);
  }

  .bracket {
    position: absolute;
    width: 10px;
    height: 10px;
    border-color: rgba(255, 255, 255, 0.25);
    border-style: solid;
    z-index: 2;
  }
  .bracket.tl {
    top: -1px;
    left: -1px;
    border-width: 1px 0 0 1px;
  }
  .bracket.tr {
    top: -1px;
    right: -1px;
    border-width: 1px 1px 0 0;
  }
  .bracket.bl {
    bottom: -1px;
    left: -1px;
    border-width: 0 0 1px 1px;
  }
  .bracket.br {
    bottom: -1px;
    right: -1px;
    border-width: 0 1px 1px 0;
  }

  .placeholder-cell {
    background: repeating-linear-gradient(
      45deg,
      transparent 0px,
      transparent 14px,
      rgba(255, 255, 255, 0.02) 14px,
      rgba(255, 255, 255, 0.02) 15px
    );
  }

  @media (prefers-reduced-motion: reduce) {
    .cb-thumb {
      transition: border-color 0.3s;
    }
    .cb-thumb:hover,
    .cb-thumb:nth-child(even):hover {
      transform: none;
    }
  }
</style>

<script>
  function initCurrentlyBuilding() {
    const root = document.querySelector("[data-cb-root]");
    if (!root) return;

    const panels = root.querySelectorAll<HTMLElement>("[data-cb-panel]");
    const thumbs = root.querySelectorAll<HTMLButtonElement>("[data-cb-thumb]");
    let activeSlug = panels[0]?.dataset.cbPanel;

    thumbs.forEach((thumb) => {
      thumb.addEventListener("click", () => {
        const slug = thumb.dataset.cbThumb;
        if (!slug || slug === activeSlug) return;

        const currentPanel = root.querySelector<HTMLElement>(`[data-cb-panel="${activeSlug}"]`);
        const nextPanel = root.querySelector<HTMLElement>(`[data-cb-panel="${slug}"]`);
        if (!currentPanel || !nextPanel) return;

        currentPanel.classList.add("hidden");
        nextPanel.classList.remove("hidden");

        thumbs.forEach((t) => {
          const isActive = t.dataset.cbThumb === slug;
          t.classList.toggle("border-emerald-500/50", isActive);
          t.classList.toggle("border-white/10", !isActive);
          t.setAttribute("aria-pressed", String(isActive));
        });

        activeSlug = slug;
      });
    });
  }

  document.addEventListener("DOMContentLoaded", initCurrentlyBuilding);
  document.addEventListener("astro:page-load", initCurrentlyBuilding);
</script>
