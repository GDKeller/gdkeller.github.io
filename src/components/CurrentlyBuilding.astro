---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import gridTile from "../images/ui/grid-tile.webp";

const entries = (await getCollection("current")).sort(
  (a, b) => (a.data.order ?? 99) - (b.data.order ?? 99),
);

const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/images/current/*.{webp,jpg,jpeg,png}",
);

const resolveImage = (filename?: string) => {
  if (!filename) return null;
  const key = `/src/images/current/${filename}`;
  return images[key] ?? null;
};

const statusLabel = {
  live: "LIVE",
  beta: "BETA",
  "launching-soon": "LAUNCHING SOON",
} as const;

const itemsWithVisual = await Promise.all(
  entries.map(async (entry, idx) => {
    const loader = resolveImage(entry.data.image);
    const resolvedImage = loader ? (await loader()).default : null;
    return {
      entry,
      resolvedImage,
      refNum: `01.${String(idx + 1).padStart(2, "0")}`,
    };
  }),
);

const activeItem = itemsWithVisual[0];
const thumbItems = itemsWithVisual.slice(1);
---

<section
  class="bg-background relative isolate z-0 overflow-hidden py-32"
  aria-labelledby="currently-building-label"
>
  <div
    class="pointer-events-none absolute inset-0 z-0 bg-repeat opacity-30 mix-blend-screen blur-[0.02rem] contrast-50"
    style={`background-image: url(${gridTile.src}); background-size: 50vw auto;`}
  >
  </div>

  <div class="relative z-20 mx-auto max-w-7xl px-6 pt-16 pb-24 md:px-10 md:pt-20 md:pb-28">
    <!-- <header class="mb-12 md:mb-4">
      <h2
        id="currently-building-label"
        class="font-blackletter text-emphasis text-5xl md:text-6xl lg:text-6xl"
      >
        Currently Building
      </h2>
    </header> -->
    <div class="flex items-end">
      <h2
        id="currently-building-label"
        class="bg-emphasis font-blackletter mr-auto translate-y-1/2 scale-y-90 px-4 py-2 text-5xl leading-none font-extralight tracking-tight text-black md:text-6xl lg:text-7xl"
      >
        Currently Building
      </h2>
      <div class="border-emphasis/30 flex-1 border-b"></div>
      <!-- <div class="border-faint/80 mr-0 ml-auto border-b pt-3 pr-6 pl-4">
        <EmbossedText text="Operations" height={20} />
      </div> -->
      <div class="border-emphasis/30 border-t border-r border-l bg-black pt-4 pr-6 pb-2 pl-4">
        <p
          class="text-reduced text-body-2xs font-mono leading-none font-extralight tracking-widest uppercase"
        >
          <span>Plate&nbsp;001</span>
          <span class="tracking-tighter" aria-hidden="true">:::</span>
          <span>Active Operations</span>
          <span class="tracking-tighter" aria-hidden="true">:::</span>
          <span>5</span>
        </p>
      </div>
    </div>

    <div class="border-emphasis/30 border-x border-b bg-black pt-8" data-cb-root>
      <!-- Active viewer -->
      <div class="p-6 md:p-8" data-cb-viewer>
        {
          itemsWithVisual.map(({ entry, resolvedImage }, idx) => {
            const { data } = entry;
            return (
              <div class:list={["cb-viewer-panel", idx > 0 && "hidden"]} data-cb-panel={entry.slug}>
                <div class="flex flex-col gap-6 md:flex-row md:items-stretch md:gap-10">
                  <div class="callout-frame border-emphasis/30 relative aspect-video flex-1 overflow-hidden border bg-black">
                    <span class="bracket tl" aria-hidden="true" />
                    <span class="bracket tr" aria-hidden="true" />
                    <span class="bracket bl" aria-hidden="true" />
                    <span class="bracket br" aria-hidden="true" />

                    {data.video ? (
                      <div class="flex h-full items-center p-2">
                        <video
                          autoplay
                          loop
                          muted
                          playsinline
                          class="block h-full w-full rounded-t-[3%] object-cover object-top"
                          poster={resolvedImage?.src}
                        >
                          <source src={`/video/${data.video}`} type="video/mp4" />
                        </video>
                      </div>
                    ) : resolvedImage ? (
                      <Image
                        src={resolvedImage}
                        alt={data.imageAlt ?? data.title}
                        class="h-full w-full object-cover object-top"
                        loading="lazy"
                        widths={[400, 800, 1200]}
                        sizes="(min-width: 768px) 55vw, 90vw"
                      />
                    ) : (
                      <div class="placeholder-cell flex h-full items-center justify-center">
                        <span class="text-foundation text-body-xs font-mono tracking-widest uppercase">
                          {data.status ? statusLabel[data.status] : "IN PROGRESS"}
                        </span>
                      </div>
                    )}
                  </div>

                  <div class="flex flex-col justify-start pt-4 md:w-2/5">
                    <div class="mt-0 flex flex-col items-start">
                      <h3 class="text-emphasis font-prompt origin-bottom text-lg font-semibold tracking-wider md:text-2xl">
                        {data.title}
                      </h3>
                      <div class="before:border-faint relative mt-2 flex w-full justify-between pr-2 before:absolute before:top-0 before:left-0 before:h-0 before:w-full before:border-t before:bg-none before:content-['']">
                        {data.type && (
                          <span class="text-emphasis border-faint text-body-sm border border-t-0 px-4 py-2 font-mono tracking-widest">
                            {data.type}
                          </span>
                        )}
                        {data.tech && data.tech.length > 0 && (
                          <p class="text-emphasis py-2 font-mono text-sm font-light tracking-wide uppercase">
                            {data.tech.join(" / ")}
                          </p>
                        )}
                      </div>
                    </div>
                    <p class="text-foundation mt-8 max-w-[48ch] text-base leading-normal tracking-normal">
                      {data.description}
                    </p>
                    <div class="mt-auto mr-auto ml-0">
                      {data.url && (
                        <a
                          href={data.url}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="text-body-xs border-accent hover:bg-accent text-accent mt-auto mb-0 flex items-center justify-self-end border-y px-4 font-mono tracking-widest uppercase transition-colors hover:text-black"
                        >
                          View Site <span class="mb-1 ml-2 text-2xl">&rarr;</span>
                        </a>
                      )}
                    </div>
                  </div>
                </div>
              </div>
            );
          })
        }
      </div>

      <!-- Thumbnail row -->
      <div
        class="border-emphasis/30 grid grid-cols-2 gap-4 border-t p-6 sm:grid-cols-3 md:grid-cols-5 md:p-8"
        data-cb-thumbs
      >
        {
          itemsWithVisual.map(({ entry, resolvedImage }, idx) => {
            const { data } = entry;
            return (
              <button
                type="button"
                class:list={[
                  "cb-thumb group relative cursor-pointer border bg-black p-2 transition-all",
                  idx === 0 ? "border-accent/30" : "border-emphasis/30 hover:border-accent",
                ]}
                data-cb-thumb={entry.slug}
                aria-label={`View ${data.title}`}
                aria-pressed={idx === 0 ? "true" : "false"}
              >
                {resolvedImage ? (
                  <Image
                    src={resolvedImage}
                    alt=""
                    class="block w-full"
                    loading="lazy"
                    widths={[200, 400]}
                    sizes="(min-width: 768px) 15vw, 40vw"
                  />
                ) : (
                  <div class="placeholder-cell flex aspect-[16/10] items-center justify-center">
                    <span class="text-foundation text-body-2xs font-mono tracking-widest uppercase">
                      {data.title}
                    </span>
                  </div>
                )}
                <div class="p-2">
                  <p class="text-emphasis text-body-2xs font-mono tracking-wider">{data.title}</p>
                </div>
              </button>
            );
          })
        }
      </div>
    </div>
  </div>
</section>

<style>
  .cb-thumb {
    transition:
      border-color 0.3s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .cb-thumb:hover {
    transform: rotate(0.25deg) translateY(-0.2rem);
    /* animation-name: attention-bounce;
    animation-duration: 3s;
    animation-iteration-count: infinite;
    transform-origin: bottom; */
  }
  .cb-thumb:nth-child(even):hover {
    transform: rotate(-0.25deg) translateY(-0.2rem);
  }

  @keyframes attention-bounce {
    0% {
      transform: translateY(0rem);
    }
    50% {
      transform: translateY(-0.2rem) scaleY(1.02);
    }
    52% {
      transform: translateY(0rem) scaleY(0.9994);
    }
    57% {
      transform: translateY(-0.15rem) scaleY(1.015);
    }
    59% {
      transform: translateY(0rem) scaleY(0.9996);
    }
    63% {
      transform: translateY(-0.1rem) scaleY(1.01);
    }
    65% {
      transform: translateY(0rem) scaleY(0.9998);
    }
    68% {
      transform: translateY(-0.05rem) scaleY(1.0005);
    }
    70% {
      transform: translateY(0rem) scaleY(0.9999);
    }
  }

  @keyframes wiggle {
    0% {
      transform: rotate(0deg);
    }
    10% {
      transform: rotate(0.5deg);
    }
    20% {
      transform: rotate(0deg);
    }
    30% {
      transform: rotate(-0.5deg);
    }
    40% {
      transform: rotate(0deg);
    }
    100% {
      transform: rotate(0deg);
    }
  }

  .bracket {
    position: absolute;
    width: 10px;
    height: 10px;
    border-color: rgba(255, 255, 255, 0.25);
    border-style: solid;
    z-index: 2;
  }
  .bracket.tl {
    top: -1px;
    left: -1px;
    border-width: 1px 0 0 1px;
  }
  .bracket.tr {
    top: -1px;
    right: -1px;
    border-width: 1px 1px 0 0;
  }
  .bracket.bl {
    bottom: -1px;
    left: -1px;
    border-width: 0 0 1px 1px;
  }
  .bracket.br {
    bottom: -1px;
    right: -1px;
    border-width: 0 1px 1px 0;
  }

  .placeholder-cell {
    background: repeating-linear-gradient(
      45deg,
      transparent 0px,
      transparent 14px,
      rgba(255, 255, 255, 0.02) 14px,
      rgba(255, 255, 255, 0.02) 15px
    );
  }

  @media (prefers-reduced-motion: reduce) {
    .cb-thumb {
      transition: border-color 0.3s;
    }
    .cb-thumb:hover,
    .cb-thumb:nth-child(even):hover {
      transform: none;
    }
  }
</style>

<script>
  function initCurrentlyBuilding() {
    const root = document.querySelector("[data-cb-root]");
    if (!root) return;

    const panels = root.querySelectorAll<HTMLElement>("[data-cb-panel]");
    const thumbs = root.querySelectorAll<HTMLButtonElement>("[data-cb-thumb]");
    let activeSlug = panels[0]?.dataset.cbPanel;

    thumbs.forEach((thumb) => {
      thumb.addEventListener("click", () => {
        const slug = thumb.dataset.cbThumb;
        if (!slug || slug === activeSlug) return;

        const currentPanel = root.querySelector<HTMLElement>(`[data-cb-panel="${activeSlug}"]`);
        const nextPanel = root.querySelector<HTMLElement>(`[data-cb-panel="${slug}"]`);
        if (!currentPanel || !nextPanel) return;

        currentPanel.classList.add("hidden");
        nextPanel.classList.remove("hidden");

        thumbs.forEach((t) => {
          const isActive = t.dataset.cbThumb === slug;
          t.classList.toggle("border-emerald-500/50", isActive);
          t.classList.toggle("border-white/10", !isActive);
          t.setAttribute("aria-pressed", String(isActive));
        });

        activeSlug = slug;
      });
    });
  }

  document.addEventListener("DOMContentLoaded", initCurrentlyBuilding);
  document.addEventListener("astro:page-load", initCurrentlyBuilding);
</script>
