---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import gridTile from "../images/ui/grid-tile.webp";
import EmbossedText from "./EmbossedText.astro";

const entries = (await getCollection("current")).sort(
  (a, b) => (a.data.order ?? 99) - (b.data.order ?? 99),
);

const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/images/current/*.{webp,jpg,jpeg,png}",
);

const resolveImage = (filename?: string) => {
  if (!filename) return null;
  const key = `/src/images/current/${filename}`;
  return images[key] ?? null;
};

const statusLabel = {
  live: "LIVE",
  beta: "BETA",
  "launching-soon": "LAUNCHING SOON",
} as const;

const rotations = [
  "-rotate-[3.5deg]",
  "rotate-[2.8deg]",
  "-rotate-[2.2deg]",
  "rotate-[4deg]",
  "-rotate-[3deg]",
];

const itemsWithVisual = await Promise.all(
  entries.map(async (entry, idx) => {
    const loader = resolveImage(entry.data.image);
    const resolvedImage = loader ? (await loader()).default : null;
    return {
      entry,
      resolvedImage,
      rotation: rotations[idx] ?? "",
      refNum: `01.${String(idx + 1).padStart(2, "0")}`,
    };
  }),
);
---

<section
  class="bg-background relative isolate z-0 overflow-hidden"
  aria-labelledby="currently-building-label"
>
  <div
    class="pointer-events-none absolute inset-0 z-0 bg-repeat opacity-15"
    style={`background-image: url(${gridTile.src}); background-size: 50vw auto;`}
  >
  </div>

  <div class="relative z-20 mx-auto max-w-7xl px-6 pt-16 pb-24 md:px-10 md:pt-20 md:pb-28">
    <div class="">
      <header class="mb-12 md:mb-16">
        <h2
          id="currently-building-label"
          class="font-bokor text-emphasis text-5xl md:text-6xl lg:text-4xl"
        >
          Currently Building
        </h2>
      </header>
      <div class="flex items-end">
        <div
          class="border-faint/80 rounded-tl-lg rounded-tr-lg border-t border-r border-l pt-4 pr-6 pl-2"
        >
          <EmbossedText text="Operations" height={20} />
        </div>
        <div class="border-faint/80 flex-1 border-b"></div>
        <div class="border-faint/80 border-b">
          <p
            class="text-subtle text-body-2xs pr-2 pb-2 font-mono font-medium tracking-widest uppercase"
          >
            <span>Plate&nbsp;01</span>
            <span class="mx-1" aria-hidden="true">::</span>
            <span>Active&nbsp;Work</span>
            <span class="mx-1" aria-hidden="true">::</span>
            <span>Sheet&nbsp;01&nbsp;OF&nbsp;08</span>
          </p>
        </div>
      </div>

      <ul
        class="border-faint/80 relative grid grid-cols-1 gap-y-16 border-x border-b bg-black pt-12 md:grid-cols-12 md:gap-x-10 md:gap-y-14"
      >
        {
          itemsWithVisual.map(({ entry, resolvedImage, rotation, refNum }) => {
            const { data } = entry;
            const isFocal = data.focal === true;
            const isPlaceholder = !resolvedImage;
            const status = data.status;
            const brand = data.brand;

            return (
              <li
                class:list={[
                  "workbench-item group relative origin-center",
                  rotation,
                  isFocal ? "md:col-span-6 md:row-span-2" : "md:col-span-3",
                ]}
              >
                <a
                  href={data.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="block h-full w-full no-underline"
                  aria-label={`${data.title}: ${data.description}`}
                >
                  <div class="callout-frame relative border border-white/10 bg-black">
                    <span class="bracket tl" aria-hidden="true" />
                    <span class="bracket tr" aria-hidden="true" />
                    <span class="bracket bl" aria-hidden="true" />
                    <span class="bracket br" aria-hidden="true" />

                    <span class="text-body-2xs absolute top-2 left-2.5 z-2 font-mono font-medium tracking-wider text-white/30">
                      {refNum}
                    </span>

                    {brand === "davant" && (
                      <span class="text-body-2xs absolute top-2 right-2.5 z-2 font-mono font-medium tracking-widest text-white/20">
                        DAVANT
                      </span>
                    )}

                    {resolvedImage ? (
                      <Image
                        src={resolvedImage}
                        alt={data.imageAlt ?? data.title}
                        class="block w-full"
                        loading="lazy"
                        widths={[400, 800, 1200]}
                        sizes={
                          isFocal
                            ? "(min-width: 1024px) 50vw, 90vw"
                            : "(min-width: 1024px) 25vw, (min-width: 768px) 33vw, 90vw"
                        }
                      />
                    ) : (
                      <div class="placeholder-cell flex aspect-[16/10] items-center justify-center">
                        <span class="text-foundation text-body-xs font-mono tracking-widest uppercase">
                          {status ? statusLabel[status] : "IN PROGRESS"}
                        </span>
                      </div>
                    )}
                  </div>

                  <div class="mt-3">
                    <div class="flex items-baseline gap-3">
                      <h3 class="font-bayon text-emphasis text-h4">{data.title}</h3>
                      {status && (
                        <span class="text-foundation text-body-2xs font-mono tracking-widest uppercase">
                          {statusLabel[status]}
                        </span>
                      )}
                    </div>
                    <p class="text-foundation text-body-sm mt-1 leading-relaxed">
                      {data.description}
                    </p>
                    {data.tech && data.tech.length > 0 && (
                      <p class="text-foundation text-body-2xs mt-2 font-mono tracking-wider uppercase">
                        {data.tech.join(" / ")}
                      </p>
                    )}
                  </div>
                </a>
              </li>
            );
          })
        }
      </ul>
    </div>
  </div>
</section>

<style>
  /* Hover: lift item and shift frame/bracket colors to emerald */
  .workbench-item {
    transition:
      transform 0.3s cubic-bezier(0.22, 1, 0.36, 1),
      rotate 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .workbench-item:hover {
    transform: translateY(-3px);
    rotate: 0deg;
  }
  .workbench-item:hover .callout-frame {
    border-color: rgba(16, 185, 129, 0.3);
  }
  .workbench-item:hover .bracket {
    border-color: rgba(16, 185, 129, 0.5);
  }

  /* Corner registration brackets */
  .bracket {
    position: absolute;
    width: 10px;
    height: 10px;
    border-color: rgba(255, 255, 255, 0.25);
    border-style: solid;
    z-index: 2;
    transition: border-color 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .bracket.tl {
    top: -1px;
    left: -1px;
    border-width: 1px 0 0 1px;
  }
  .bracket.tr {
    top: -1px;
    right: -1px;
    border-width: 1px 1px 0 0;
  }
  .bracket.bl {
    bottom: -1px;
    left: -1px;
    border-width: 0 0 1px 1px;
  }
  .bracket.br {
    bottom: -1px;
    right: -1px;
    border-width: 0 1px 1px 0;
  }

  /* Placeholder hatching */
  .placeholder-cell {
    background: repeating-linear-gradient(
      45deg,
      transparent 0px,
      transparent 14px,
      rgba(255, 255, 255, 0.02) 14px,
      rgba(255, 255, 255, 0.02) 15px
    );
  }

  /* Callout frame transition */
  .callout-frame {
    transition: border-color 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }

  /* Mobile: flatten rotations */
  @media (max-width: 767px) {
    .workbench-item {
      rotate: 0deg !important;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .workbench-item,
    .callout-frame,
    .bracket {
      transition: none;
    }
    .workbench-item:hover {
      transform: none;
      rotate: inherit;
    }
  }
</style>
