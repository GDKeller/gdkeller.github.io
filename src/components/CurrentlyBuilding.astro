---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import gridTile from "../images/ui/grid-tile.webp";

const entries = (await getCollection("current")).sort(
  (a, b) => (a.data.order ?? 99) - (b.data.order ?? 99),
);

const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/images/current/*.{webp,jpg,jpeg,png}",
);

const resolveImage = async (filename?: string) => {
  if (!filename) return null;
  const loader = images[`/src/images/current/${filename}`];
  return loader ? (await loader()).default : null;
};

const statusLabel = {
  live: "LIVE",
  beta: "BETA",
  "launching-soon": "LAUNCHING SOON",
} as const;

const items = await Promise.all(
  entries.map(async (entry) => ({
    entry,
    image: await resolveImage(entry.data.image),
  })),
);
---

<section
  class="bg-background relative isolate z-0 overflow-hidden py-32"
  aria-labelledby="currently-building-label"
>
  <div
    class="pointer-events-none absolute inset-0 z-0 bg-repeat opacity-30 mix-blend-screen blur-[0.02rem] contrast-50"
    style={`background-image: url(${gridTile.src}); background-size: 50vw auto;`}
  >
  </div>

  <div class="relative z-20 mx-auto max-w-7xl px-6 pt-16 pb-24 md:px-10 md:pt-20 md:pb-28">
    <div class="flex items-end">
      <h2
        id="currently-building-label"
        class="bg-emphasis font-blackletter mr-auto translate-y-1/2 scale-y-90 px-4 py-2 text-5xl leading-none font-extralight tracking-tight text-black md:text-6xl lg:text-7xl"
      >
        Currently Building
      </h2>
      <div class="border-faint/80 flex-1 border-b-2"></div>
      <div class="border-faint/80 bg-background border-2 border-b-0 pt-4 pr-6 pb-2 pl-4">
        <p
          class="text-faint text-body-2xs font-mono leading-none font-extralight tracking-widest uppercase"
        >
          <span>Plate&nbsp;001</span>
          <span class="tracking-tighter" aria-hidden="true">:::</span>
          <span>Active Operations</span>
          <span class="tracking-tighter" aria-hidden="true">:::</span>
          <span>5</span>
        </p>
      </div>
    </div>

    <div class="border-faint/80 border-2 border-t-0 bg-black pt-8" data-builds>
      <!-- Active viewer -->
      <div class="p-6 md:p-8">
        {
          items.map(({ entry, image }, idx) => {
            const { data } = entry;
            return (
              <div class:list={[idx > 0 && "hidden"]} data-panel={entry.slug}>
                <div class="flex flex-col gap-6 md:flex-row md:items-stretch md:gap-10">
                  <div class="callout-frame border-faint/80 bg-background relative aspect-video flex-1 border-0">
                    <span class="bracket tl" aria-hidden="true" />
                    <span class="bracket tr" aria-hidden="true" />
                    <span class="bracket bl" aria-hidden="true" />
                    <span class="bracket br" aria-hidden="true" />

                    {data.video ? (
                      <div class="flex h-full items-center p-2">
                        <video
                          autoplay
                          loop
                          muted
                          playsinline
                          class="block h-full w-full rounded-t-[3%] object-cover object-top"
                          poster={image?.src}
                        >
                          <source src={`/video/${data.video}`} type="video/mp4" />
                        </video>
                      </div>
                    ) : image ? (
                      <Image
                        src={image}
                        alt={data.imageAlt ?? data.title}
                        class="h-full w-full object-cover object-top"
                        loading="lazy"
                        widths={[400, 800, 1200]}
                        sizes="(min-width: 768px) 55vw, 90vw"
                      />
                    ) : (
                      <div class="placeholder-cell flex h-full items-center justify-center">
                        <span class="text-foundation text-body-xs font-mono tracking-widest uppercase">
                          {data.status ? statusLabel[data.status] : "IN PROGRESS"}
                        </span>
                      </div>
                    )}
                  </div>

                  <div class="flex flex-col justify-start pt-4 md:w-2/5">
                    <div class="mt-0 flex flex-col items-start">
                      <h3 class="text-emphasis font-prompt origin-bottom text-lg font-semibold tracking-wider md:text-2xl">
                        {data.title}
                      </h3>
                      <div class="before:border-faint relative mt-2 flex w-full justify-between pr-2 before:absolute before:top-0 before:left-0 before:h-0 before:w-full before:border-t before:bg-none before:content-['']">
                        {data.type && (
                          <span class="text-emphasis border-faint text-body-sm border border-t-0 px-4 py-2 font-mono tracking-widest">
                            {data.type}
                          </span>
                        )}
                        {data.tech && data.tech.length > 0 && (
                          <p class="text-emphasis py-2 font-mono text-sm font-light tracking-wide uppercase">
                            {data.tech.join(" / ")}
                          </p>
                        )}
                      </div>
                    </div>
                    <p class="text-foundation mt-8 max-w-[48ch] text-base leading-normal tracking-normal">
                      {data.description}
                    </p>
                    <div class="mt-auto mr-auto ml-0">
                      {data.url && (
                        <a
                          href={data.url}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="text-body-xs border-accent hover:bg-accent text-accent mt-auto mb-0 flex items-center justify-self-end border-y px-4 font-mono tracking-widest uppercase transition-colors hover:text-black"
                        >
                          View Site <span class="mb-1 ml-2 text-2xl">&rarr;</span>
                        </a>
                      )}
                    </div>
                  </div>
                </div>
              </div>
            );
          })
        }
      </div>

      <!-- Thumbnail row -->
      <div
        class="border-faint/80 grid grid-cols-2 gap-4 border-t-2 p-6 sm:grid-cols-3 md:grid-cols-5 md:p-8"
      >
        {
          items.map(({ entry, image }, idx) => {
            const { data } = entry;
            return (
              <button
                type="button"
                class:list={[
                  "thumb group relative flex cursor-pointer flex-col border transition-all duration-200",
                  idx === 0 && "is-active",
                ]}
                data-thumb={entry.slug}
                aria-label={`View ${data.title}`}
                aria-pressed={idx === 0 ? "true" : "false"}
              >
                {image ? (
                  <Image
                    src={image}
                    alt=""
                    class="block aspect-16/10 w-full object-cover"
                    loading="lazy"
                    widths={[200, 400]}
                    sizes="(min-width: 768px) 15vw, 40vw"
                  />
                ) : (
                  <div class="placeholder-cell flex aspect-16/10 flex-1 items-center justify-center">
                    <span class="text-foundation text-body-2xs font-mono tracking-widest uppercase">
                      {data.title}
                    </span>
                  </div>
                )}
                <div class="thumb-title bg-emphasis group-hover:bg-accent m-0 mt-auto flex h-12 p-2 transition-colors duration-200">
                  <p class="text-background text-body-2xs m-auto font-mono font-medium tracking-normal">
                    {data.title}
                  </p>
                </div>
              </button>
            );
          })
        }
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  @reference "../styles/global.css";

  .thumb {
    @apply border-faint/80;

    &:hover {
      @apply border-accent;
      transform: translateY(-0.1rem);
    }

    &.is-active,
    &.is-active:hover {
      @apply border-accent;
    }

    &.is-active .thumb-title {
      @apply bg-accent;
    }
  }

  @keyframes attention-bounce {
    0% {
      transform: translateY(0rem);
    }
    50% {
      transform: translateY(-0.2rem) scaleY(1.02);
    }
    52% {
      transform: translateY(0rem) scaleY(0.9994);
    }
    57% {
      transform: translateY(-0.15rem) scaleY(1.015);
    }
    59% {
      transform: translateY(0rem) scaleY(0.9996);
    }
    63% {
      transform: translateY(-0.1rem) scaleY(1.01);
    }
    65% {
      transform: translateY(0rem) scaleY(0.9998);
    }
    68% {
      transform: translateY(-0.05rem) scaleY(1.0005);
    }
    70% {
      transform: translateY(0rem) scaleY(0.9999);
    }
  }

  @keyframes wiggle {
    0% {
      transform: rotate(0deg);
    }
    10% {
      transform: rotate(0.5deg);
    }
    20% {
      transform: rotate(0deg);
    }
    30% {
      transform: rotate(-0.5deg);
    }
    40% {
      transform: rotate(0deg);
    }
    100% {
      transform: rotate(0deg);
    }
  }

  .bracket {
    position: absolute;
    width: 10px;
    height: 10px;
    @apply border-accent;
    border-style: solid;
    z-index: 2;
  }
  .bracket.tl {
    top: -1px;
    left: -1px;
    border-width: 1px 0 0 1px;
  }
  .bracket.tr {
    top: -1px;
    right: -1px;
    border-width: 1px 1px 0 0;
  }
  .bracket.bl {
    bottom: -1px;
    left: -1px;
    border-width: 0 0 1px 1px;
  }
  .bracket.br {
    bottom: -1px;
    right: -1px;
    border-width: 0 1px 1px 0;
  }

  .placeholder-cell {
    background: repeating-linear-gradient(
      45deg,
      transparent 0px,
      transparent 14px,
      rgba(255, 255, 255, 0.2) 14px,
      rgba(255, 255, 255, 0.2) 15px
    );
  }

  @media (prefers-reduced-motion: reduce) {
    .thumb {
      transition: border-color 0.3s;
    }
    .thumb:hover,
    .thumb:nth-child(even):hover {
      transform: none;
    }
  }
</style>

<script>
  function initCurrentlyBuilding() {
    const root = document.querySelector<HTMLElement>("[data-builds]");
    if (!root) return;

    const panels = root.querySelectorAll<HTMLElement>("[data-panel]");
    const thumbs = root.querySelectorAll<HTMLButtonElement>("[data-thumb]");

    const setActive = (slug: string) => {
      panels.forEach((p) => p.classList.toggle("hidden", p.dataset.panel !== slug));
      thumbs.forEach((t) => {
        const active = t.dataset.thumb === slug;
        t.classList.toggle("is-active", active);
        t.setAttribute("aria-pressed", String(active));
      });
    };

    thumbs.forEach((thumb) => {
      thumb.addEventListener("click", () => {
        const slug = thumb.dataset.thumb;
        if (slug) setActive(slug);
      });
    });
  }

  document.addEventListener("DOMContentLoaded", initCurrentlyBuilding);
  document.addEventListener("astro:page-load", initCurrentlyBuilding);
</script>
