---
import { Picture } from "astro:assets";
import type { ImageMetadata } from "astro";

// Client logos — foundation-tinted variants for visual uniformity
import logoAAM from "../images/logos/clients/tinted/logo_AAM_tint.webp";
import logoADDitude from "../images/logos/clients/tinted/logo_ADDitude_tint.webp";
import logoAlley from "../images/logos/clients/tinted/logo_alley_tint.webp";
import logoCoolGreenScience from "../images/logos/clients/tinted/logo_CoolGreenScience_tint.webp";
import logoCPJ from "../images/logos/clients/tinted/logo_CPJ_tint.webp";
import logoDecider from "../images/logos/clients/tinted/logo_decider_wordmark_tint.webp";
import logoDunBradstreet from "../images/logos/clients/tinted/logo_DunandBradstreet_wordmark_tint.webp";
import logoHealthline from "../images/logos/clients/tinted/logo_healthline_tint.webp";
import logoKFF from "../images/logos/clients/tinted/logo_KFF-HealthNews_tint.webp";
import logoLADPH from "../images/logos/clients/tinted/logo_LADPH_tint.webp";
import logoMarinersMuseum from "../images/logos/clients/tinted/logo_MarinersMuseum_tint.webp";
import logoNASA from "../images/logos/clients/tinted/logo_nasa_wordmark_tint.webp";
import logoNHMLAC from "../images/logos/clients/tinted/logo_NHMLAC_tint.webp";
import logoNYP from "../images/logos/clients/tinted/logo_NYP_tint.webp";
import logoPageSix from "../images/logos/clients/tinted/logo_PageSix_tint.webp";
import logoRCFP from "../images/logos/clients/tinted/logo_RCFP_tint.webp";
import logoStudio3 from "../images/logos/clients/tinted/logo_studio3_tint.webp";
import logoTedx from "../images/logos/clients/tinted/logo_tedx_tint.webp";

interface Logo {
  src: ImageMetadata;
  alt: string;
}

const logos: Logo[] = [
  { src: logoRCFP, alt: "Reporters Committee for Freedom of the Press" },
  { src: logoADDitude, alt: "ADDitude Magazine" },
  { src: logoStudio3, alt: "Studio 3" },
  { src: logoNASA, alt: "NASA" },
  { src: logoNYP, alt: "New York Post" },
  { src: logoTedx, alt: "TEDx" },
  { src: logoNHMLAC, alt: "Natural History Museum of Los Angeles County" },
  { src: logoLADPH, alt: "LA County Department of Public Health" },
  { src: logoPageSix, alt: "Page Six" },
  { src: logoHealthline, alt: "Healthline" },
  { src: logoDunBradstreet, alt: "Dun & Bradstreet" },
  { src: logoAlley, alt: "Alley" },
  { src: logoAAM, alt: "American Alliance of Museums" },
  { src: logoCPJ, alt: "Committee to Protect Journalists" },
  { src: logoKFF, alt: "KFF Health News" },
  { src: logoMarinersMuseum, alt: "The Mariners' Museum" },
  { src: logoDecider, alt: "Decider" },
  { src: logoCoolGreenScience, alt: "Cool Green Science" },
];
---

<div
  class="logo-carousel relative h-full overflow-hidden"
  role="region"
  aria-label="Organizations I've worked with"
>
  <div class="carousel-mask relative h-full">
    <div
      class="carousel-track flex h-full items-center gap-[7vw] 2xl:gap-[5vw]"
    >
      {/* Primary logos - visible to screen readers */}
      {
        logos.map((logo) => (
          <div class="carousel-item flex h-full shrink-0 items-center">
            <Picture
              src={logo.src}
              alt={logo.alt}
              widths={[160, 320]}
              sizes="(min-width: 768px) 220px, 160px"
              formats={["avif", "webp"]}
              fallbackFormat="webp"
              loading="lazy"
              class="h-full max-h-full w-auto max-w-48 object-contain
                md:max-w-[12vw] lg:max-w-[12vw] xl:max-w-[15vw]"
            />
          </div>
        ))
      }
      {/* Duplicated logos for seamless scroll - hidden from screen readers */}
      {
        logos.map((logo) => (
          <div
            class="carousel-item--duplicate carousel-item flex h-full shrink-0
              items-center lg:max-w-[12vw]"
            aria-hidden="true"
          >
            <Picture
              src={logo.src}
              alt=""
              widths={[160, 320]}
              sizes="(min-width: 768px) 220px, 160px"
              formats={["avif", "webp"]}
              fallbackFormat="webp"
              loading="lazy"
              class="h-full max-h-full w-auto max-w-48 object-contain
                xl:max-w-[15vw]"
            />
          </div>
        ))
      }
    </div>
  </div>
</div>

<style>
  .carousel-mask {
    mask-image: linear-gradient(
      to right,
      transparent,
      black 10%,
      black 90%,
      transparent
    );
    -webkit-mask-image: linear-gradient(
      to right,
      transparent,
      black 10%,
      black 90%,
      transparent
    );
  }

  .carousel-track {
    animation: scroll 40s linear infinite;
    width: max-content;
  }

  @keyframes scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  /* Reduced motion: show static grid instead of scrolling duplicates */
  @media (prefers-reduced-motion: reduce) {
    .logo-carousel,
    .carousel-mask {
      height: auto;
    }

    .carousel-mask {
      mask-image: none;
      -webkit-mask-image: none;
    }

    .carousel-track {
      animation: none;
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 1.5rem 2rem;
      width: 100%;
      height: auto;
      padding: 0 1rem;
    }

    .carousel-item {
      height: auto;
    }

    .carousel-item :global(img) {
      height: auto;
      max-height: 3.5rem;
    }

    /* Hide duplicate logos in reduced motion mode */
    .carousel-item--duplicate {
      display: none;
    }
  }
</style>
