---
import HeadingSection from "./HeadingSection.astro";
import SkillsCard from "./SkillsCard.astro";

const primarySkills = [
  "TypeScript",
  "React",
  "SCSS / Tailwind",
  "Accessibility",
  "GSAP",
  "Node.js",
  "Information Architecture",
  "Performance Optimization",
];

const secondaryCategories = [
  {
    title: "Javascript",
    items: [
      "Typescript",
      "React 19",
      "React Native / Expo",
      "Astro / Gatsby",
      "Express / Fastify",
      "Next.js",
      "ThreeJS",
    ],
  },
  {
    title: "CSS",
    items: [
      "Sass / SCSS",
      "Advanced CSS Animations",
      "Semantic Systems",
      "BEM / Component Systems",
      "Vite / Turbo / Webpack",
      "Responsive at all sizes",
      "Cross-browser compatibility",
    ],
  },
  {
    title: "HTML",
    items: [
      "Information Architecture (IA)",
      "Technical SEO",
      "Core Web Vitals",
      "Analytics (GA4, Custom)",
      "Google Ads / Adslot",
      "CRO / Heatmaps / A/B Testing",
    ],
  },
  {
    title: "WordPress / PHP",
    items: [
      "Custom themes & plugins",
      "WordPress VIP hosting",
      "Advanced Custom Fields",
      "WooCommerce",
      "Custom membership systems",
      "WP-specific performance",
    ],
  },
  {
    title: "Python",
    items: [
      "Stable Diffusion / Comfy UI",
      "Computer Vision / OpenCV",
      "Tensorflow / PyTorch",
      "Flask",
      "Tkinter / Qt",
      "PyInstaller / Portable Binaries",
    ],
  },
  {
    title: "C++",
    items: [
      "ESP32 / Espressif",
      "Arduino Ecosystem",
      "PlatformIO",
      "OTA Updates",
      "Captive WiFi portal",
      "LEDs & peripherals",
    ],
  },
];
---

<div class="mb-8 flex flex-col items-center md:mb-16">
  <h2 class="sr-only">Skills</h2>
  <HeadingSection
    as="p"
    text="Tools of the Trade"
    align="center"
    animate={true}
    aria-hidden="true"
  />
</div>

<!-- Primary Skills — Core Expertise -->
<div class="primary-skills mb-0 flex flex-col items-start">
  <div
    class="core-expertise-label bg-emphasis z-20 translate-y-0.5 py-2 pr-12
      pl-4"
  >
    <p
      class="text-background-dark relative z-100 font-mono text-sm font-bold
        tracking-widest uppercase"
    >
      Core Expertise
    </p>
  </div>
  <ul
    class="bg-faint z-1 grid w-full gap-0.5 p-0.5 pb-0 sm:grid-cols-2 md:flex
      md:flex-row md:flex-wrap"
  >
    {
      primarySkills.map((skill) => (
        <li
          class="text-emphasis bg-background-dark relative z-110 w-auto px-4
            py-2 font-mono text-base tracking-wide uppercase sm:px-4 md:grow
            md:px-4 md:py-4 md:text-center lg:px-8 lg:py-8"
        >
          {skill}
        </li>
      ))
    }
  </ul>
</div>

<!-- Secondary Skills — Full Range by Category -->
<details class="secondary-skills-details relative z-2">
  <summary
    class="font-display group text-highlight border-faint mx-auto mr-0 mb-0
      ml-auto flex w-full cursor-pointer items-center justify-center border-2
      p-1 text-right whitespace-pre select-none"
  >
    <span class="hazard-stripe--reverse h-12 w-full"></span>
    <span
      class="text relative z-110 px-2 py-4 pl-4 font-mono text-sm leading-none
        tracking-widest uppercase"
      >Full Loadout</span
    >
    <span class="hazard-stripe--reverse h-12 w-full"></span>
  </summary>
  <div
    class="skills-grid border-fainter bg-faint flex flex-col gap-0.5 px-0.5
      pb-0.5 sm:grid sm:grid-cols-2 lg:grid-cols-3"
  >
    {
      secondaryCategories.map((cat) => (
        <SkillsCard category={cat.title} skills={cat.items} />
      ))
    }
  </div>
</details>

<style lang="scss">
  @reference "../styles/global.css";

  .core-expertise-label {
    clip-path: polygon(
      0 0,
      calc(100% - 2.25rem) 0,
      100% 2.25rem,
      100% 100%,
      0 100%
    );
  }

  details {
    interpolate-size: allow-keywords;
  }

  details::details-content {
    block-size: 0;
    overflow: clip;
    transition:
      block-size 350ms ease,
      content-visibility 350ms allow-discrete;
  }

  details[open]::details-content {
    block-size: auto;
  }

  summary {
    .text::after {
      letter-spacing: 0.25em;
      margin-left: 0.5em;
      content: "[+]";
    }

    .hazard-stripe--reverse {
      transition:
        clip-path 50ms ease-in-out,
        opacity 50ms;
      opacity: 0.7;
      animation: hazard-breathe 3s infinite ease-in-out;
      &:first-child {
        clip-path: polygon(0 0, 93% 0, 100% 100%, 0 100%);
      }
      &:last-child {
        clip-path: polygon(0 0, 100% 0, 100% 100%, 7% 100%);
      }
    }

    &:hover {
      @apply text-highlight-hover border-emphasis;

      .hazard-stripe--reverse {
        opacity: 1;
        animation: none;
        &:first-child {
          clip-path: polygon(0 0, 98% 0, 100% 100%, 0 100%);
        }
        &:last-child {
          clip-path: polygon(0 0, 100% 0, 100% 100%, 2% 100%);
        }
      }
    }
  }

  details[open] > summary {
    .text::after {
      content: "[−]";
    }
    .hazard-stripe--reverse {
      animation: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    details::details-content {
      transition: none;
    }
    summary .hazard-stripe--reverse {
      animation: none;
    }
  }

  @keyframes hazard-breathe {
    0%,
    50% {
      opacity: 0.5;
    }
    75% {
      opacity: 1;
    }
    100% {
      opacity: 0.5;
    }
  }
</style>
