---
import HeadingSection from "./HeadingSection.astro";
import SkillsCard from "./SkillsCard.astro";

const primarySkills = [
  "TypeScript",
  "React",
  "Node.js",
  "Accessibility / WCAG",
  "SCSS/Tailwind CSS",
  "GSAP",
  "Information Architecture",
  "Performance Optimization",
];

const secondaryCategories = [
  {
    title: "Javascript",
    items: [
      "Typescript",
      "React 19",
      "React Native / Expo",
      "Astro / Gatsby",
      "Express / Fastify",
      "Next.js",
      "ThreeJS",
    ],
  },
  {
    title: "CSS",
    items: [
      "Sass/SCSS",
      "Advanced CSS Animations",
      "Semantic Systems",
      "BEM / Component Systems",
      "Vite / Turbo / Webpack",
      "Responsive at all sizes",
      "Cross-browser compatibility",
    ],
  },
  {
    title: "HTML",
    items: [
      "Information Architecture (IA)",
      "Technical SEO",
      "Core Web Vitals",
      "Analytics (GA4, Custom)",
      "Google Ads / Adslot",
      "CRO / Heatmaps / A/B Testing",
    ],
  },
  {
    title: "WordPress / PHP",
    items: [
      "Custom themes & plugins",
      "WordPress VIP hosting",
      "Advanced Custom Fields",
      "WooCommerce",
      "Custom membership systems",
      "WP-specific performance",
    ],
  },
  {
    title: "Python",
    items: [
      "Stable Diffusion / Comfy UI",
      "Computer Vision / OpenCV",
      "Tensorflow / PyTorch",
      "Flask",
      "Tkinter / Qt",
      "PyInstaller / Portable Distribution",
    ],
  },
  {
    title: "C++",
    items: [
      "ESP32 / Espressif toolchain",
      "Arduino Ecosystem",
      "PlatformIO",
      "OTA Updates",
      "Captive WiFi portal",
      "LED and peripherals",
    ],
  },
];
---

<div class="mb-16 flex flex-col items-center">
  <h2 class="sr-only">Skills</h2>
  <HeadingSection as="p" text="Tools of the Trade" align="center" aria-hidden="true" />
</div>

<!-- Primary Skills — Core Expertise -->
<div class="primary-skills mb-12 flex flex-col items-center">
  <div class="bg-emphasis border-faint border border-b-0 px-4 py-2">
    <p
      class="text-background-dark font-regular relative z-100 font-mono text-sm tracking-widest uppercase"
    >
      Core Expertise
    </p>
  </div>
  <ul class="bg-background-dark grid w-full grid-cols-[auto_auto_auto_auto]">
    {
      primarySkills.map((skill) => (
        <li class="text-emphasis border-fainter relative z-110 w-auto border px-8 py-4 font-mono text-base tracking-wide uppercase">
          {skill}
        </li>
      ))
    }
  </ul>
</div>

<!-- Secondary Skills — Full Range by Category -->
<details class="secondary-skills-details group">
  <summary
    class="font-display text-emphasis mx-auto mb-4 flex w-min cursor-pointer items-center justify-center px-4 py-2 whitespace-pre select-none"
  >
    <span class="relative z-110 mr-2 font-mono text-sm tracking-widest uppercase">Full Loadout</span
    >
    <svg
      class="h-4 w-4 transition-transform group-open:rotate-180"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="2"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
    </svg>
  </summary>
  <div class="skills-grid flex flex-col sm:grid sm:grid-cols-2 lg:grid-cols-3">
    {
      secondaryCategories.map((cat) => (
        <SkillsCard text={cat.title}>
          <ul class="list flex flex-col gap-2">
            {cat.items.map((item) => (
              <li class="relative z-110 px-8 py-1 font-mono text-base">{item}</li>
            ))}
          </ul>
        </SkillsCard>
      ))
    }
  </div>
</details>
