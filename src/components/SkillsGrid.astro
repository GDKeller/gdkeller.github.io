---
import HeadingSection from "./HeadingSection.astro";
import SkillsCard from "./SkillsCard.astro";

const primarySkills = [
  "TypeScript",
  "React",
  "Node.js",
  "GSAP",
  "Accessibility / WCAG",
  "SCSS / Tailwind",
  "Information Architecture",
  "Performance Optimization",
];

const secondaryCategories = [
  {
    title: "Javascript",
    items: [
      "Typescript",
      "React 19",
      "React Native / Expo",
      "Astro / Gatsby",
      "Express / Fastify",
      "Next.js",
      "ThreeJS",
    ],
  },
  {
    title: "CSS",
    items: [
      "Sass / SCSS",
      "Advanced CSS Animations",
      "Semantic Systems",
      "BEM / Component Systems",
      "Vite / Turbo / Webpack",
      "Responsive at all sizes",
      "Cross-browser compatibility",
    ],
  },
  {
    title: "HTML",
    items: [
      "Information Architecture (IA)",
      "Technical SEO",
      "Core Web Vitals",
      "Analytics (GA4, Custom)",
      "Google Ads / Adslot",
      "CRO / Heatmaps / A/B Testing",
    ],
  },
  {
    title: "WordPress / PHP",
    items: [
      "Custom themes & plugins",
      "WordPress VIP hosting",
      "Advanced Custom Fields",
      "WooCommerce",
      "Custom membership systems",
      "WP-specific performance",
    ],
  },
  {
    title: "Python",
    items: [
      "Stable Diffusion / Comfy UI",
      "Computer Vision / OpenCV",
      "Tensorflow / PyTorch",
      "Flask",
      "Tkinter / Qt",
      "PyInstaller / Portable Distribution",
    ],
  },
  {
    title: "C++",
    items: [
      "ESP32 / Espressif toolchain",
      "Arduino Ecosystem",
      "PlatformIO",
      "OTA Updates",
      "Captive WiFi portal",
      "LED and peripherals",
    ],
  },
];
---

<div class="mb-8 flex flex-col items-center md:mb-16">
  <h2 class="sr-only">Skills</h2>
  <HeadingSection
    as="p"
    text="Tools of the Trade"
    align="center"
    animate={true}
    aria-hidden="true"
  />
</div>

<!-- Primary Skills — Core Expertise -->
<div class="primary-skills mb-0 flex flex-col items-start gap-1">
  <div class="bg-emphasis px-4 py-2">
    <p
      class="text-background-dark font-regular relative z-100 font-mono text-sm tracking-widest uppercase"
    >
      Core Expertise
    </p>
  </div>
  <ul
    class="bg-background-dark grid w-full sm:grid-cols-2 md:flex md:flex-row md:flex-wrap md:gap-1"
  >
    {
      primarySkills.map((skill) => (
        <li class="text-emphasis border-fainter relative z-110 w-auto border px-4 py-2 font-mono text-base tracking-wide uppercase md:grow md:px-4 md:py-4 md:text-center lg:px-8 lg:py-8">
          {skill}
        </li>
      ))
    }
  </ul>
</div>

<!-- Secondary Skills — Full Range by Category -->
<details class="secondary-skills-details">
  <summary
    class="font-display text-accent border-faint hover:text-accent-hover mx-auto mr-0 mb-0 ml-auto flex w-full cursor-pointer items-center justify-center gap-2 border-b py-1 text-right whitespace-pre select-none"
  >
    <span class="hazard-stripe h-8 w-full"></span>
    <span
      class="text relative z-110 px-2 py-4 pl-3 font-mono text-sm leading-none tracking-widest uppercase"
      >Full Loadout</span
    >
    <span class="hazard-stripe h-8 w-full"></span>
  </summary>
  <div
    class="skills-grid border-fainter -mt-px flex flex-col border-r border-b sm:grid sm:grid-cols-2 lg:grid-cols-3"
  >
    {
      secondaryCategories.map((cat) => (
        <SkillsCard category={cat.title} skills={cat.items} />
      ))
    }
  </div>
</details>

<style lang="scss">
  summary {
    .text {
      &::after {
        letter-spacing: 0.25em;
        margin-left: 0.5em;
        content: "[+]";
      }
    }

    &:hover {
      .hazard-stripe {
        opacity: 1;
        animation: none;
      }
    }
  }

  details[open] > summary .text::after {
    content: "[−]";
  }

  details {
    interpolate-size: allow-keywords;
  }

  details[open] > summary .hazard-stripe {
    animation: none;
  }

  details::details-content {
    block-size: 0;
    overflow: clip;
    transition:
      block-size 350ms ease,
      content-visibility 350ms allow-discrete;
  }

  details[open]::details-content {
    block-size: auto;
  }

  @media (prefers-reduced-motion: reduce) {
    details::details-content {
      transition: none;
    }
    .hazard-stripe {
      animation: none;
    }
  }

  .hazard-stripe {
    transition: opacity 50ms;
    opacity: 0.7;
    animation: hazard-breathe 3s infinite ease-in-out;
    &:first-child {
      clip-path: polygon(
        0 0,
        calc(100% - 0px) 0,
        95% 100%,
        calc(100% - 0px) 100%,
        0 100%
      );
    }
    &:last-child {
      clip-path: polygon(0px 0, 100% 0, 100% 100%, 0px 100%, 5% 0%);
    }
  }

  @keyframes hazard-breathe {
    0% {
      opacity: 0.5;
    }
    25% {
      opacity: 1;
    }
    50% {
      opacity: 0.5;
    }
    100% {
      opacity: 0.5;
    }
  }
</style>
