---
import { Picture } from "astro:assets";
import type { ImageMetadata } from "astro";
import emmyImg from "../images/awards/emmy.webp";
import addyImg from "../images/awards/addy-gold.webp";
import cgwImg from "../images/awards/CGW_SIGGRAPH.webp";
import hackadayImg from "../images/awards/hackaday_gold.png";
import HeadingSection from "./HeadingSection.astro";

interface Award {
  src: ImageMetadata;
  alt: string;
  name: string;
  subtitle: string;
  level: "gold" | "silver" | "bronze";
  count: number;
}

const awards: Award[] = [
  {
    src: cgwImg,
    alt: "CGW SIGGRAPH Best of Show",
    name: "Computer Graphics World",
    subtitle: "SIGGRAPH Best of Show",
    level: "silver",
    count: 1,
  },
  {
    src: emmyImg,
    alt: "Emmy Award",
    name: "Emmy Awards",
    subtitle: "Science, Narrative Short",
    level: "gold",
    count: 2,
  },
  {
    src: addyImg,
    alt: "Addy Award",
    name: "Addy Awards",
    subtitle: "Best of Show, Editors' Choice",
    level: "gold",
    count: 2,
  },
  {
    src: hackadayImg,
    alt: "Hackaday Superconference Badge Hacking Prize",
    name: "Hackaday Supercon",
    subtitle: "Badge Hacking Prize",
    level: "gold",
    count: 1,
  },
];
---

<div class="awards" role="region" aria-label="Awards and recognition">
  <HeadingSection
    text="Awards"
    align="center"
    treatment="glow"
    animate={true}
    class="mb-16 md:mb-24"
  />
  <div
    class="relative grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-4
      lg:gap-12"
  >
    {
      awards.map((award) => (
        <div
          class="award-item group flex w-full flex-col items-center text-center
            lg:w-auto"
        >
          <div class="relative mb-4 h-28 w-28 md:h-32 md:w-32 lg:h-44 lg:w-44">
            <Picture
              src={award.src}
              alt={award.alt}
              widths={[112, 176, 352]}
              sizes="(min-width: 1024px) 176px, (min-width: 768px) 128px, 112px"
              formats={["avif", "webp"]}
              fallbackFormat="webp"
              loading="lazy"
              class={`h-full w-full object-contain transition-shadow
                ${award.level === "gold" ? "drop-shadow-[0_0_1rem_rgba(250,220,160,0.2)]" : award.level === "silver" ? "drop-shadow-[0_0_1.5rem_rgba(192,192,192,0.1)]" : "drop-shadow-[0_0_1rem_rgba(205,127,50,0.2)]"}`}
            />
          </div>
          <div class="relative z-110">
            <h3
              class="text-foundation mb-1 text-lg font-medium md:text-lg
                lg:text-lg xl:text-xl"
            >
              {award.name}
            </h3>
            <p class="text-emphasis font-mono text-xs font-extralight">
              {award.subtitle}
            </p>
            {award.count > 1 && (
              <span
                class="text-accent absolute -top-6 -right-4 flex h-8 w-8
                  items-center justify-center text-base font-bold md:h-10
                  md:w-10 md:text-lg"
              >
                x{award.count}
              </span>
            )}
          </div>
        </div>
      ))
    }
  </div>
</div>
