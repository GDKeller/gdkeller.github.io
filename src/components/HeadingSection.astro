---
import type { HTMLAttributes } from "astro/types";

type Align = "left" | "center";
type Size = "sm" | "md" | "lg";
type Treatment = "none" | "line" | "glow" | "inverted" | "bordered";
type LineColor = "accent" | "emphasis";
type As = "h2" | "h3" | "p";

interface Props {
  text: string;
  as?: As;
  align?: Align;
  size?: Size;
  /* Single treatment or an array to compose multiple (e.g. ["line", "inverted"]). */
  treatment?: Treatment | Treatment[];
  /* Modifiers for the `line` treatment. Ignored when line isn't present. */
  lineColor?: LineColor;
  lineFlush?: boolean;
  id?: HTMLAttributes<"h2">["id"];
  animate?: boolean;
  class?: HTMLAttributes<"h2">["class"];
}

const {
  text,
  as: Tag = "h2",
  align = "center",
  size = "lg",
  treatment = "none",
  lineColor = "accent",
  lineFlush = false,
  id,
  animate,
  class: className,
  ...rest
} = Astro.props as Props;

const alignClasses: Record<Align, string> = {
  left: "text-left mr-auto",
  center: "text-center mx-auto",
};

const sizeClasses: Record<Size, string> = {
  sm: "text-3xl md:text-4xl",
  md: "text-4xl sm:text-5xl md:text-6xl",
  lg: "text-5xl sm:text-7xl md:text-8xl lg:text-8xl xl:text-8xl 2xl:text-9xl",
};

const lineClass = [
  "section-heading__line",
  lineColor === "emphasis" && "section-heading__line--emphasis",
  lineFlush && "section-heading__line--flush",
]
  .filter(Boolean)
  .join(" ");

const treatmentClasses: Record<Treatment, string> = {
  none: "",
  line: lineClass,
  glow: "section-heading__glow",
  inverted: "section-heading__inverted bg-emphasis py-2 px-4",
  bordered: "border border-emphasis py-2 px-4",
};

const treatmentList: Treatment[] = Array.isArray(treatment)
  ? treatment
  : [treatment];
---

<Tag
  id={id}
  class:list={[
    "section-heading",
    "font-decorative text-emphasis leading-none",
    alignClasses[align],
    sizeClasses[size],
    treatmentList.map((t) => treatmentClasses[t]),
    animate && "section-heading__animate",
    className,
  ]}
  {...rest}
>
  {text}
</Tag>

<style>
  .section-heading {
    width: min-content;
    white-space: pre;
  }

  .section-heading__glow {
    text-shadow:
      0.005em 0.005em 0.05em
        color-mix(in oklch, var(--color-background) 50%, transparent),
      -0.005em -0.005em 0.05em
        color-mix(in oklch, var(--color-background) 50%, transparent),
      -0.005em 0.005em 0.05em
        color-mix(in oklch, var(--color-background) 50%, transparent),
      0.005em -0.005em 0.05em
        color-mix(in oklch, var(--color-background) 50%, transparent),
      0 0 0.07em color-mix(in oklch, var(--color-emphasis) 25%, transparent),
      0 0 0.15em
        color-mix(in oklch, var(--color-emphasis-hover) 20%, transparent),
      0 0 0.35em color-mix(in oklch, var(--color-faint) 30%, transparent),
      0 0 0.55em color-mix(in oklch, var(--color-fainter) 10%, transparent),
      0 0 0.75em color-mix(in oklch, var(--color-fainter) 10%, transparent);
  }

  /* Line treatment: a horizontal rule passes through the heading and extends
     past the viewport on both sides. Self-contained, so the positioning
     context lives here and the treatment composes with any alignment.
     `top` is tuned to land near the optical center of font-decorative under
     the base `leading-none`. Avoid changing line-height here — that would
     alter the line-box and the inverted treatment's bg height with it. */
  .section-heading__line {
    position: relative;
    display: block;
  }
  .section-heading__line::before,
  .section-heading__line::after {
    content: "";
    position: absolute;
    top: 50%;
    width: 100vw;
    height: 1px;
    background-color: var(--color-accent);
  }
  .section-heading__line::before {
    right: calc(100% + 1rem);
  }
  .section-heading__line::after {
    left: calc(100% + 1rem);
  }

  /* Line modifier: emphasis-colored rule instead of accent. */
  .section-heading__line--emphasis::before,
  .section-heading__line--emphasis::after {
    background-color: var(--color-emphasis);
  }

  /* Line modifier: rule butts directly against the heading edge with no gap.
     Useful with the inverted treatment so the rule meets the bg flush. */
  .section-heading__line--flush::before {
    right: 100%;
  }
  .section-heading__line--flush::after {
    left: 100%;
  }

  /* Scoped attribute selector outranks the base text-emphasis utility, so
     inverted's text color wins reliably when composed with other treatments. */
  .section-heading__inverted {
    color: black;
  }
</style>
