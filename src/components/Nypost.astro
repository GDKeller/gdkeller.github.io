---
import { Picture } from "astro:assets";
import NypSpread from "../images/projects/site-spread.webp";
import NypostLogo from "../images/logos/clients/original/nypost-logo.svg?raw";
import Link from "./Link.astro";
---

<div
  class="relative z-0 container mx-auto mb-24 flex max-w-full flex-col items-start justify-center overflow-x-hidden py-24 font-light lg:flex-row"
>
  <div class="relative z-10 w-full px-12 lg:max-w-1/2">
    <h3 class="sr-only">New York Post</h3>
    <div class="relative mb-4 max-w-92">
      <Fragment set:html={NypostLogo} />
    </div>
    <div class="relative isolate lg:h-[calc(60vw*896/1026)]">
      <div
        class="nyp browser absolute top-0 right-0 isolate -z-1 w-[40vw] translate-x-4 overflow-visible"
      >
        <Picture
          src={NypSpread}
          alt="New York Post"
          widths={[400, 800, 1200]}
          sizes="(min-width: 1024px) 40vw, 90vw"
          formats={["avif", "webp"]}
          fallbackFormat="jpg"
          loading="lazy"
          class="h-full w-full object-cover"
        />
      </div>
    </div>
  </div>
  <div class="content-box relative z-20 flex w-full justify-start">
    <div class="flex">
      <div class="">
        <div
          class="text-emphasis mb-8 flex flex-col items-center gap-16 sm:flex-row"
        >
          <div class="">
            <div
              class="font-blackletter mb-4 flex items-end text-8xl leading-[0.6em] -tracking-wider sm:text-8xl md:text-7xl lg:text-7xl xl:text-9xl"
            >
              <span class="-ml-[0.1em]">3</span>
              <span class="-tracking-[0.125em]">9</span><span
                class="-tracking-[0.125em]">1</span
              ><span class="sr-only">&nbsp;</span>
              <span
                class="ml-2 text-xl leading-[0.55em] tracking-normal lg:text-3xl xl:text-5xl"
                >million</span
              >
            </div>
            <div
              class="text-foundation text-2xl leading-none font-medium tracking-wide md:text-3xl lg:text-xl xl:text-3xl"
            >
              monthly pageviews
            </div>
          </div>
          <div class="">
            <div
              class="font-blackletter mb-4 flex items-end text-8xl leading-[0.6em] -tracking-wider sm:text-8xl md:text-7xl lg:text-7xl xl:text-9xl"
            >
              <span class="-ml-[0.1em]">65</span><span class="sr-only"
                >&nbsp;</span
              >
              <span
                class="ml-2 text-xl leading-[0.55em] tracking-normal lg:text-3xl xl:text-5xl"
                >million</span
              >
            </div>
            <div
              class="text-foundation text-2xl leading-none font-medium tracking-wide md:text-3xl lg:text-xl xl:text-3xl"
            >
              unique visitors
            </div>
          </div>
        </div>
        <div class="bg-background/80 pr-8">
          <div class="mb-8 block w-full">
            <p class="mb-4 text-lg font-bold">
              Senior User Experience Developer ᠅ <Link
                href="https://alley.com/"
                target="_blank"
                variant="subtle">Alley Interactive</Link
              >
            </p>
            <p class="text-md mb-8">
              Primary development team for all NYP digital properties, working
              directly with editorial stakeholders.
            </p>
            <p class="mb-4 text-sm">
              Delivered UX improvements at massive scale on a custom enterprise
              stack hosted on <span class="inline-block break-keep"
                >WordPress VIP</span
              >. Built custom Gutenberg blocks, crafted responsive SCSS
              component styles, and maintained the unified theme system serving
              NYP, Page Six, and Decider.
            </p>
            <ul class="list-custom">
              <li>Component styling & responsive layouts</li>
              <li>Editorial workflow improvements</li>
              <li>Performance optimization</li>
              <li>WCAG accessibility compliance</li>
            </ul>
          </div>
          <span class="divider"></span>
          <div
            class="text-100 flex flex-col flex-wrap sm:flex-row sm:items-center"
          >
            <p class="text-md sm:text-md text-emphasis font-bold sm:mr-4">
              Technologies:
            </p>
            <ul
              class="list sm:text-md flex flex-row gap-2 text-sm font-light sm:flex-row sm:flex-wrap sm:gap-4"
            >
              <li>WordPress</li>
              <li>React</li>
              <li>Typescript</li>
              <li>SCSS</li>
              <li>PHP</li>
            </ul>
          </div>
        </div>
      </div>
    </div>

    <style>
      .browser {
        filter: drop-shadow(0.1rem 0.1rem 0.3rem rgba(0, 0, 0, 1));
      }
      .content-box {
        box-shadow: 0 0 1.2rem -0.4rem rgba(255, 0, 0, 0.1);
      }
    </style>
  </div>
</div>
