---
import Image from "astro/components/Image.astro";
import NypSpread from "../images/projects/site-spread.webp";
import NypostLogo from "../images/nypost-logo.svg?raw";
import statueOfLiberty from "../images/statue-of-liberty.jpg";
import Link from "./Link.astro";
---

<div
  class="relative z-0 container mx-auto mb-24 flex max-w-full flex-col items-start justify-center overflow-x-hidden py-24 font-light lg:flex-row"
>
  <span
    class="absolute top-0 left-0 z-10 h-1/4 w-full bg-gradient-to-b from-black to-transparent opacity-100"
  ></span>
  <span
    class="absolute bottom-0 left-0 z-10 h-1/4 w-full bg-gradient-to-t from-black to-transparent opacity-90"
  ></span>
  <!-- <span class="color__nyp-red--dark absolute top-0 left-0 z-0 h-full w-full"></span> -->
  <div class="relative z-10 w-full px-12 lg:max-w-1/2">
    <h3 class="sr-only">New York Post</h3>
    <div class="relative mb-4 max-w-92">
      <Fragment set:html={NypostLogo} />
    </div>
    <div class="relative isolate">
      <div
        class="nyp browser absolute top-0 right-0 isolate -z-1 w-[60vw] translate-x-4 overflow-visible"
      >
        <Image src={NypSpread} alt="New York Post" class="h-full w-full object-cover" />
      </div>
    </div>
  </div>
  <div class="content-box relative z-20 flex w-full justify-start">
    <div class="flex">
      <div class="">
        <div class="mb-4 flex flex-col items-center sm:flex-row">
          <div class="mr-12 font-bold">
            <div
              class="font-bokor mb-2 flex items-end text-8xl sm:text-8xl md:text-7xl lg:text-7xl xl:text-9xl"
            >
              391 <span class="mb-4 ml-2 text-xl lg:text-3xl xl:text-5xl">million</span>
            </div>
            <div
              class="font-bayon text-foundation -mt-4 ml-2 text-2xl md:text-3xl lg:text-xl xl:text-4xl"
            >
              monthly pageviews
            </div>
          </div>
          <div class="mfont-bold">
            <span
              class="font-bokor mb-2 flex items-end text-8xl sm:text-8xl md:text-7xl lg:text-7xl xl:text-9xl"
              >65 <span class="mb-4 ml-2 text-xl lg:text-3xl xl:text-5xl">million</span></span
            >
            <div
              class="font-bayon -mt-4 ml-2 text-2xl text-emerald-100 md:text-3xl lg:text-xl xl:text-4xl"
            >
              unique visitors
            </div>
          </div>
        </div>
        <div class="bg-background/80 pr-8">
          <div class="mb-8 block w-full text-emerald-100">
            <p class="mb-4 text-lg font-bold">
              Senior User Experience Developer ᠅ <Link
                href="https://alley.com/"
                target="_blank"
                variant="subtle">Alley Interactive</Link
              >
            </p>
            <p class="text-md mb-8">
              Primary development team for all NYP digital properties, working directly with
              editorial stakeholders.
            </p>
            <p class="mb-4 text-sm">
              Delivered UX improvements at massive scale on a custom enterprise stack hosted on <span
                class="inline-block break-keep">WordPress VIP</span
              >. Built custom Gutenberg blocks, crafted responsive SCSS component styles, and
              maintained the unified theme system serving NYP, Page Six, and Decider.
            </p>
            <ul class="list list-inside list-disc text-emerald-100">
              <li>Component styling & responsive layouts</li>
              <li>Editorial workflow improvements</li>
              <li>Performance optimization</li>
              <li>WCAG accessibility compliance</li>
            </ul>
          </div>
          <span class="divider"></span>
          <div class="text-100 flex flex-col flex-wrap sm:flex-row sm:items-center">
            <p class="text-md sm:text-md font-bold sm:mr-4">Technologies:</p>
            <ul
              class="list sm:text-md flex flex-row gap-2 text-sm font-light text-emerald-100 sm:flex-row sm:flex-wrap sm:gap-4"
            >
              <li>WordPress</li>
              <li>React</li>
              <li>Typescript</li>
              <li>SCSS</li>
              <li>PHP</li>
            </ul>
          </div>
        </div>
      </div>

      <!-- <div class="image__statueofliberty hidden w-full max-w-1/4 sm:block">
        <Image src={statueOfLiberty} alt="Statue of Liberty" class="h-full w-full object-cover" />
      </div> -->
    </div>

    <style>
      .browser {
        filter: drop-shadow(0.1rem 0.1rem 0.3rem rgba(0, 0, 0, 1));
      }
      .color__nyp-red {
        background-color: #c60800;
      }
      .color__nyp-red--text {
        color: #c60800;
      }
      .color__nyp-red--dark {
        background-color: #1e0b09;
      }
      .content-box {
        box-shadow: 0 0 1.2rem -0.4rem rgba(255, 0, 0, 0.1);
      }
    </style>
  </div>
</div>
