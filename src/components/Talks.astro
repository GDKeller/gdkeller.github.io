---
import HeadingSection from "./HeadingSection.astro";

interface Appearance {
  title: string;
  event: string;
  year: string;
  type: "youtube" | "audio";
  videoId?: string;
  startTime?: number;
  embedUrl?: string;
}

const appearances: Appearance[] = [
  {
    title: "Stable Diffusion Real-Time Tool Set",
    event: "Production Summit LA",
    year: "2023",
    type: "youtube",
    videoId: "n1TnQvNTTQ8",
  },
  {
    title: "Dynamic Expressions for 2D Characters",
    event: "Production Summit LA",
    year: "2024",
    type: "youtube",
    videoId: "JHZ976lIQ3E",
  },
  {
    title: "Inside Experiential AI (clip)",
    event: "The AI Chicks Podcast",
    year: "2024",
    type: "youtube",
    videoId: "MPKU_DaPws4",
  },
  {
    title: "Inside Experiential AI (full episode)",
    event: "The AI Chicks Podcast",
    year: "2024",
    type: "audio",
    embedUrl: "https://playlist.megaphone.fm/?e=WNCOP5493168652&wmode=opaque",
  },
  {
    title: "Badge Hacking Ceremony",
    event: "Hackaday Supercon",
    year: "2018",
    type: "youtube",
    videoId: "WCLlz_taeQk",
    startTime: 807,
  },
];

const sorted = [...appearances].sort((a, b) => Number(b.year) - Number(a.year));

const getEmbedSrc = (item: Appearance) => {
  if (item.type === "youtube" && item.videoId) {
    return `https://www.youtube.com/embed/${item.videoId}${item.startTime ? `?start=${item.startTime}` : ""}`;
  }
  return item.embedUrl ?? "";
};

const getPoster = (item: Appearance) => {
  if (item.type === "youtube" && item.videoId) {
    return `https://i.ytimg.com/vi/${item.videoId}/mqdefault.jpg`;
  }
  return null;
};

const total = sorted.length;
const pad2 = (n: number) => String(n).padStart(1, "0");
const initial = sorted[0];
---

<div class="container mx-auto max-w-7xl px-4 sm:px-6 md:px-8" data-talks>
  <HeadingSection text="Appearances" as="h2" align="left" class="mb-16" />

  <div class="grid gap-8 md:grid-cols-[1fr_auto_1.5fr] md:gap-0">
    <!-- Player stage -->
    <section
      class="border-faint order-3 border p-8 md:order-3 md:col-span-1"
      aria-label="Appearance player"
    >
      <div class="player-frame bg-background-dark relative">
        <span class="bracket tl" aria-hidden="true"></span>
        <span class="bracket tr" aria-hidden="true"></span>
        <span class="bracket bl" aria-hidden="true"></span>
        <span class="bracket br" aria-hidden="true"></span>
        <div class="relative z-110 aspect-video" data-player-slot data-slot-mode={initial.type}>
          <iframe
            src={getEmbedSrc(initial)}
            title={initial.title}
            class="h-full w-full border-0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            loading="lazy"
            scrolling={initial.type === "audio" ? "no" : undefined}></iframe>
        </div>
      </div>

      <div class="mt-8 flex items-stretch gap-4 pl-4">
        <div class="relative z-110 min-w-0 flex-1">
          <p
            class="text-accent mb-4 font-mono text-xs leading-none font-extralight tracking-widest uppercase"
            data-player-event
          >
            {initial.event}
          </p>
          <h3
            class="text-foundation font-display text-xl leading-tight tracking-wider md:text-2xl"
            data-player-title
          >
            {initial.title}
          </h3>
        </div>
      </div>
    </section>

    <div class="order-2 flex w-4 flex-col justify-center gap-1">
      <span class="bg-faint mt-auto block h-2"></span>
      <div class="border-faint mt-0 mb-0 h-full max-h-64 border-y-2 py-1">
        <span class="hazard-stripe__faint block h-full w-4"></span>
      </div>
      <span class="bg-faint mb-auto block h-2"></span>
    </div>

    <!-- Queue -->
    <aside
      class="border-faint bg-background-dark order-2 border md:order-1 md:col-span-1"
      aria-label="Appearance queue"
    >
      <div class="queue flex h-full flex-col">
        <div class="border-faint flex items-center justify-between border-b px-4 py-3">
          <p
            class="text-faint text-2xs font-mono leading-none font-extralight tracking-widest uppercase"
          >
            <span class="text-subtle tracking-tighter" aria-hidden="true">:::</span>
            <span class="ml-2">Queue</span>
          </p>
          <p
            class="text-faint text-2xs font-mono leading-none font-extralight tracking-widest uppercase tabular-nums"
          >
            {pad2(total)}&nbsp;<span class="text-subtle">tracks</span>
          </p>
        </div>
        <ul role="list" class="flex flex-1 flex-col">
          {
            sorted.map((item, idx) => (
              <li class="border-faint flex flex-1 border-t first:border-t-0">
                <button
                  type="button"
                  class:list={[
                    "track group relative flex w-full flex-1 cursor-pointer items-stretch gap-3 px-3 py-3 text-left",
                    idx === 0 && "is-active",
                  ]}
                  data-track
                  data-src={getEmbedSrc(item)}
                  data-title={item.title}
                  data-event={item.event}
                  data-year={item.year}
                  data-type={item.type}
                  aria-pressed={idx === 0 ? "true" : "false"}
                >
                  <span class="absolute top-0 left-0 h-full w-32 overflow-hidden">
                    <span
                      class="track__index text-faint absolute -top-[32%] -left-[0.05em] z-0 shrink-0 pt-1 text-right font-mono text-[8.75rem] leading-none font-extralight -tracking-widest uppercase tabular-nums opacity-50 transition duration-300"
                      aria-hidden="true"
                    >
                      {pad2(idx + 1)}
                    </span>
                  </span>
                  <span class="track__poster border-background-dark bg-background-dark relative ml-12 aspect-video w-24 shrink-0 overflow-hidden border-2">
                    {getPoster(item) ? (
                      <img
                        src={getPoster(item)!}
                        alt=""
                        class="h-full w-full object-cover"
                        loading="lazy"
                      />
                    ) : (
                      <span class="track__audio-tile flex h-full w-full items-center justify-center">
                        <span class="text-emphasis bg-background-dark text-body-2xs px-2 py-1 font-mono tracking-widest uppercase">
                          Audio
                        </span>
                      </span>
                    )}
                    <span class="track__playing" aria-hidden="true">
                      <span />
                      <span />
                      <span />
                    </span>
                  </span>
                  <span class="relative z-110 flex min-w-0 flex-1 flex-col">
                    <span class="track__title text-foundation text-body-sm line-clamp-2 leading-snug font-light">
                      {item.title}
                    </span>
                    <span class="track__event text-emphasis text-body-2xs mt-1 truncate font-mono font-extralight tracking-widest uppercase">
                      {item.event}
                    </span>
                    <span class="text-faint text-body-2xs mt-auto font-mono font-extralight tracking-widest uppercase tabular-nums">
                      {item.year}
                      <span class="text-subtle mx-0 hidden leading-none -tracking-widest sm:inline-block">
                        ᠅
                      </span>
                      {item.type === "audio" ? "Audio" : "Video"}
                    </span>
                  </span>
                </button>
              </li>
            ))
          }
        </ul>
      </div>
    </aside>
  </div>
</div>

<style lang="scss">
  @reference "../styles/global.css";

  .bracket {
    position: absolute;
    opacity: 0.3;

    &::before,
    &::after {
      content: "";
      position: absolute;
      background-color: var(--color-emphasis);
    }

    &::before {
      width: 1px;
      height: 0.5rem;
    }

    &::after {
      width: 0.5rem;
      height: 1px;
    }

    &.tl {
      top: 0;
      left: 0;

      &::before {
        top: -0.75rem;
        left: -1px;
      }
      &::after {
        top: -1px;
        left: -0.75rem;
      }
    }

    &.tr {
      top: 0;
      right: 0;

      &::before {
        top: -0.75rem;
        right: -1px;
      }
      &::after {
        top: -1px;
        right: -1rem;
      }
    }

    &.bl {
      bottom: 0;
      left: 0;

      &::before {
        bottom: -0.75rem;
        left: -1px;
      }
      &::after {
        bottom: -1px;
        left: -0.75rem;
      }
    }

    &.br {
      bottom: 0;
      right: 0;

      &::before {
        bottom: -0.75rem;
        right: -1px;
      }
      &::after {
        bottom: -1px;
        right: -0.75rem;
      }
    }
  }

  .track {
    transition: background-color 0.2s ease;

    &::before {
      content: "";
      position: absolute;
      top: 0;
      bottom: 0;
      right: 100%;
      width: 0px;
      background: var(--color-emphasis);
      transition:
        width 200ms,
        background 500ms;
      z-index: 1;
    }
    &::after {
      content: "";
      position: absolute;
      top: 0;
      height: 0px;
      width: 0px;
      right: 0;
      background: var(--color-emphasis);
      transition:
        width 300ms,
        height 200ms,
        background 500ms;
      z-index: 1;
      clip-path: polygon(0 0, 100% 0%, 100% 100%);
    }

    &:hover {
      background: color-mix(in oklch, var(--color-faint) 10%, transparent);
    }

    &:hover .track__index {
      @apply text-emphasis opacity-100;
    }
    &:hover .track__title {
      @apply text-emphasis-hover;
    }

    &:hover .track__event {
      @apply text-emphasis-hover;
    }

    &:hover::before {
      width: 8px;
    }
    &:hover::after {
      height: 16px;
      width: 24px;
    }

    &.is-active .track__title {
      @apply text-accent;
    }

    &.is-active .track__index {
      @apply text-accent opacity-100;
    }

    &.is-active .track__playing {
      opacity: 1;
    }

    &.is-active::before {
      width: 8px;
      background: var(--color-accent);
    }
    &.is-active::after {
      height: 16px;
      width: 24px;
      background: var(--color-accent);
    }
  }

  .track__audio-tile {
    background: repeating-linear-gradient(
      45deg,
      transparent 0,
      transparent 0.4rem,
      color-mix(in srgb, var(--color-emphasis) 25%, transparent) 0.4rem,
      color-mix(in srgb, var(--color-emphasis) 25%, transparent) 0.45rem
    );
  }

  .track__playing {
    position: absolute;
    right: 0.25rem;
    bottom: 0.25rem;
    display: flex;
    align-items: flex-end;
    gap: 2px;
    height: 0.7rem;
    opacity: 0;
    transition: opacity 0.2s ease;

    span {
      display: block;
      width: 2px;
      background: var(--color-accent);
      animation: equalize 0.9s ease-in-out infinite;

      &:nth-child(1) {
        animation-delay: 0s;
      }
      &:nth-child(2) {
        animation-delay: 0.25s;
      }
      &:nth-child(3) {
        animation-delay: 0.1s;
      }
    }
  }

  @keyframes equalize {
    0%,
    100% {
      height: 25%;
    }
    50% {
      height: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .track__playing span {
      animation: none;
      height: 60%;
    }
  }

  @media (prefers-contrast: more) {
    .bracket {
      opacity: 0.7;
    }
  }
</style>

<script>
  function initTalks() {
    const root = document.querySelector<HTMLElement>("[data-talks]");
    if (!root) return;

    const tracks = root.querySelectorAll<HTMLButtonElement>("[data-track]");
    const slot = root.querySelector<HTMLElement>("[data-player-slot]");
    const titleEl = root.querySelector<HTMLElement>("[data-player-title]");
    const eventEl = root.querySelector<HTMLElement>("[data-player-event]");
    if (!slot || !titleEl || !eventEl) return;

    const setActive = (button: HTMLButtonElement) => {
      const { src, title, event, type } = button.dataset;
      if (!src) return;

      const isAudio = type === "audio";
      slot.dataset.slotMode = type ?? "youtube";

      const iframe = document.createElement("iframe");
      iframe.src = src;
      iframe.title = title ?? "";
      iframe.className = "h-full w-full border-0";
      iframe.setAttribute(
        "allow",
        "accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture",
      );
      iframe.setAttribute("allowfullscreen", "");
      iframe.setAttribute("loading", "lazy");
      if (isAudio) iframe.setAttribute("scrolling", "no");

      slot.replaceChildren(iframe);

      titleEl.textContent = title ?? "";
      eventEl.textContent = event ?? "";

      tracks.forEach((t) => {
        const active = t === button;
        t.classList.toggle("is-active", active);
        t.setAttribute("aria-pressed", String(active));
      });
    };

    tracks.forEach((button) => {
      button.addEventListener("click", () => setActive(button));
    });
  }

  document.addEventListener("DOMContentLoaded", initTalks);
  document.addEventListener("astro:page-load", initTalks);
</script>
