---
import HeadingSection from "./HeadingSection.astro";

interface Appearance {
  title: string;
  event: string;
  year: string;
  type: "youtube" | "audio";
  videoId?: string;
  startTime?: number;
  embedUrl?: string;
}

const appearances: Appearance[] = [
  {
    title: "Stable Diffusion Real-Time Tool Set",
    event: "Production Summit LA",
    year: "2023",
    type: "youtube",
    videoId: "n1TnQvNTTQ8",
  },
  {
    title: "Dynamic Expressions for 2D Characters",
    event: "Production Summit LA",
    year: "2024",
    type: "youtube",
    videoId: "JHZ976lIQ3E",
  },
  {
    title: "Inside Experiential AI (clip)",
    event: "The AI Chicks Podcast",
    year: "2024",
    type: "youtube",
    videoId: "MPKU_DaPws4",
  },
  {
    title: "Inside Experiential AI (full episode)",
    event: "The AI Chicks Podcast",
    year: "2024",
    type: "audio",
    embedUrl: "https://playlist.megaphone.fm/?e=WNCOP5493168652&wmode=opaque",
  },
  {
    title: "Badge Hacking Ceremony",
    event: "Hackaday Supercon",
    year: "2018",
    type: "youtube",
    videoId: "WCLlz_taeQk",
    startTime: 807,
  },
];

const sorted = [...appearances].sort((a, b) => Number(b.year) - Number(a.year));

const getEmbedSrc = (item: Appearance) => {
  if (item.type === "youtube" && item.videoId) {
    return `https://www.youtube.com/embed/${item.videoId}${item.startTime ? `?start=${item.startTime}` : ""}`;
  }
  return item.embedUrl ?? "";
};

const getPoster = (item: Appearance, size: "mq" | "hq" = "mq") => {
  if (item.type === "youtube" && item.videoId) {
    return `https://i.ytimg.com/vi/${item.videoId}/${size}default.jpg`;
  }
  return null;
};

const initial = sorted[0];
---

<div class="container px-4 mx-auto max-w-7xl sm:px-6 md:px-8" data-talks>
  <HeadingSection text="Appearances" as="h2" align="left" class="mb-16" />

  <div class="grid gap-8 md:grid-cols-[1fr_auto_1.5fr] md:gap-0">
    <!-- Player stage -->
    <section
      class="order-3 p-8 border border-faint md:order-3 md:col-span-1"
      aria-label="Appearance player"
    >
      <div class="relative mb-8 player-frame bg-background-dark">
        <span class="bracket tl" aria-hidden="true"></span>
        <span class="bracket tr" aria-hidden="true"></span>
        <span class="bracket bl" aria-hidden="true"></span>
        <span class="bracket br" aria-hidden="true"></span>
        <div
          class="relative z-110 aspect-video"
          data-player-slot
          data-slot-mode={initial.type}
        >
          <button
            type="button"
            class="relative block w-full h-full p-0 border-0 cursor-pointer player-facade group bg-background-dark"
            data-player-facade
            data-src={getEmbedSrc(initial)}
            data-title={initial.title}
            data-type={initial.type}
            aria-label={`Play ${initial.title}`}
          >
            {
              getPoster(initial, "hq") ? (
                <img
                  src={getPoster(initial, "hq")!}
                  alt=""
                  class="object-cover w-full h-full"
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <span class="flex items-center justify-center w-full h-full player-facade__audio">
                  <span class="font-mono tracking-widest uppercase text-emphasis text-2xs">
                    Audio
                  </span>
                </span>
              )
            }
            <span class="player-facade__icon" aria-hidden="true">
              <svg viewBox="0 0 68 48" width="68" height="48" focusable="false">
                <path
                  class="player-facade__icon-bg"
                  d="M66.52 7.74c-.78-2.93-2.49-5.41-5.42-6.19C55.79.13 34 0 34 0S12.21.13 6.9 1.55c-2.93.78-4.63 3.26-5.42 6.19C.06 13.05 0 24 0 24s.06 10.95 1.48 16.26c.78 2.93 2.49 5.41 5.42 6.19C12.21 47.87 34 48 34 48s21.79-.13 27.1-1.55c2.93-.78 4.64-3.26 5.42-6.19C67.94 34.95 68 24 68 24s-.06-10.95-1.48-16.26z"
                ></path>
                <path class="player-facade__icon-arrow" d="M45 24 27 14v20"
                ></path>
              </svg>
            </span>
          </button>
        </div>
      </div>

      <div class="flex items-stretch gap-4 pl-4">
        <div class="relative flex-1 min-w-0 z-110">
          <p
            class="mb-2 font-mono leading-none tracking-widest uppercase text-accent text-2xs font-extralight"
            data-player-event
          >
            {initial.event}
          </p>
          <h3
            class="text-xl leading-tight tracking-wider text-foundation font-display md:text-2xl"
            data-player-title
          >
            {initial.title}
          </h3>
        </div>
      </div>
    </section>

    <div class="flex flex-col justify-center order-2 w-4 gap-1">
      <span class="block h-2 mt-auto bg-faint"></span>
      <div class="h-full py-1 mt-0 mb-0 border-faint max-h-64 border-y-2">
        <span class="block w-4 h-full hazard-stripe__faint"></span>
      </div>
      <span class="block h-2 mb-auto bg-faint"></span>
    </div>

    <!-- Queue -->
    <aside
      class="order-2 border border-faint bg-background-dark md:order-1 md:col-span-1"
      aria-label="Appearance queue"
    >
      <div class="flex flex-col h-full queue">
        <div
          class="flex items-center justify-between px-4 py-3 border-b border-faint"
        >
          <p
            aria-hidden="true"
            class="flex items-center font-mono leading-none tracking-widest uppercase text-emphasis text-2xs font-extralight"
          >
            <span class="font-light text-accent triplecolon" aria-hidden="true"
              >:::</span
            >
            <span class="ml-2">Queue</span>
          </p>
        </div>
        <ul role="list" class="flex flex-col flex-1">
          {
            sorted.map((item, idx) => (
              <li class="flex flex-1 border-t border-faint first:border-t-0">
                <button
                  type="button"
                  class:list={[
                    "track group relative flex w-full flex-1 cursor-pointer items-stretch gap-3 px-3 py-3 text-left",
                    idx === 0 && "is-active",
                  ]}
                  data-track
                  data-src={getEmbedSrc(item)}
                  data-title={item.title}
                  data-event={item.event}
                  data-year={item.year}
                  data-type={item.type}
                  aria-pressed={idx === 0 ? "true" : "false"}
                >
                  <span class="absolute top-0 left-0 w-32 h-full overflow-hidden">
                    <span
                      class="track__index text-faint absolute top-[-32%] left-[-0.05em] z-0 shrink-0 pt-1 text-right font-mono text-[8.75rem] leading-none font-extralight -tracking-widest uppercase tabular-nums opacity-50 transition duration-300"
                      aria-hidden="true"
                    >
                      {idx + 1}
                    </span>
                  </span>
                  <span class="relative w-24 ml-12 overflow-hidden border-2 track__poster border-background-dark bg-background-dark aspect-video shrink-0">
                    {getPoster(item) ? (
                      <img
                        src={getPoster(item)!}
                        alt=""
                        class="object-cover w-full h-full"
                        loading="lazy"
                      />
                    ) : (
                      <span class="flex items-center justify-center w-full h-full track__audio-tile">
                        <span class="px-2 py-1 font-mono tracking-widest uppercase text-emphasis bg-background-dark text-2xs">
                          Audio
                        </span>
                      </span>
                    )}
                    <span class="track__playing" aria-hidden="true">
                      <span />
                      <span />
                      <span />
                    </span>
                  </span>
                  <span class="relative flex flex-col flex-1 min-w-0 z-110">
                    <span class="mb-1 text-sm font-light leading-snug track__title text-foundation line-clamp-2">
                      {item.title}
                    </span>
                    <span class="font-mono tracking-widest uppercase truncate track__event text-emphasis text-2xs font-extralight">
                      {item.event}
                    </span>
                    <span class="mt-auto font-mono tracking-widest uppercase text-emphasis text-2xs font-extralight tabular-nums">
                      {item.year}
                      <span class="hidden mx-0 leading-none text-accent -tracking-widest sm:inline-block">
                        ᠅
                      </span>
                      {item.type === "audio" ? "Audio" : "Video"}
                    </span>
                  </span>
                </button>
              </li>
            ))
          }
        </ul>
      </div>
    </aside>
  </div>
</div>

<style lang="scss">
  @reference "../styles/global.css";

  .player-facade {
    position: relative;
    isolation: isolate;

    &::after {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(
        180deg,
        transparent 40%,
        color-mix(in oklch, var(--color-background-dark) 60%, transparent)
      );
      pointer-events: none;
      transition: opacity 240ms ease-out;
    }

    &:hover::after,
    &:focus-visible::after {
      opacity: 0.5;
    }
  }

  .player-facade__icon {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;

    svg {
      transition:
        transform 260ms cubic-bezier(0.22, 1, 0.36, 1),
        filter 260ms ease-out;
      filter: drop-shadow(
        0 0 18px color-mix(in oklch, var(--color-accent) 40%, transparent)
      );
    }
  }

  .player-facade__icon-bg {
    fill: color-mix(in oklch, var(--color-background-dark) 75%, transparent);
  }

  .player-facade__icon-arrow {
    fill: var(--color-accent);
  }

  .player-facade:hover .player-facade__icon svg,
  .player-facade:focus-visible .player-facade__icon svg {
    transform: scale(1.08);
    filter: drop-shadow(
      0 0 28px color-mix(in oklch, var(--color-accent) 75%, transparent)
    );
  }

  .player-facade:hover .player-facade__icon-bg {
    fill: var(--color-accent);
  }

  .player-facade:hover .player-facade__icon-arrow {
    fill: var(--color-background-dark);
  }

  @media (prefers-reduced-motion: reduce) {
    .player-facade::after,
    .player-facade__icon svg {
      transition-duration: 0ms;
    }
  }

  .bracket {
    position: absolute;
    opacity: 0.3;

    &::before,
    &::after {
      content: "";
      position: absolute;
      background-color: var(--color-emphasis);
    }

    &::before {
      width: 1px;
      height: 0.5rem;
    }

    &::after {
      width: 0.5rem;
      height: 1px;
    }

    &.tl {
      top: 0;
      left: 0;

      &::before {
        top: -0.75rem;
        left: -1px;
      }
      &::after {
        top: -1px;
        left: -0.75rem;
      }
    }

    &.tr {
      top: 0;
      right: 0;

      &::before {
        top: -0.75rem;
        right: -1px;
      }
      &::after {
        top: -1px;
        right: -1rem;
      }
    }

    &.bl {
      bottom: 0;
      left: 0;

      &::before {
        bottom: -0.75rem;
        left: -1px;
      }
      &::after {
        bottom: -1px;
        left: -0.75rem;
      }
    }

    &.br {
      bottom: 0;
      right: 0;

      &::before {
        bottom: -0.75rem;
        right: -1px;
      }
      &::after {
        bottom: -1px;
        right: -0.75rem;
      }
    }
  }

  .track {
    transition: background-color 0.2s ease;

    &::before {
      content: "";
      position: absolute;
      top: 0;
      bottom: 0;
      right: 100%;
      width: 0px;
      background: var(--color-emphasis);
      transition:
        width 200ms,
        background 500ms;
      z-index: 1;
    }
    &::after {
      content: "";
      position: absolute;
      top: 0;
      height: 0px;
      width: 0px;
      right: 0;
      background: var(--color-emphasis);
      transition:
        width 300ms,
        height 200ms,
        background 500ms;
      z-index: 1;
      clip-path: polygon(0 0, 100% 0%, 100% 100%);
    }

    &:hover {
      background: color-mix(in oklch, var(--color-faint) 10%, transparent);
    }

    &:hover .track__index {
      @apply text-emphasis opacity-100;
    }
    &:hover .track__title {
      @apply text-emphasis-hover;
    }

    &:hover .track__event {
      @apply text-emphasis-hover;
    }

    &:hover::before {
      width: 8px;
    }
    &:hover::after {
      height: 16px;
      width: 24px;
    }

    &.is-active .track__title {
      @apply text-accent;
    }

    &.is-active .track__index {
      @apply text-accent opacity-100;
    }

    &.is-active .track__playing {
      opacity: 1;
    }

    &.is-active::before {
      width: 8px;
      background: var(--color-accent);
    }
    &.is-active::after {
      height: 16px;
      width: 24px;
      background: var(--color-accent);
    }
  }

  .track__audio-tile {
    background: repeating-linear-gradient(
      45deg,
      transparent 0,
      transparent 0.4rem,
      color-mix(in srgb, var(--color-emphasis) 25%, transparent) 0.4rem,
      color-mix(in srgb, var(--color-emphasis) 25%, transparent) 0.45rem
    );
  }

  .track__playing {
    position: absolute;
    right: 0.25rem;
    bottom: 0.25rem;
    display: flex;
    align-items: flex-end;
    gap: 2px;
    height: 0.7rem;
    opacity: 0;
    transition: opacity 0.2s ease;

    span {
      display: block;
      width: 2px;
      background: var(--color-accent);
      animation: equalize 0.9s ease-in-out infinite;

      &:nth-child(1) {
        animation-delay: 0s;
      }
      &:nth-child(2) {
        animation-delay: 0.25s;
      }
      &:nth-child(3) {
        animation-delay: 0.1s;
      }
    }
  }

  @keyframes equalize {
    0%,
    100% {
      height: 25%;
    }
    50% {
      height: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .track__playing span {
      animation: none;
      height: 60%;
    }
  }

  @media (prefers-contrast: more) {
    .bracket {
      opacity: 0.7;
    }
  }
</style>

<script>
  function initTalks() {
    const root = document.querySelector<HTMLElement>("[data-talks]");
    if (!root) return;

    const tracks = root.querySelectorAll<HTMLButtonElement>("[data-track]");
    const slot = root.querySelector<HTMLElement>("[data-player-slot]");
    const titleEl = root.querySelector<HTMLElement>("[data-player-title]");
    const eventEl = root.querySelector<HTMLElement>("[data-player-event]");
    if (!slot || !titleEl || !eventEl) return;

    const mountIframe = (
      src: string,
      title: string,
      type: string,
      autoplay = false,
    ) => {
      const isAudio = type === "audio";
      slot.dataset.slotMode = type || "youtube";

      const iframe = document.createElement("iframe");
      iframe.src =
        autoplay && !isAudio
          ? `${src}${src.includes("?") ? "&" : "?"}autoplay=1`
          : src;
      iframe.title = title;
      iframe.className = "h-full w-full border-0";
      iframe.setAttribute(
        "allow",
        "accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture",
      );
      iframe.setAttribute("allowfullscreen", "");
      if (isAudio) iframe.setAttribute("scrolling", "no");

      slot.replaceChildren(iframe);
    };

    const setActive = (button: HTMLButtonElement) => {
      const { src, title, event, type } = button.dataset;
      if (!src) return;

      mountIframe(src, title ?? "", type ?? "youtube");

      titleEl.textContent = title ?? "";
      eventEl.textContent = event ?? "";

      tracks.forEach((t) => {
        const active = t === button;
        t.classList.toggle("is-active", active);
        t.setAttribute("aria-pressed", String(active));
      });
    };

    tracks.forEach((button) => {
      button.addEventListener("click", () => setActive(button));
    });

    const facade = slot.querySelector<HTMLButtonElement>(
      "[data-player-facade]",
    );
    if (facade) {
      facade.addEventListener(
        "click",
        () => {
          const { src, title, type } = facade.dataset;
          if (!src) return;
          mountIframe(src, title ?? "", type ?? "youtube", true);
        },
        { once: true },
      );
    }
  }

  document.addEventListener("DOMContentLoaded", initTalks);
  document.addEventListener("astro:page-load", initTalks);
</script>
